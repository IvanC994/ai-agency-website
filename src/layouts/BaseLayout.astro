---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';
import { BUSINESS_ADDRESS, BUSINESS_EMAIL, BUSINESS_PHONE, SITE_LOGO_URL, SITE_URL } from '../config/site';
const {
  title,
  description,
  canonical,
  ogImage = '/og-routineforge.png',
  lang = 'en',
  enUrl = SITE_URL,
  srUrl = `${SITE_URL}/sr`
} = Astro.props;
const siteTitle = lang === 'sr' ? 'RoutineForge | AI Agencija za Automatizaciju' : 'RoutineForge | AI Automation Agency';
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const pageDescription = description || 'RoutineForge helps businesses automate customer communication and repetitive workflows with AI-powered voice agents, chatbots, and intelligent automation.';
const pageCanonical = canonical || SITE_URL;
const pageOgImage = new URL(ogImage, pageCanonical).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#071126" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/logo-mark.png" />
    <link rel="canonical" href={pageCanonical} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="sr" href={srUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageOgImage} />
    <meta property="og:url" content={pageCanonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageOgImage} />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
      window.gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied'
      });
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'RoutineForge',
      url: SITE_URL,
      logo: SITE_LOGO_URL,
      description: pageDescription,
      address: BUSINESS_ADDRESS,
      email: BUSINESS_EMAIL,
      telephone: BUSINESS_PHONE,
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer service',
        email: BUSINESS_EMAIL,
        telephone: BUSINESS_PHONE,
        availableLanguage: ['English', 'Serbian']
      }
    })}></script>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      name: 'RoutineForge',
      url: SITE_URL,
      description: pageDescription,
      address: BUSINESS_ADDRESS,
      email: BUSINESS_EMAIL,
      telephone: BUSINESS_PHONE,
      areaServed: 'Global',
      serviceType: ['AI Phone Agent', 'AI Chatbots', 'Workflow Automation', 'Custom AI Solutions']
    })}></script>
    <title>{pageTitle}</title>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <slot />
    <CookieConsent />
    <script>
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const counters = document.querySelectorAll('[data-counter]');

      if (counters.length) {
        const animateCounter = (el: Element) => {
          const target = Number(el.getAttribute('data-target') || '0');
          const suffix = el.getAttribute('data-suffix') || '';

          if (prefersReducedMotion) {
            el.textContent = `${target}${suffix}`;
            return;
          }

          const duration = 1200;
          const start = performance.now();

          const step = (now: number) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = Math.round(target * eased);
            el.textContent = `${current}${suffix}`;
            if (progress < 1) requestAnimationFrame(step);
          };

          requestAnimationFrame(step);
        };

        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                animateCounter(entry.target);
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.5 }
        );

        counters.forEach((counter) => observer.observe(counter));
      }

      const revealEls = document.querySelectorAll('[data-reveal]');
      if (revealEls.length) {
        if (prefersReducedMotion) {
          revealEls.forEach((el) => el.classList.add('is-revealed'));
        } else {
          const revealObserver = new IntersectionObserver(
            (entries, obs) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-revealed');
                  obs.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
          );
          revealEls.forEach((el) => revealObserver.observe(el));
        }
      }
    </script>
  </body>
</html>
