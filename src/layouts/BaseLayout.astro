---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';
import {
  BRAND_NAME,
  BUSINESS_ADDRESS,
  BUSINESS_ALTERNATE_NAME,
  BUSINESS_EMAIL,
  BUSINESS_LEGAL_NAME,
  BUSINESS_LINKEDIN_URL,
  BUSINESS_PHONE,
  BUSINESS_REGISTRATION_NUMBER,
  BUSINESS_TAX_ID,
  SITE_LOGO_URL,
  SITE_URL
} from '../config/site';
const {
  title,
  description,
  canonical,
  ogImage = '/og-routineforge.png',
  ogImageAlt,
  lang = 'en',
  enUrl = `${SITE_URL}/`,
  srUrl = `${SITE_URL}/sr/`
} = Astro.props;
const siteTitle = 'RoutineForge';
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const pageDescription = description || 'RoutineForge helps businesses automate customer communication and repetitive workflows with AI-powered voice agents, chatbots, and intelligent automation.';
const pageCanonical = canonical || `${SITE_URL}/`;
const pageOgImage = new URL(ogImage, pageCanonical).href;
const pageOgImageAlt = ogImageAlt || (lang === 'sr'
  ? 'RoutineForge — AI automatizacije koje rade dok Vi spavate'
  : 'RoutineForge — AI automations that work while you sleep');
const organizationLogo = {
  '@type': 'ImageObject',
  url: SITE_LOGO_URL,
  contentUrl: SITE_LOGO_URL,
  width: 146,
  height: 153,
  caption: 'RoutineForge logo'
};
const brand = {
  '@type': 'Brand',
  '@id': `${SITE_URL}/#brand`,
  name: BRAND_NAME,
  url: `${SITE_URL}/`,
  logo: organizationLogo
};
const organization = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'ProfessionalService'],
  '@id': `${SITE_URL}/#organization`,
  name: BRAND_NAME,
  legalName: BUSINESS_LEGAL_NAME,
  alternateName: BUSINESS_ALTERNATE_NAME,
  url: `${SITE_URL}/`,
  logo: organizationLogo,
  image: organizationLogo,
  brand,
  description: pageDescription,
  address: BUSINESS_ADDRESS,
  email: BUSINESS_EMAIL,
  telephone: BUSINESS_PHONE,
  taxID: BUSINESS_TAX_ID,
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'Matični broj',
    value: BUSINESS_REGISTRATION_NUMBER
  },
  sameAs: [BUSINESS_LINKEDIN_URL],
  areaServed: 'Global',
  serviceType: ['AI Phone Agent', 'AI Chatbots', 'AI Workflow Automation', 'Web Development', 'Custom AI Systems'],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: BUSINESS_EMAIL,
    telephone: BUSINESS_PHONE,
    availableLanguage: ['English', 'Serbian']
  }
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#071126" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon.png" />
    <link rel="canonical" href={pageCanonical} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="sr" href={srUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageOgImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1731" />
    <meta property="og:image:height" content="909" />
    <meta property="og:image:alt" content={pageOgImageAlt} />
    <meta property="og:url" content={pageCanonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageOgImage} />
    <meta name="twitter:image:alt" content={pageOgImageAlt} />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
      window.gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied'
      });
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(organization)}></script>
    <title>{pageTitle}</title>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <slot />
    <CookieConsent />
    <script is:inline>
      const gaMeasurementId = 'G-F93XY4Y6CG';
      let googleAnalyticsLoaded = false;

      const readConsentPreferences = () => {
        try {
          const savedConsent = window.localStorage.getItem('bol-consent');
          return savedConsent ? JSON.parse(savedConsent) : null;
        } catch {
          return null;
        }
      };

      const loadGoogleAnalytics = () => {
        const preferences = readConsentPreferences();
        if (googleAnalyticsLoaded || !preferences?.analytics) return;
        googleAnalyticsLoaded = true;

        window.gtag('consent', 'update', {
          analytics_storage: 'granted',
          ad_storage: preferences.marketing ? 'granted' : 'denied',
          ad_user_data: preferences.marketing ? 'granted' : 'denied',
          ad_personalization: preferences.marketing ? 'granted' : 'denied'
        });

        const script = document.createElement('script');
        script.async = true;
        script.src = `https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`;
        document.head.appendChild(script);

        window.gtag('js', new Date());
        window.gtag('config', gaMeasurementId);
      };

      loadGoogleAnalytics();
      window.addEventListener('routineforge:cookie-consent', (event) => {
        if (event.detail?.analytics) loadGoogleAnalytics();
      });
    </script>
    <script>
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const counters = document.querySelectorAll('[data-counter]');

      if (counters.length) {
        const animateCounter = (el: Element) => {
          const target = Number(el.getAttribute('data-target') || '0');
          const suffix = el.getAttribute('data-suffix') || '';

          if (prefersReducedMotion) {
            el.textContent = `${target}${suffix}`;
            return;
          }

          const duration = 1200;
          const start = performance.now();

          const step = (now: number) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = Math.round(target * eased);
            el.textContent = `${current}${suffix}`;
            if (progress < 1) requestAnimationFrame(step);
          };

          requestAnimationFrame(step);
        };

        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                animateCounter(entry.target);
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.5 }
        );

        counters.forEach((counter) => observer.observe(counter));
      }

      const revealEls = document.querySelectorAll('[data-reveal]');
      if (revealEls.length) {
        if (prefersReducedMotion) {
          revealEls.forEach((el) => el.classList.add('is-revealed'));
        } else {
          const revealObserver = new IntersectionObserver(
            (entries, obs) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-revealed');
                  obs.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
          );
          revealEls.forEach((el) => revealObserver.observe(el));
        }
      }
    </script>
  </body>
</html>
