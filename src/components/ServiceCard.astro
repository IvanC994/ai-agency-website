---
const { title, description, bullets, icon = 'spark', href = '#contact' } = Astro.props;
---

<article class="group rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl">
  <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-sky-100 bg-sky-50 text-sky-600">
    {icon === 'phone' && <svg viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.7 2.6a2 2 0 0 1-.4 2.1L8.1 9.7a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.8.4 1.7.6 2.6.7a2 2 0 0 1 1.9 2.2Z" /></svg>}
    {icon === 'chat' && <svg viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.4 8.4 0 0 1-9 8.4 9.8 9.8 0 0 1-4.2-1L3 20l1.2-4A8.4 8.4 0 0 1 3 11.5a8.4 8.4 0 0 1 9-8.4 8.4 8.4 0 0 1 9 8.4Z" /><path d="M8 12h.01M12 12h.01M16 12h.01" /></svg>}
    {icon === 'workflow' && <svg viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m13 2-9 12h7l-1 8 10-13h-7z" /></svg>}
    {icon === 'custom' && <svg viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="5" width="14" height="14" rx="2" /><path d="M9 1v4M15 1v4M9 19v4M15 19v4M19 9h4M19 15h4M1 9h4M1 15h4" /></svg>}
    {icon === 'spark' && <slot name="icon" />}
  </div>
  <h3 class="text-xl font-semibold text-slate-950">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{description}</p>
  <ul class="mt-5 space-y-2 text-sm text-slate-600">
    {bullets.map((bullet) => <li class="flex items-start gap-2"><span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600"><svg viewBox="0 0 20 20" class="h-3 w-3 fill-none stroke-current" stroke-width="2.5" aria-hidden="true"><path d="m4 10 4 4 8-8" stroke-linecap="round" stroke-linejoin="round" /></svg></span><span>{bullet}</span></li>)}
  </ul>
  <a href={href} class="mt-6 inline-flex items-center text-sm font-semibold text-slate-950 transition hover:text-sky-700">
    Learn more <span class="ml-2">→</span>
  </a>
</article>
