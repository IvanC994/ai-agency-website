---
import LogoWordmark from './LogoWordmark.astro';
const isSerbianPage = Astro.url.pathname.startsWith('/sr');
const homeHref = isSerbianPage ? '/sr/' : '/';
const contactHref = `${homeHref}#contact`;
const privacyHref = isSerbianPage ? '/sr/privacy/' : '/privacy/';
const termsHref = isSerbianPage ? '/sr/terms/' : '/terms/';
const content = isSerbianPage
  ? {
      ctaEyebrow: 'Spremni za sledeći korak?',
      ctaTitle: 'Prestanite da gubite leadove dok je tim zauzet.',
      ctaText: 'Recite nam gde se upiti i vreme danas gube — zajedno ćemo osmisliti AI sistem koji rešava taj problem.',
      ctaButton: 'Zakažite besplatnu konsultaciju',
      explore: 'Istražite', contact: 'Kontakt', availability: 'AI sistemi aktivni 24/7', location: 'Niš, Serbia', serviceArea: 'Klijenti u Srbiji i širom sveta',
      description: 'AI sistemi koji hvataju, kvalifikuju i pretvaraju leadove u klijente — 24/7.',
      copyright: 'Sva prava zadržana.', privacy: 'Privatnost', terms: 'Uslovi korišćenja',
      links: [{ label: 'Usluge', href: '/sr/#services' }, { label: 'Proces', href: '/sr/#process' }, { label: 'ROI kalkulator', href: '/sr/#roi' }, { label: 'Česta pitanja', href: '/sr/#faq' }]
    }
  : {
      ctaEyebrow: 'Ready for the next step?',
      ctaTitle: 'Stop losing leads while your team is busy.',
      ctaText: 'Tell us where inquiries and time are disappearing today — together we will design an AI system that solves it.',
      ctaButton: 'Book a free consultation',
      explore: 'Explore', contact: 'Contact', availability: 'AI systems online 24/7', location: 'Niš, Serbia', serviceArea: 'Serving clients in Serbia and globally',
      description: 'AI systems that capture, qualify, and convert leads into customers — 24/7.',
      copyright: 'All rights reserved.', privacy: 'Privacy', terms: 'Terms',
      links: [{ label: 'Services', href: '/#services' }, { label: 'Process', href: '/#process' }, { label: 'ROI Calculator', href: '/#roi' }, { label: 'FAQ', href: '/#faq' }]
    };
---

<footer class="relative overflow-hidden bg-slate-950 text-white">
  <div class="h-px bg-gradient-to-r from-transparent via-sky-400 to-cyan-300"></div>
  <div class="absolute -left-24 top-0 h-52 w-52 rounded-full bg-sky-400/10 blur-3xl" aria-hidden="true"></div>
  <div class="absolute -right-24 bottom-0 h-52 w-52 rounded-full bg-cyan-400/10 blur-3xl" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
    <section class="grid gap-5 rounded-3xl border border-sky-300/20 bg-gradient-to-br from-slate-900 via-slate-900 to-sky-950 p-6 shadow-xl shadow-slate-950/30 sm:p-7 lg:grid-cols-[1fr_auto] lg:items-end" aria-label="Contact call to action">
      <div class="max-w-2xl">
        <p class="inline-flex rounded-full border border-sky-300/20 bg-sky-400/10 px-3 py-1 text-xs font-semibold text-sky-200">{content.ctaEyebrow}</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">{content.ctaTitle}</h2>
        <p class="mt-3 text-sm leading-6 text-slate-300">{content.ctaText}</p>
      </div>
      <a href={contactHref} class="group inline-flex items-center justify-center gap-2 rounded-full bg-sky-700 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-950/30 transition hover:bg-sky-800"><span>{content.ctaButton}</span><span class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span></a>
    </section>

    <div class="grid gap-7 py-7 md:grid-cols-[1fr_auto] md:py-8">
      <div>
        <a href={homeHref} class="inline-flex" aria-label="RoutineForge home">
          <LogoWordmark dark />
        </a>
        <p class="mt-3 max-w-sm text-sm leading-6 text-slate-300">{content.description}</p>
        <p class="mt-4 inline-flex items-center gap-2 text-xs font-medium text-sky-100"><span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span></span>{content.availability}</p>
      </div>

      <div class="grid gap-7 sm:grid-cols-2 sm:gap-14 lg:gap-20">
        <div>
          <h3 class="text-sm font-semibold text-white">{content.explore}</h3>
          <nav class="mt-3 grid gap-2 text-sm text-slate-300" aria-label={content.explore}>{content.links.map((link) => <a href={link.href} class="transition hover:text-sky-300">{link.label}</a>)}</nav>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-white">{content.contact}</h3>
          <div class="mt-3 grid gap-2 text-sm text-slate-300">
          <a href="mailto:office@routineforge.tech" class="transition hover:text-sky-300">office@routineforge.tech</a>
          <a href="https://www.linkedin.com" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-white/10 bg-white/5 text-slate-200 transition hover:border-sky-300/40 hover:bg-sky-400/10 hover:text-sky-300" aria-label="LinkedIn"><svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true"><path d="M5.3 3.5A2.3 2.3 0 1 1 .7 3.5a2.3 2.3 0 0 1 4.6 0ZM1.1 8.2h4.3V22H1.1V8.2ZM8.1 8.2h4.1v1.9h.1c.6-1.1 2-2.3 4.2-2.3 4.5 0 5.3 3 5.3 6.8V22h-4.3v-6.4c0-1.5 0-3.5-2.1-3.5s-2.5 1.7-2.5 3.4V22H8.1V8.2Z"/></svg><span class="sr-only">LinkedIn</span></a>
          <p class="mt-1 text-slate-200">{content.location}</p>
          <p class="max-w-[15rem] text-xs leading-5 text-slate-300">{content.serviceArea}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-2 border-t border-white/10 pt-5 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
      <p>© {new Date().getFullYear()} RoutineForge. {content.copyright}</p>
      <div class="flex gap-4"><a href={privacyHref} class="transition hover:text-sky-300">{content.privacy}</a><a href={termsHref} class="transition hover:text-sky-300">{content.terms}</a></div>
    </div>
  </div>
</footer>
