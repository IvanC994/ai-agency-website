---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import LogoMark from './LogoMark.astro';
import IndustryIcon from './IndustryIcon.astro';
import ServiceIcon from './ServiceIcon.astro';
import { SITE_URL } from '../config/site';

const { lang = 'en' } = Astro.props;
const isSr = lang === 'sr';
const contactHref = isSr ? '/sr#contact' : '/#contact';

const content = isSr
  ? {
      metaTitle: 'AI za agencije za nekretnine: kvalifikacija i zakazivanje',
      metaDescription: 'RoutineForge gradi AI chatbotove za nekretnine koji odgovaraju o oglasima, kvalifikuju kupce, zakazuju gledanja i aktiviraju CRM bazu.',
      canonical: `${SITE_URL}/sr/ai-za-nekretnine`, enUrl: `${SITE_URL}/ai-for-real-estate`, srUrl: `${SITE_URL}/sr/ai-za-nekretnine`,
      eyebrow: 'INDUSTRIJE · NEKRETNINE', title: 'AI kvalifikuje. Agent zatvara.',
      intro: 'Kupac koji čeka odgovor o stanu već gleda sledeći oglas. Gradimo AI sistem koji odmah odgovara o nekretninama, kvalifikuje prema budžetu, lokaciji, roku i finansiranju i zakazuje gledanje direktno u kalendar agenta.',
      primaryCta: 'Zakažite besplatnu konsultaciju', secondaryCta: 'Pogledajte prodajni tok',
      proof: [{ value: '24/7', label: 'odgovori o ceni, kvadraturi i dostupnosti' }, { value: 'Svaki upit', label: 'ulazi u kvalifikacioni tok' }, { value: 'Jedan CRM', label: 'preferencije, gledanja i sledeći korak' }],
      visualLabel: 'UPIT SA OGLASA · ILUSTRATIVNI PRIMER', buyer: 'Potencijalni kupac', assistant: 'RoutineForge Property AI',
      messages: ['Da li je stan od 67 m² na Vračaru još dostupan?', 'Jeste. Cena je 219.000 €. Da li kupujete iz sopstvenih sredstava ili putem kredita?', 'Kredit. Budžet mi je do 230.000 € i uselio bih se u naredna 3 meseca.'],
      visualStates: ['Budžet: do 230.000 €', 'Lokacija: Vračar', 'Rok: 3 meseca', 'Finansiranje: kredit'], visualOutcome: 'Kvalifikovan kupac · gledanje spremno za zakazivanje',
      painEyebrow: 'GDE AGENCIJE GUBE PROVIZIJE', painTitle: 'Prodaja nekretnine je igra brzine i pažnje: pobeđuje onaj ko prvi odgovori i ne zaboravi nijednog kupca.', painIntro: 'AI preuzima prijem i trijažu. Agenti rade ono što AI ne može — teren, odnos, procenu i pregovore.',
      pains: [
        { number: '01', title: 'Upiti stižu stalno, a agenti su na terenu', text: 'Dok agent vodi jedno gledanje, tri nova upita čekaju. Kupac ne čeka; piše sledećoj agenciji koja nudi sličan stan.' },
        { number: '02', title: 'Većina upita nikada ne postane kupovina', text: 'Upiti bez budžeta, roka i načina finansiranja troše sate. Bez kvalifikacije niko ne zna ko zaslužuje gledanje danas, a ko follow-up za šest meseci.' },
        { number: '03', title: 'Baza kupaca se ne koristi posle prvog kontakta', text: 'Kupac koji nije našao stan u martu možda kupuje u septembru, ali ga niko ne kontaktira kada se pojavi nekretnina koja odgovara njegovim kriterijumima.' }
      ],
      buildEyebrow: 'ŠTA GRADIMO ZA AGENCIJE', buildTitle: 'AI radi intake i kvalifikaciju. Agent dobija ozbiljnog kupca sa kompletnim kontekstom.', buildIntro: 'Sistem se povezuje sa bazom oglasa, komunikacionim kanalima, kalendarom i CRM-om, bez potrebe da agent odgovara na svako početno pitanje.',
      builds: [
        { icon: 'chat', title: 'AI chatbot za oglase', text: 'Odgovara o ceni, kvadraturi, spratu, dokumentaciji i dostupnosti na sajtu, Instagramu i WhatsAppu iz ažurne baze nekretnina.', outcome: 'Kada se oglas promeni ili proda, sledeći odgovor koristi novo stanje.' },
        { icon: 'workflow', title: 'Automatska kvalifikacija kupaca', text: 'Kroz razgovor utvrđuje budžet, lokaciju, rok useljenja, način finansiranja i druge važne kriterijume.', outcome: 'Agent dobija pripremljen profil i jasan prioritet.' },
        { icon: 'custom', title: 'Zakazivanje gledanja', text: 'Kvalifikovan kupac bira dozvoljen termin direktno u kalendaru, uz automatsku potvrdu i podsetnik.', outcome: 'Manje dogovaranja i manji rizik da gledanje propadne.' },
        { icon: 'custom', title: 'CRM baza koja prodaje mesecima kasnije', text: 'Svaki upit ulazi u CRM sa preferencijama, pa sistem obaveštava kupca kada u ponudu stigne odgovarajuća nekretnina.', outcome: 'Provizija dolazi iz uređene baze, ne iz slučajnosti.' },
        { icon: 'phone', title: 'Opcioni AI telefonski agent', text: 'Prima pozive sa oglasa, identifikuje nekretninu, prikuplja kriterijume i zakazuje razgovor ili gledanje prema pravilima.', outcome: 'Poziv sa terena postaje strukturiran lead umesto propuštene prilike.' }
      ],
      listingEyebrow: 'AŽURNA BAZA OGLASA', listingTitle: 'AI može da odgovori tačno samo ako je ponuda tačna.', listingText: 'Povezujemo sajt, CRM ili evidenciju koju agencija već koristi. Cena, status, dostupnost, karakteristike i dokumentacija imaju odobren izvor. Kada se nekretnina rezerviše ili proda, chatbot prestaje da je nudi.',
      listingCards: [{ label: 'Status', value: 'Dostupno', detail: 'Ažurirano danas u 09:42' }, { label: 'Cena', value: '219.000 €', detail: 'Odobrena javna cena' }, { label: 'Površina', value: '67 m²', detail: '2.5 sobe · III sprat' }, { label: 'Dokumentacija', value: 'Uknjiženo', detail: 'Detalje potvrđuje agent' }],
      sourceFlow: [{ label: 'Baza oglasa', text: 'Sajt, CRM, tabela ili property feed' }, { label: 'AI odgovor', text: 'Samo odobreni i aktuelni podaci' }, { label: 'Kupac', text: 'Odgovor, kvalifikacija i sledeći korak' }],
      qualifyEyebrow: 'PROFIL KUPCA PRE PRVOG POZIVA', qualifyTitle: 'Agent ne dobija „Zanima me stan”. Dobija razlog da reaguje.', qualifyText: 'Kvalifikacija ne odbacuje ljude — daje prioritet i odgovarajući follow-up. Ozbiljan kupac ide odmah agentu, dugoročan kupac ulazi u bazu, a nerelevantan upit ne prekida teren.',
      profile: [{ label: 'Budžet', value: '200–230k €' }, { label: 'Lokacija', value: 'Vračar / Zvezdara' }, { label: 'Rok', value: 'Do 3 meseca' }, { label: 'Finansiranje', value: 'Stambeni kredit' }, { label: 'Tip', value: '2–3 sobe · lift' }, { label: 'Prioritet', value: 'Visok' }],
      priorityStates: [{ level: 'Sada', title: 'Spreman za gledanje', text: 'Kriterijumi i finansiranje su jasni.' }, { level: 'Negovati', title: 'Kupovina za 3–6 meseci', text: 'Automatski match i relevantan follow-up.' }, { level: 'Arhiva', title: 'Nema definisan budžet', text: 'Čuva se uz dozvolu, bez trošenja vremena agenta.' }],
      calendarEyebrow: 'GLEDANJE BEZ PREPISKE U KRUG', calendarTitle: 'Kvalifikovan kupac bira termin dok je interesovanje još snažno.', calendarText: 'Sistem prikazuje samo termine i agente koji odgovaraju nekretnini, lokaciji i pravilima. Nakon rezervacije šalje potvrdu, podatke o lokaciji i podsetnik, a promene se beleže u CRM-u.',
      slots: ['Utorak · 17:30', 'Sreda · 12:00', 'Četvrtak · 18:15'], calendarStates: ['Termin rezervisan', 'Agent obavešten', 'Podsetnik zakazan'],
      crmEyebrow: 'CRM KOJI NE ZABORAVLJA KUPCA', crmTitle: 'Nova nekretnina automatski pronalazi stare upite kojima odgovara.', crmText: 'Kada se oglas doda, sistem poredi lokaciju, cenu, površinu, tip, rok i druge kriterijume sa profilima u bazi. Odgovarajući kupci dobijaju dozvoljenu, relevantnu poruku, a agent listu prioriteta.',
      matches: [{ buyer: 'Milica J.', criteria: 'Vračar · do 230k · 2–3 sobe', score: '96% match' }, { buyer: 'Nikola P.', criteria: 'Centar · do 250k · lift', score: '88% match' }, { buyer: 'Ana & Marko', criteria: 'Zvezdara/Vračar · kredit', score: '82% match' }],
      speedEyebrow: 'BRZINA ODGOVORA · PRODAJA NEKRETNINA', speedTitle: 'Upit o stanu retko stiže samo jednoj agenciji.', speedText: 'AI odgovara odmah čak i kada su svi agenti na gledanjima, prikuplja kriterijume i prosleđuje samo pripremljene kupce. Brzina privlači pažnju; dobra kvalifikacija je pretvara u ozbiljan razgovor.',
      speedBenefits: ['Svaki upit dobija odgovor i sledeće pitanje bez čekanja', 'Agent vidi budžet, lokaciju, rok i finansiranje pre kontakta', 'Kupac iz baze dobija poruku kada se pojavi relevantna nekretnina'],
      benchmarks: [{ value: '78%', label: 'kupaca bira ponuđača koji prvi odgovori', source: 'lead-response benchmark naveden na referentnoj stranici' }, { value: '21×', label: 'veća šansa kvalifikacije uz odgovor u prvih 5 minuta', source: 'HBR / MIT benchmark naveden na referentnoj stranici' }, { value: '7%', label: 'prodavaca odgovara u prvih 5 minuta', source: 'lead-response benchmark naveden na referentnoj stranici' }],
      benchmarkNote: 'Eksterni podaci ilustruju važnost brzine i nisu RoutineForge garancija prodajnog rezultata. Za agenciju merimo vreme odgovora, kvalifikovane leadove, zakazana gledanja i reaktivirane kupce.',
      segmentsEyebrow: 'JEDAN SISTEM · VIŠE TOKOVA', segmentsTitle: 'Prodaja, kupovina, izdavanje i novogradnja dobijaju različita pitanja i pravog agenta.', segments: [{ title: 'Kupci', text: 'Budžet, lokacija, rok, finansiranje i kriterijumi nekretnine.' }, { title: 'Zakupci', text: 'Mesečni budžet, datum useljenja, trajanje, ljubimci i posebni uslovi.' }, { title: 'Prodavci i stanodavci', text: 'Lokacija, tip, status dokumentacije i zahtev za procenu ili razgovor.' }, { title: 'Investitori i novogradnja', text: 'Dostupne jedinice, faza izgradnje, cenovnik, struktura i kvalifikacija za prodajni tim.' }],
      habitsTitle: 'Agenti ne moraju da menjaju ceo način rada.', habitsText: 'Kvalifikovani upiti mogu da stignu u CRM, e-mail, telefon ili drugi alat koji tim već koristi. Promena je u tome što agent više ne odgovara na svaki početni upit niti ručno vodi listu kupaca.',
      processEyebrow: 'OD OGLASA DO ZAKAZANOG GLEDANJA', processTitle: 'Prvo uređujemo podatke i kriterijume. Zatim automatizujemo razgovor.', process: [{ phase: '01', title: 'Snimak lead toka', text: 'Mapiramo kanale, bazu oglasa, pitanja kupaca, kriterijume kvalifikacije, kalendare, CRM i odgovornosti agenata.' }, { phase: '02', title: 'Podaci i scenariji', text: 'Definišemo izvore oglasa, statuse, pravila odgovora, profil kupca, prioritete i human handoff.' }, { phase: '03', title: 'Integracije i testiranje', text: 'Povezujemo prvi kanal, kalendar i CRM i testiramo prodate oglase, promene cena, nepotpune upite i rubne slučajeve.' }, { phase: '04', title: 'Lansiranje i aktivacija baze', text: 'Pokrećemo intake i zakazivanje, merimo kvalitet, pa dodajemo property matching i automatizovan follow-up.' }],
      faqEyebrow: 'ČESTA PITANJA', faqTitle: 'Šta agenti za nekretnine žele da znaju.',
      faqs: [
        { q: 'Kako AI zna podatke o nekretnini?', a: 'Iz baze oglasa koju odobrite: povezujemo sajt, CRM, tabelu ili drugi izvor. Kada se cena ili status promene, sistem koristi ažurirano stanje.' },
        { q: 'Da li kupci žele da razgovaraju sa AI sistemom?', a: 'Kupci pre svega žele brz i tačan odgovor. AI se predstavlja kao digitalni asistent agencije, a ozbiljan kupac brzo prelazi živom agentu sa već prikupljenim kriterijumima.' },
        { q: 'Da li radi i za prodavce i izdavanje?', a: 'Da. Sistem može da vodi odvojene tokove za kupovinu, prodaju, zakup i izdavanje i da svaki lead usmeri odgovarajućem agentu.' },
        { q: 'Koliko agenti moraju da menjaju navike?', a: 'Minimalno. Kvalifikovani upit stiže u alat koji već koriste — CRM, e-mail ili telefon. Glavna promena je što ne odgovaraju ručno na svako početno pitanje.' },
        { q: 'Koliko košta AI chatbot za agenciju?', a: 'Zavisi od broja kanala, izvora oglasa, kvalifikacionih tokova, kalendara i CRM integracije. Osnovni chatbot je manja investicija od kompletnog sistema sa bazom i matching automatizacijom.' },
        { q: 'Da li sistem radi za investitore i novogradnju?', a: 'Da. Može da odgovara o jedinicama u izgradnji, dostupnosti, strukturi i cenama, prikuplja kriterijume i priprema kupca za prodajni tim investitora.' }
      ],
      ctaTitle: 'AI filtrira. Agenti zatvaraju.', ctaText: 'Recite nam koliko upita stiže mesečno i kako ih danas pratite. Pokazaćemo gde se kriju kvalifikovani kupci, gledanja i provizije koje baza trenutno ne aktivira.', ctaButton: 'Zakažite konsultaciju'
    }
  : {
      metaTitle: 'AI for real estate: buyer qualification and viewing booking',
      metaDescription: 'RoutineForge builds real-estate AI chatbots that answer listing questions, qualify buyers, book viewings, and reactivate the CRM database.',
      canonical: `${SITE_URL}/ai-for-real-estate`, enUrl: `${SITE_URL}/ai-for-real-estate`, srUrl: `${SITE_URL}/sr/ai-za-nekretnine`,
      eyebrow: 'INDUSTRIES · REAL ESTATE', title: 'AI filters. Agents close.',
      intro: 'A buyer waiting for an answer about a property is already viewing the next listing. We build an AI system that answers instantly, qualifies by budget, location, timeline, and financing, and books viewings directly into the agent’s calendar.',
      primaryCta: 'Book a free consultation', secondaryCta: 'See the sales workflow',
      proof: [{ value: '24/7', label: 'answers about price, floor area, and availability' }, { value: 'Every enquiry', label: 'enters a qualification workflow' }, { value: 'One CRM', label: 'preferences, viewings, and next action' }],
      visualLabel: 'LISTING ENQUIRY · ILLUSTRATIVE EXAMPLE', buyer: 'Potential buyer', assistant: 'RoutineForge Property AI',
      messages: ['Is the 67 m² apartment in Vračar still available?', 'Yes. The price is €219,000. Are you purchasing with cash or mortgage financing?', 'Mortgage. My budget is up to €230,000, and I would move within three months.'],
      visualStates: ['Budget: up to €230,000', 'Location: Vračar', 'Timeline: 3 months', 'Financing: mortgage'], visualOutcome: 'Qualified buyer · viewing ready to book',
      painEyebrow: 'WHERE AGENCIES LOSE COMMISSIONS', painTitle: 'Selling property is a game of speed and attention: the winner replies first and forgets no buyer.', painIntro: 'AI handles intake and triage. Agents do what AI cannot — field work, relationships, judgment, and negotiation.',
      pains: [
        { number: '01', title: 'Enquiries arrive constantly while agents are in the field', text: 'While an agent runs one viewing, three new enquiries wait. The buyer does not; they message the next agency offering a similar property.' },
        { number: '02', title: 'Most enquiries never become a purchase', text: 'Enquiries without budget, timeline, or financing consume hours. Without qualification, nobody knows who deserves a viewing today and who needs follow-up in six months.' },
        { number: '03', title: 'The buyer database goes unused after first contact', text: 'A buyer who did not find a property in March may buy in September, but nobody contacts them when a matching listing enters the market.' }
      ],
      buildEyebrow: 'WHAT WE BUILD FOR AGENCIES', buildTitle: 'AI handles intake and qualification. The agent receives a serious buyer with full context.', buildIntro: 'The system connects listing data, communication channels, calendars, and CRM without asking agents to answer every initial question.',
      builds: [
        { icon: 'chat', title: 'AI chatbot for listings', text: 'It answers about price, floor area, floor, paperwork, and availability across web, Instagram, and WhatsApp from an updated property database.', outcome: 'When a listing changes or sells, the next answer uses the new state.' },
        { icon: 'workflow', title: 'Automatic buyer qualification', text: 'Through conversation, it establishes budget, location, move-in timeline, financing, and other important criteria.', outcome: 'The agent receives a prepared profile with a clear priority.' },
        { icon: 'custom', title: 'Viewing scheduling', text: 'A qualified buyer chooses an approved slot directly in the calendar, with automatic confirmation and reminder.', outcome: 'Less back-and-forth and lower risk of a missed viewing.' },
        { icon: 'custom', title: 'A CRM that sells months later', text: 'Every enquiry enters CRM with preferences, allowing the system to alert a buyer when a matching property appears.', outcome: 'Commission comes from an organized database, not chance.' },
        { icon: 'phone', title: 'Optional AI phone agent', text: 'It answers listing calls, identifies the property, captures criteria, and books a call or viewing according to rules.', outcome: 'A call from the field becomes a structured lead instead of a missed opportunity.' }
      ],
      listingEyebrow: 'AN UPDATED LISTING DATABASE', listingTitle: 'AI can answer accurately only when the offer is accurate.', listingText: 'We connect the website, CRM, or records the agency already uses. Price, status, availability, characteristics, and paperwork have an approved source. When a property is reserved or sold, the chatbot stops offering it.',
      listingCards: [{ label: 'Status', value: 'Available', detail: 'Updated today at 09:42' }, { label: 'Price', value: '€219,000', detail: 'Approved public price' }, { label: 'Floor area', value: '67 m²', detail: '2.5 rooms · third floor' }, { label: 'Paperwork', value: 'Registered', detail: 'Details confirmed by agent' }],
      sourceFlow: [{ label: 'Listing source', text: 'Website, CRM, spreadsheet, or property feed' }, { label: 'AI answer', text: 'Approved and current information only' }, { label: 'Buyer', text: 'Answer, qualification, and next step' }],
      qualifyEyebrow: 'A BUYER PROFILE BEFORE THE FIRST CALL', qualifyTitle: 'The agent does not receive “I am interested.” They receive a reason to act.', qualifyText: 'Qualification does not discard people — it assigns priority and the right follow-up. A serious buyer goes to an agent now, a long-term buyer enters the database, and an irrelevant enquiry does not interrupt field work.',
      profile: [{ label: 'Budget', value: '€200–230k' }, { label: 'Location', value: 'Vračar / Zvezdara' }, { label: 'Timeline', value: 'Within 3 months' }, { label: 'Financing', value: 'Mortgage' }, { label: 'Property type', value: '2–3 rooms · elevator' }, { label: 'Priority', value: 'High' }],
      priorityStates: [{ level: 'Now', title: 'Ready for a viewing', text: 'Criteria and financing are clear.' }, { level: 'Nurture', title: 'Buying in 3–6 months', text: 'Automatic matching and relevant follow-up.' }, { level: 'Archive', title: 'No defined budget', text: 'Stored with permission without consuming agent time.' }],
      calendarEyebrow: 'VIEWINGS WITHOUT ENDLESS MESSAGING', calendarTitle: 'A qualified buyer chooses a slot while interest is still strong.', calendarText: 'The system shows only slots and agents appropriate to the property, location, and rules. After booking, it sends confirmation, location details, and a reminder, while changes are logged in CRM.',
      slots: ['Tuesday · 17:30', 'Wednesday · 12:00', 'Thursday · 18:15'], calendarStates: ['Viewing booked', 'Agent notified', 'Reminder scheduled'],
      crmEyebrow: 'A CRM THAT DOES NOT FORGET THE BUYER', crmTitle: 'A new listing automatically finds old enquiries that match.', crmText: 'When a listing is added, the system compares location, price, floor area, type, timeline, and other criteria with buyer profiles. Matching buyers receive a permitted, relevant message, while agents receive a priority list.',
      matches: [{ buyer: 'Milica J.', criteria: 'Vračar · up to €230k · 2–3 rooms', score: '96% match' }, { buyer: 'Nikola P.', criteria: 'Centre · up to €250k · elevator', score: '88% match' }, { buyer: 'Ana & Marko', criteria: 'Zvezdara/Vračar · mortgage', score: '82% match' }],
      speedEyebrow: 'REPLY SPEED · SELLING PROPERTY', speedTitle: 'An enquiry about a property rarely reaches only one agency.', speedText: 'AI replies instantly even while every agent is at a viewing, collects criteria, and hands over prepared buyers only. Speed earns attention; good qualification turns it into a serious conversation.',
      speedBenefits: ['Every enquiry receives an answer and next question without waiting', 'The agent sees budget, location, timeline, and financing before contact', 'A buyer in the database receives a message when a relevant property appears'],
      benchmarks: [{ value: '78%', label: 'of buyers choose the provider who replies first', source: 'lead-response benchmark quoted by the reference page' }, { value: '21×', label: 'higher qualification likelihood with a reply in the first 5 minutes', source: 'HBR / MIT benchmark quoted by the reference page' }, { value: '7%', label: 'of sellers reply within the first 5 minutes', source: 'lead-response benchmark quoted by the reference page' }],
      benchmarkNote: 'External figures illustrate the importance of speed and are not a RoutineForge sales guarantee. For your agency, we measure response time, qualified leads, booked viewings, and reactivated buyers.',
      segmentsEyebrow: 'ONE SYSTEM · MULTIPLE WORKFLOWS', segmentsTitle: 'Sales, purchases, rentals, and new developments receive different questions and the right agent.', segments: [{ title: 'Buyers', text: 'Budget, location, timeline, financing, and property criteria.' }, { title: 'Tenants', text: 'Monthly budget, move-in date, lease length, pets, and special conditions.' }, { title: 'Sellers and landlords', text: 'Location, type, paperwork status, and a request for valuation or conversation.' }, { title: 'Developers and new builds', text: 'Available units, construction stage, pricing, structure, and qualification for the sales team.' }],
      habitsTitle: 'Agents do not have to change their entire way of working.', habitsText: 'Qualified enquiries can arrive in CRM, email, phone, or another tool the team already uses. The change is that agents no longer answer every initial question or maintain buyer lists manually.',
      processEyebrow: 'FROM LISTING TO BOOKED VIEWING', processTitle: 'First we organize data and criteria. Then we automate the conversation.', process: [{ phase: '01', title: 'Lead-flow discovery', text: 'We map channels, listing database, buyer questions, qualification criteria, calendars, CRM, and agent responsibilities.' }, { phase: '02', title: 'Data and scenarios', text: 'We define listing sources, statuses, answer rules, buyer profiles, priorities, and human handoff.' }, { phase: '03', title: 'Integration and testing', text: 'We connect the first channel, calendar, and CRM and test sold listings, price changes, incomplete enquiries, and edge cases.' }, { phase: '04', title: 'Launch and database activation', text: 'We launch intake and booking, measure quality, then add property matching and automated follow-up.' }],
      faqEyebrow: 'FREQUENTLY ASKED QUESTIONS', faqTitle: 'What real-estate agents want to know.',
      faqs: [
        { q: 'How does AI know the property details?', a: 'From the listing source you approve: website, CRM, spreadsheet, or another record. When price or status changes, the system uses the updated state.' },
        { q: 'Will buyers want to talk to an AI system?', a: 'Buyers mainly want a fast and accurate answer. AI introduces itself as the agency’s digital assistant, and a serious buyer quickly reaches a live agent with criteria already captured.' },
        { q: 'Does this work for sellers and rentals too?', a: 'Yes. The system can run separate workflows for buying, selling, renting, and letting and direct each lead to the appropriate agent.' },
        { q: 'How much do agents have to change their habits?', a: 'Minimally. A qualified enquiry reaches the tool they already use — CRM, email, or phone. The main change is that they no longer answer every initial question manually.' },
        { q: 'How much does an AI chatbot for an estate agency cost?', a: 'It depends on channels, listing sources, qualification workflows, calendars, and CRM integration. A basic chatbot is a smaller investment than a complete database and matching system.' },
        { q: 'Does it work for developers and new builds?', a: 'Yes. It can answer about units under construction, availability, layouts, and prices, capture criteria, and prepare buyers for the developer’s sales team.' }
      ],
      ctaTitle: 'AI filters. Agents close.', ctaText: 'Tell us how many enquiries arrive monthly and how you track them today. We will show where qualified buyers, viewings, and commissions are sleeping inside the database.', ctaButton: 'Book a consultation'
    };

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: isSr ? 'AI sistemi za agencije za nekretnine' : 'AI systems for real-estate agencies',
  serviceType: 'Real estate lead qualification and sales automation',
  provider: { '@type': 'Organization', name: 'RoutineForge', url: SITE_URL },
  areaServed: 'Global', description: content.metaDescription,
  availableChannel: { '@type': 'ServiceChannel', serviceUrl: content.canonical, availableLanguage: ['English', 'Serbian'] }
};
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} canonical={content.canonical} enUrl={content.enUrl} srUrl={content.srUrl} lang={isSr ? 'sr' : 'en'}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <div class="min-h-screen overflow-x-hidden bg-slate-50">
    <Navbar />
    <main>
      <section class="flow-grid-bg relative overflow-hidden border-b border-slate-200/80"><div class="absolute inset-0 bg-[radial-gradient(circle_at_82%_20%,rgba(14,165,233,0.16),transparent_32%),radial-gradient(circle_at_12%_70%,rgba(34,211,238,0.12),transparent_28%)]"></div><div class="relative mx-auto grid max-w-7xl gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:px-8 lg:py-24"><div data-reveal><p class="inline-flex items-center gap-2 rounded-full border border-sky-200 bg-white/80 px-3 py-1 text-sm font-semibold text-sky-700"><IndustryIcon icon="real-estate" />{content.eyebrow}</p><h1 class="mt-6 max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">{content.title}</h1><p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">{content.intro}</p><div class="mt-8 flex flex-wrap gap-3"><a href={contactHref} class="inline-flex items-center gap-2 rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-200 transition hover:bg-cyan-500">{content.primaryCta}<span>→</span></a><a href="#property-system" class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-sky-300 hover:text-sky-700">{content.secondaryCta}<span>↓</span></a></div><div class="mt-10 grid gap-3 sm:grid-cols-3">{content.proof.map((item) => <div class="rounded-2xl border border-white bg-white/75 p-4 shadow-sm backdrop-blur"><p class="font-semibold text-slate-950">{item.value}</p><p class="mt-1 text-xs leading-5 text-slate-500">{item.label}</p></div>)}</div></div><div data-reveal class="rounded-[2rem] border border-sky-300/30 bg-slate-950 p-5 text-white shadow-[0_30px_80px_-28px_rgba(2,132,199,0.6)] sm:p-7"><div class="flex items-center justify-between border-b border-white/10 pb-5"><div><p class="text-xs font-semibold tracking-[0.18em] text-sky-300">{content.visualLabel}</p><p class="mt-2 text-sm text-slate-400">Website · Instagram · WhatsApp</p></div><span class="rounded-2xl border border-sky-400/20 bg-sky-400/10 p-3 text-sky-300"><IndustryIcon icon="real-estate" /></span></div><div class="mt-6 space-y-3">{content.messages.map((message, index) => <div class:list={["max-w-[90%] rounded-2xl px-4 py-3 text-sm leading-6", index === 1 ? 'ml-auto bg-sky-500 text-white' : 'border border-white/10 bg-white/5 text-slate-200']}>{message}</div>)}</div><div class="mt-5 flex flex-wrap gap-2">{content.visualStates.map((state) => <span class="rounded-full border border-sky-400/20 bg-sky-400/10 px-3 py-1.5 text-xs font-semibold text-sky-200">{state}</span>)}</div><div class="mt-5 flex items-center gap-3 rounded-2xl border border-emerald-400/20 bg-emerald-400/10 p-4 text-sm font-semibold text-emerald-300"><span class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-emerald-400">✓</span>{content.visualOutcome}</div></div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.painEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.painTitle}</h2><p class="mt-5 text-lg leading-8 text-slate-600">{content.painIntro}</p></div><div class="mt-10 grid gap-5 md:grid-cols-3">{content.pains.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 80}ms`} class="rounded-3xl border border-slate-200 bg-white/90 p-7 shadow-sm"><span class="text-xs font-semibold tracking-[0.18em] text-sky-700">{item.number}</span><h3 class="mt-4 text-xl font-semibold text-slate-950">{item.title}</h3><p class="mt-3 leading-7 text-slate-600">{item.text}</p></article>)}</div></section>

      <section id="property-system" class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.buildEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">{content.buildTitle}</h2><p class="mt-5 text-lg leading-8 text-slate-300">{content.buildIntro}</p></div><div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">{content.builds.map((item, index) => <article data-reveal style={`--reveal-delay:${(index % 3) * 80}ms`} class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-7"><span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-sky-400/20 bg-sky-400/10 text-sky-300"><ServiceIcon icon={item.icon} /></span><h3 class="mt-5 text-xl font-semibold">{item.title}</h3><p class="mt-3 flex-1 leading-7 text-slate-300">{item.text}</p><p class="mt-5 border-t border-white/10 pt-4 text-sm font-semibold text-sky-200">{item.outcome}</p></article>)}</div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.listingEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.listingTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.listingText}</p></div><div data-reveal class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-xl shadow-slate-200/60"><div class="flex items-center justify-between border-b border-slate-100 pb-4"><div><p class="text-xs font-semibold tracking-[0.14em] text-sky-700">PROPERTY #RF-284</p><p class="mt-1 font-semibold text-slate-950">Vračar · 67 m²</p></div><span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">● Available</span></div><div class="mt-5 grid gap-3 sm:grid-cols-2">{content.listingCards.map((item) => <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4"><p class="text-xs font-semibold uppercase tracking-[0.14em] text-sky-700">{item.label}</p><p class="mt-2 font-semibold text-slate-950">{item.value}</p><p class="mt-1 text-xs text-slate-500">{item.detail}</p></article>)}</div></div></div><div class="mt-8 grid gap-3 md:grid-cols-3">{content.sourceFlow.map((item, index) => <article data-reveal class="relative rounded-3xl border border-slate-200 bg-white p-6 text-center shadow-sm"><p class="text-xs font-semibold text-sky-700">0{index + 1} · {item.label}</p><p class="mt-3 text-sm leading-6 text-slate-600">{item.text}</p>{index < content.sourceFlow.length - 1 && <span class="absolute -right-3 top-1/2 z-10 hidden h-6 w-6 -translate-y-1/2 items-center justify-center rounded-full bg-sky-500 text-xs text-white md:inline-flex">→</span>}</article>)}</div></section>

      <section class="border-y border-slate-200 bg-gradient-to-br from-sky-50 via-white to-cyan-50 py-20"><div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-start lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-white px-3 py-1 text-sm font-semibold text-sky-700">{content.qualifyEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.qualifyTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.qualifyText}</p><div class="mt-6 space-y-3">{content.priorityStates.map((item) => <article class="rounded-2xl border border-sky-100 bg-white/85 p-4"><p class="text-xs font-semibold uppercase tracking-[0.14em] text-sky-700">{item.level}</p><h3 class="mt-2 font-semibold text-slate-950">{item.title}</h3><p class="mt-1 text-xs leading-5 text-slate-500">{item.text}</p></article>)}</div></div><div data-reveal class="rounded-[2rem] border border-sky-200 bg-white p-6 shadow-xl shadow-sky-100"><div class="flex items-center gap-3 border-b border-slate-100 pb-4"><LogoMark size={38} /><div><p class="font-semibold text-slate-950">Qualified buyer profile</p><p class="text-xs text-emerald-600">● Ready for agent</p></div></div><div class="mt-5 grid gap-3 sm:grid-cols-2">{content.profile.map((item) => <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4"><p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">{item.label}</p><p class="mt-2 font-semibold text-slate-950">{item.value}</p></article>)}</div></div></div></section>

      <section class="mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-center lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.calendarEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.calendarTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.calendarText}</p></div><div data-reveal class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-2xl"><div class="flex items-center justify-between border-b border-white/10 pb-4"><p class="font-semibold">Viewing calendar</p><span class="text-xs text-sky-300">Vračar · Agent Ivan</span></div><div class="mt-5 grid gap-3 sm:grid-cols-3">{content.slots.map((slot, index) => <button type="button" class:list={["rounded-2xl border p-4 text-left text-sm font-semibold", index === 0 ? 'border-sky-400 bg-sky-400/15 text-sky-200' : 'border-white/10 bg-white/5 text-slate-300']}>{slot}</button>)}</div><div class="mt-5 flex flex-wrap gap-2">{content.calendarStates.map((state) => <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1.5 text-xs font-semibold text-emerald-300">✓ {state}</span>)}</div></div></section>

      <section class="bg-slate-950 py-20 text-white"><div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-center lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.crmEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">{content.crmTitle}</h2><p class="mt-5 leading-8 text-slate-300">{content.crmText}</p></div><div data-reveal class="rounded-[2rem] border border-white/10 bg-white/5 p-6"><div class="space-y-3">{content.matches.map((item, index) => <article class="grid gap-3 rounded-2xl border border-white/10 bg-slate-950/60 p-4 sm:grid-cols-[1fr_auto] sm:items-center"><div><p class="font-semibold">{item.buyer}</p><p class="mt-1 text-xs text-slate-400">{item.criteria}</p></div><span class:list={["w-max rounded-full px-3 py-1 text-xs font-semibold", index === 0 ? 'bg-emerald-400/10 text-emerald-300' : 'bg-sky-400/10 text-sky-300']}>{item.score}</span></article>)}</div><button type="button" class="mt-4 w-full rounded-xl bg-sky-500 px-4 py-3 text-sm font-semibold text-white">Notify matching buyers</button></div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.speedEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.speedTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.speedText}</p><ul class="mt-6 space-y-3">{content.speedBenefits.map((item) => <li class="flex items-start gap-3 text-sm leading-6 text-slate-700"><span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">✓</span>{item}</li>)}</ul></div><div data-reveal class="grid gap-3 sm:grid-cols-3">{content.benchmarks.map((item) => <article class="rounded-3xl border border-sky-200 bg-gradient-to-br from-white to-sky-50 p-6 shadow-sm"><p class="text-3xl font-semibold tracking-tight text-sky-700">{item.value}</p><p class="mt-3 text-sm font-semibold leading-6 text-slate-800">{item.label}</p><p class="mt-4 border-t border-sky-100 pt-3 text-[11px] leading-5 text-slate-500">{item.source}</p></article>)}</div></div><p class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-xs leading-6 text-amber-900">{content.benchmarkNote}</p></section>

      <section class="border-y border-slate-200 bg-white/70 py-20"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.segmentsEyebrow}</p><h2 class="mt-5 max-w-3xl text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.segmentsTitle}</h2></div><div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">{content.segments.map((item) => <article data-reveal class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h3 class="font-semibold text-slate-950">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p></article>)}</div><div data-reveal class="mt-6 rounded-3xl border border-sky-200 bg-sky-50 p-6"><h3 class="font-semibold text-slate-950">{content.habitsTitle}</h3><p class="mt-2 text-sm leading-7 text-slate-600">{content.habitsText}</p></div></div></section>

      <section class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.processEyebrow}</p><h2 class="mt-5 max-w-3xl text-3xl font-semibold tracking-tight sm:text-4xl">{content.processTitle}</h2></div><div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">{content.process.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 80}ms`} class="rounded-3xl border border-white/10 bg-white/5 p-6"><p class="text-xs font-semibold tracking-[0.17em] text-sky-300">{item.phase}</p><h3 class="mt-5 text-lg font-semibold">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-300">{item.text}</p></article>)}</div></div></section>

      <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="text-center"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.faqEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.faqTitle}</h2></div><div class="mt-10 space-y-3">{content.faqs.map((item) => <details data-reveal class="group rounded-2xl border border-slate-200 bg-white/90 p-5 shadow-sm"><summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-slate-950"><span>{item.q}</span><span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-sky-50 text-sky-700 transition group-open:rotate-45">+</span></summary><p class="mt-4 max-w-3xl border-t border-slate-100 pt-4 leading-7 text-slate-600">{item.a}</p></details>)}</div></section>

      <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8"><div data-reveal class="relative overflow-hidden rounded-[2rem] border border-sky-400/20 bg-slate-950 p-8 text-center text-white shadow-[0_30px_90px_-25px_rgba(15,23,42,0.6)] sm:p-12"><div class="absolute left-1/2 top-0 h-64 w-64 -translate-x-1/2 rounded-full bg-sky-400/15 blur-3xl"></div><div class="relative"><h2 class="mx-auto max-w-4xl text-3xl font-semibold tracking-tight sm:text-4xl">{content.ctaTitle}</h2><p class="mx-auto mt-5 max-w-2xl leading-8 text-slate-300">{content.ctaText}</p><a href={contactHref} class="mt-8 inline-flex items-center gap-2 rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-950/30 transition hover:bg-cyan-400">{content.ctaButton}<span>→</span></a></div></div></section>
    </main>
    <Footer />
  </div>
</BaseLayout>
