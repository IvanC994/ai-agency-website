---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import LogoMark from './LogoMark.astro';
import IndustryIcon from './IndustryIcon.astro';
import ServiceIcon from './ServiceIcon.astro';
import { SITE_URL } from '../config/site';

const { lang = 'en' } = Astro.props;
const isSr = lang === 'sr';
const contactHref = isSr ? '/sr/#contact' : '/#contact';

const content = isSr
  ? {
      metaTitle: 'AI za stomatologe: telefonski agent, chatbot, podsetnici i CRM',
      metaDescription: 'RoutineForge povezuje AI telefonskog agenta, chatbot, podsetnike, aktivaciju pacijenata i CRM u sistem za stomatološke ordinacije.',
      canonical: `${SITE_URL}/sr/ai-za-stomatologe/`, enUrl: `${SITE_URL}/ai-for-dentists/`, srUrl: `${SITE_URL}/sr/ai-za-stomatologe/`,
      eyebrow: 'INDUSTRIJE · STOMATOLOŠKE ORDINACIJE', title: 'Puniji raspored. Manje propuštenih termina. Mirnija recepcija.',
      intro: 'Gradimo povezan sistem za komunikaciju sa pacijentima: AI telefonski agent i chatbot koji odgovaraju i zakazuju, automatske podsetnike i recall poruke, kao i CRM sa istorijom pacijenta — prilagođeno načinu rada Vaše ordinacije.',
      primaryCta: 'Zakažite besplatnu konsultaciju', secondaryCta: 'Pogledajte šta gradimo',
      proof: [{ value: '24/7', label: 'pozivi, poruke i prijem upita' }, { value: '1 istorija', label: 'termini, razgovori i sledeći koraci' }, { value: 'Human handoff', label: 'tim preuzima kada je potrebno' }],
      visualLabel: 'TOK PACIJENTA', visualTitle: 'Od prvog pitanja do sledeće kontrole.',
      patient: 'Novi pacijent', messages: ['Da li imate pregled sledeće nedelje?', 'Imamo utorak u 17:30 ili četvrtak u 18:00.', 'Utorak mi odgovara.'],
      visualStates: ['Termin rezervisan', 'Podsetnik zakazan', 'CRM ažuriran'],
      painEyebrow: 'GDE ORDINACIJA GUBI VREME I PRIHOD', painTitle: 'Četiri problema koja se ponavljaju svakog dana.', painIntro: 'Dobar sistem ne počinje od AI alata, već od trenutaka u kojima pacijent čeka, termin ostaje prazan ili informacija nestaje između recepcije i ordinacije.',
      pains: [
        { icon: '01', title: 'Pacijenti zaboravljaju termine', text: 'Prazna stolica znači izgubljeno vreme i prihod, dok tim troši sate na ručne pozive i podsetnike.' },
        { icon: '02', title: 'Kontrole se ne zakazuju same', text: 'Posle intervencije nema doslednog poziva na kontrolu, čišćenje kamenca ili nastavak terapije, pa vredan follow-up tiho nestaje.' },
        { icon: '03', title: 'Telefon zvoni dok radite', text: 'Najviše upita stiže kada su ruke sa pacijentom. Ako niko ne odgovori, sledeći poziv često ide drugoj ordinaciji.' },
        { icon: '04', title: 'Podaci su na više mesta', text: 'Termini, dogovori, beleške i istorija komunikacije ostaju u sveskama, tabelama i inboxima, pa tim proverava iste stvari više puta.' }
      ],
      buildEyebrow: 'ŠTA GRADIMO ZA ORDINACIJU', buildTitle: 'Jedan sistem, od prvog upita do godišnje kontrole.', buildIntro: 'Nije generički paket. Biramo module i pravila prema procedurama, timu, kanalima i softveru koji već koristite.',
      builds: [
        { title: 'AI telefonski agent', text: 'Javlja se kada je recepcija zauzeta ili ordinacija ne radi, odgovara na dozvoljena pitanja, prikuplja podatke, zakazuje i prosleđuje osetljive pozive timu.', outcome: 'Svaki poziv dobija odgovor i jasan sledeći korak.' },
        { title: 'AI chatbot koji zakazuje', text: 'Na sajtu, WhatsAppu ili Instagramu odgovara na pitanja o uslugama i okvirnom procesu, prikuplja podatke i nudi dozvoljene termine 24/7.', outcome: 'Brži odgovor i manje propuštenih upita.' },
        { title: 'Automatski podsetnici i recall', text: 'Šalje potvrde, podsetnike, pozive na kontrolu, čišćenje ili nastavak terapije u trenutku koji definišete.', outcome: 'Sistem pamti umesto ručne liste poziva.' },
        { title: 'CRM i evidencija pacijenata', text: 'Povezuje kontakt, termine, poruke, beleške, saglasnosti i sledeće korake u pregled koji tim može odmah da razume.', outcome: 'Manje prepisivanja i traženja informacija.' },
        { title: 'Baza kontakata koja radi', text: 'Segmentira pacijente za relevantan follow-up: nisu dolazili godinu dana, završili su proceduru ili im dolazi vreme za održavanje.', outcome: 'Dosledna reaktivacija bez masovnih, nepersonalizovanih poruka.' }
      ],
      chatEyebrow: 'AI CHATBOT · SAJT, WHATSAPP, INSTAGRAM', chatTitle: 'Pacijent dobija odgovor i termin dok ordinacija ne radi.', chatText: 'Chatbot vodi kratak, jasan razgovor u tonu ordinacije. Objašnjava dostupne informacije, predlaže termin i predaje razgovor članu tima kada pitanje zahteva stručnu procenu ili poseban dogovor.',
      chatBenefits: ['Pacijent može da rezerviše, potvrdi ili zatraži pomeranje termina u razgovoru', 'Recepcija manje vremena provodi na ponavljajućim pitanjima', 'Večernji i vikend upiti ne čekaju sledeći radni dan'],
      phoneEyebrow: 'AI TELEFONSKI AGENT · SVAKI POZIV DOBIJA ODGOVOR', phoneTitle: 'Digitalna podrška recepciji dok je tim sa pacijentom.', phoneText: 'AI agent se javlja na postojeći ili novi broj, utvrđuje razlog poziva i vodi samo odobrene tokove. Može da ponudi raspoloživ termin, potvrdi ili zatraži promenu, zabeleži ishod u CRM-u i uključi čoveka kada je poziv hitan, osetljiv ili klinički.',
      phoneBenefits: ['Odgovara tokom gužve, van radnog vremena i kao overflow za recepciju', 'Zakazuje, menja ili otkazuje termine prema pravilima kalendara', 'Ne postavlja dijagnozu — stručna, hitna i nejasna pitanja prosleđuje timu'],
      phoneCallLabel: 'DOLAZNI POZIV · ILUSTRATIVNI PRIMER', phoneCaller: 'Pacijent', phoneAgent: 'RoutineForge AI agent', phoneTranscript: ['Dobar dan, želeo bih prvi pregled zbog bola u zubu.', 'Mogu da Vam pomognem oko zakazivanja. Da li je u pitanju jak bol, otok ili povreda koja zahteva hitnu procenu?', 'Nema otoka ni povrede. Odgovarao bi mi termin posle 17h.'], phoneStates: ['Razlog poziva zabeležen', 'Termin pronađen', 'CRM i recepcija obavešteni'],
      reminderEyebrow: 'PODSETNICI I PORUKE PREMA PROCEDURI', reminderTitle: 'Nije svaki pacijent u istom trenutku svog puta.', reminderText: 'Zajedno definišemo scenarije, vreme, kanal i ton poruke. Pacijent može da odgovori, a tim preuzima razgovor kada je potreban čovek.',
      reminderSteps: [{ time: 'Odmah', title: 'Potvrda zakazivanja', text: 'Termin, lokacija i potrebna priprema.' }, { time: 'Dan ranije', title: 'Podsetnik', text: 'Potvrda ili zahtev za promenu u istom razgovoru.' }, { time: 'Posle procedure', title: 'Sledeći korak', text: 'Dogovorena kontrola ili nastavak terapije.' }, { time: 'Za 6–12 meseci', title: 'Recall', text: 'Personalizovan poziv na pregled ili održavanje.' }],
      crmEyebrow: 'APLIKACIJA ORDINACIJE · POVEZANI CRM', crmTitle: 'Sve što telefonski agent, chatbot i podsetnici dogovore ostaje zabeleženo.', crmText: 'Tim otvara jedan pregled i vidi kontakt, termine, pozive, poruke, status podsetnika, beleške i sledeću akciju. Kada je praktično, aplikacija radi u pregledaču bez lokalne instalacije i povezuje se sa postojećim alatima.',
      crmCards: [{ label: 'Pacijent', value: 'Milica Jovanović', detail: 'Aktivan plan terapije' }, { label: 'Sledeći termin', value: 'Uto · 17:30', detail: 'Potvrđen putem WhatsAppa' }, { label: 'Poslednja poruka', value: 'Podsetnik potvrđen', detail: 'Automatski upisano' }, { label: 'Sledeća akcija', value: 'Kontrola za 6 meseci', detail: 'Recall je zakazan' }],
      outcomesEyebrow: 'MERITE ONO ŠTO JE VAŽNO', outcomesTitle: 'Jasan sistem mora da pokaže poslovni rezultat.', outcomesText: 'Ne obećavamo tuđe brojke. Pre implementacije beležimo početno stanje i dogovaramo metrike koje RoutineForge sistem treba da poboljša.',
      outcomes: [{ label: 'No-show stopa', text: 'Udeo propuštenih termina pre i posle podsetnika.' }, { label: 'Follow-up zakazivanja', text: 'Broj kontrola i nastavaka terapije pokrenutih automatski.' }, { label: 'Vreme administracije', text: 'Sati utrošeni na pozive, prepisivanje i ručno praćenje.' }, { label: 'Brzina odgovora', text: 'Koliko upita dobija odgovor i sledeći korak bez čekanja.' }],
      dataEyebrow: 'PODACI I POSTOJEĆI ALATI', dataTitle: 'Sistem se prilagođava ordinaciji, ne obrnuto.', dataText: 'Prvo proveravamo softver, kalendar, kanale i mogućnosti integracije. Ako postoji API, povezujemo ga. Ako ne postoji, definišemo kontrolisan uvoz/izvoz kako tim ne bi radio isti posao dvaput.',
      dataPoints: [{ title: 'Vlasništvo nad podacima', text: 'Podaci ostaju Vaši; pristup dobijaju samo ovlašćene uloge prema dogovorenoj svrsi.' }, { title: 'Zvanični kanali', text: 'Poruke se šalju kroz odgovarajuće poslovne kanale, uz identitet i ton ordinacije.' }, { title: 'Minimalan obim', text: 'Čuvamo i prosleđujemo samo podatke potrebne za konkretan tok.' }, { title: 'Ljudska kontrola', text: 'Tim može da preuzme razgovor, promeni status i zaustavi automatizaciju.' }],
      processEyebrow: 'OD ANALIZE DO PRVE VERZIJE', processTitle: 'Počnite malim tokom koji odmah rasterećuje tim.', process: [{ phase: '01', title: 'Snimak procesa', text: 'Mapiramo pozive, poruke, zakazivanje, podsetnike, recall, postojeći softver i odgovornosti tima.' }, { phase: '02', title: 'Prioritet i blueprint', text: 'Biramo prvi modul, scenarije, kanale, podatke, integracije i metrike uspeha.' }, { phase: '03', title: 'Izrada i testiranje', text: 'Gradimo tok i testiramo realna pitanja, pozive, termine, izuzetke, promene i human handoff.' }, { phase: '04', title: 'Postepeno lansiranje', text: 'Prva fokusirana verzija često može da radi za 2–4 nedelje; zatim širimo sistem po dokazanoj vrednosti.' }],
      faqEyebrow: 'ČESTA PITANJA', faqTitle: 'Šta stomatološke ordinacije žele da znaju.',
      faqs: [
        { q: 'Može li AI telefonski agent da koristi naš postojeći broj?', a: 'Često može kroz prosleđivanje, SIP ili podržanog telefonskog provajdera. Pre implementacije proveravamo operatera, zemlju, postojeću konfiguraciju i fallback kada veza ili integracija nisu dostupne.' },
        { q: 'Da li sistem radi uz softver koji već koristimo?', a: 'Da, gde postoji pouzdana integracija. Kada alat nema otvoren interfejs, proveravamo kontrolisan uvoz i izvoz ili drugi praktičan način da tim ne prepisuje podatke.' },
        { q: 'Koliko traje implementacija?', a: 'Fokusirana prva verzija sa podsetnicima i bazom pacijenata često može da bude spremna za 2–4 nedelje. Kompletniji CRM se uvodi fazno, u zavisnosti od obima i integracija.' },
        { q: 'Kako pacijenti reaguju na automatske poruke?', a: 'Poruke su najprihvatljivije kada stižu na kanalu koji pacijent već koristi, pod identitetom ordinacije i u jasnom tonu. Pacijent može da odgovori, a osoblje preuzima kada je potrebno.' },
        { q: 'Šta je sa podacima pacijenata?', a: 'Opseg, pristup, čuvanje i kanali definišu se prema svrsi i primenljivim pravilima zaštite podataka. AI ne treba da daje dijagnozu; osetljive i stručne teme se prosleđuju odgovornoj osobi.' },
        { q: 'Koliko košta sistem za ordinaciju?', a: 'Zavisi od modula, kanala, integracija i obima. Podsetnici su manja investicija od kompletnog CRM-a. Posle konsultacije dobijate fazni predlog sa troškovima i jasnim prvim rezultatom.' }
      ],
      ctaTitle: 'Vi lečite pacijente. Sistem pamti.', ctaText: 'Na besplatnoj konsultaciji prolazimo kroz procese ordinacije i predlažemo šta uvesti prvo, kako povezati postojeće alate i kojim metrikama proveriti rezultat.', ctaButton: 'Zakažite konsultaciju'
    }
  : {
      metaTitle: 'AI for dentists: phone agent, chatbot, reminders, and CRM',
      metaDescription: 'RoutineForge connects an AI phone agent, chatbot, reminders, patient reactivation, and CRM into one system for dental practices.',
      canonical: `${SITE_URL}/ai-for-dentists/`, enUrl: `${SITE_URL}/ai-for-dentists/`, srUrl: `${SITE_URL}/sr/ai-za-stomatologe/`,
      eyebrow: 'INDUSTRIES · DENTAL PRACTICES', title: 'A fuller schedule. Fewer missed appointments. A calmer front desk.',
      intro: 'We build one connected patient communication system: an AI phone agent and chatbot that answer and book, automatic reminders and recall messages, plus a CRM with patient history — shaped around how your practice works.',
      primaryCta: 'Book a free consultation', secondaryCta: 'See what we build',
      proof: [{ value: '24/7', label: 'calls, messages, and enquiry capture' }, { value: '1 history', label: 'appointments, conversations, and next steps' }, { value: 'Human handoff', label: 'your team takes over when needed' }],
      visualLabel: 'PATIENT JOURNEY', visualTitle: 'From the first question to the next check-up.',
      patient: 'New patient', messages: ['Do you have a check-up next week?', 'We have Tuesday at 17:30 or Thursday at 18:00.', 'Tuesday works for me.'],
      visualStates: ['Appointment booked', 'Reminder scheduled', 'CRM updated'],
      painEyebrow: 'WHERE THE PRACTICE LOSES TIME AND REVENUE', painTitle: 'Four problems that repeat every day.', painIntro: 'A useful system starts with the moments where a patient waits, a chair remains empty, or information disappears between reception and treatment.',
      pains: [
        { icon: '01', title: 'Patients forget appointments', text: 'An empty chair costs time and revenue, while the team spends hours on manual calls and reminders.' },
        { icon: '02', title: 'Check-ups do not book themselves', text: 'After treatment, there is no consistent invitation for a check-up, cleaning, or continued care, so valuable follow-up quietly disappears.' },
        { icon: '03', title: 'The phone rings while you work', text: 'Many enquiries arrive while your hands are with a patient. If nobody answers, the next call often goes to another practice.' },
        { icon: '04', title: 'Information lives in several places', text: 'Appointments, agreements, notes, and conversation history sit in notebooks, spreadsheets, and inboxes, so the team checks the same facts twice.' }
      ],
      buildEyebrow: 'WHAT WE BUILD FOR DENTAL PRACTICES', buildTitle: 'One system, from the first enquiry to next year’s check-up.', buildIntro: 'This is not a generic package. We select modules and rules around your procedures, team, channels, and existing software.',
      builds: [
        { title: 'AI phone agent', text: 'It answers when reception is busy or the practice is closed, handles approved questions, captures details, books appointments, and hands sensitive calls to your team.', outcome: 'Every call receives an answer and a clear next step.' },
        { title: 'An AI chatbot that books', text: 'On your website, WhatsApp, or Instagram, it answers questions about services and the general process, captures details, and offers approved slots 24/7.', outcome: 'Faster replies and fewer lost enquiries.' },
        { title: 'Automatic reminders and recall', text: 'It sends confirmations, reminders, and invitations for check-ups, cleanings, or continued treatment at the moment you define.', outcome: 'The system remembers instead of a manual call list.' },
        { title: 'CRM and patient records', text: 'It connects contacts, appointments, messages, notes, agreements, and next steps in a view the whole team can understand.', outcome: 'Less retyping and less searching for information.' },
        { title: 'A contact database that works', text: 'It segments patients for relevant follow-up: no visit in a year, a completed procedure, or upcoming maintenance.', outcome: 'Consistent reactivation without generic mass messaging.' }
      ],
      chatEyebrow: 'AI CHATBOT · WEBSITE, WHATSAPP, INSTAGRAM', chatTitle: 'Patients get an answer and a slot while the practice is closed.', chatText: 'The chatbot holds a short, clear conversation in your practice’s tone. It explains approved information, proposes a slot, and hands the conversation to a team member when a question needs clinical judgment or a special arrangement.',
      chatBenefits: ['Patients can book, confirm, or request a new time inside the conversation', 'Reception spends less time answering the same questions', 'Evening and weekend enquiries do not wait for the next working day'],
      phoneEyebrow: 'AI PHONE AGENT · EVERY CALL GETS AN ANSWER', phoneTitle: 'Digital front-desk support while your team is with a patient.', phoneText: 'The AI agent answers an existing or new number, identifies the reason for the call, and follows approved workflows only. It can offer an available slot, confirm or request a change, log the outcome in the CRM, and involve a person when the call is urgent, sensitive, or clinical.',
      phoneBenefits: ['Answers during busy periods, after hours, or as reception overflow', 'Books, moves, or cancels appointments according to calendar rules', 'Does not diagnose — clinical, urgent, and unclear questions go to your team'],
      phoneCallLabel: 'INBOUND CALL · ILLUSTRATIVE EXAMPLE', phoneCaller: 'Patient', phoneAgent: 'RoutineForge AI agent', phoneTranscript: ['Hello, I would like a first appointment because of tooth pain.', 'I can help with booking. Is there severe pain, swelling, or an injury that needs urgent assessment?', 'There is no swelling or injury. A time after 17:00 would work.'], phoneStates: ['Call reason recorded', 'Appointment found', 'CRM and reception notified'],
      reminderEyebrow: 'MESSAGES SHAPED AROUND EACH PROCEDURE', reminderTitle: 'Not every patient is at the same point in their journey.', reminderText: 'Together, we define the scenario, timing, channel, and tone. Patients can reply, and your team takes over whenever a person is needed.',
      reminderSteps: [{ time: 'Immediately', title: 'Booking confirmation', text: 'Time, location, and required preparation.' }, { time: 'One day before', title: 'Reminder', text: 'Confirm or request a change in the same chat.' }, { time: 'After treatment', title: 'Next step', text: 'An agreed check-up or continued treatment.' }, { time: 'In 6–12 months', title: 'Recall', text: 'A personalized invitation for a check-up or maintenance.' }],
      crmEyebrow: 'PRACTICE APP · CONNECTED CRM', crmTitle: 'Everything agreed by the phone agent, chatbot, and reminders stays recorded.', crmText: 'Your team opens one view and sees the contact, appointments, calls, messages, reminder status, notes, and next action. Where practical, the application runs in a browser with no local installation and connects to existing tools.',
      crmCards: [{ label: 'Patient', value: 'Milica Jovanović', detail: 'Active treatment plan' }, { label: 'Next appointment', value: 'Tue · 17:30', detail: 'Confirmed via WhatsApp' }, { label: 'Latest message', value: 'Reminder confirmed', detail: 'Logged automatically' }, { label: 'Next action', value: 'Check-up in 6 months', detail: 'Recall scheduled' }],
      outcomesEyebrow: 'MEASURE WHAT MATTERS', outcomesTitle: 'A connected system must show a business outcome.', outcomesText: 'We do not present another company’s numbers as ours. Before implementation, we record a baseline and agree on the metrics the RoutineForge system should improve.',
      outcomes: [{ label: 'No-show rate', text: 'The share of missed appointments before and after reminders.' }, { label: 'Follow-up bookings', text: 'Check-ups and continued treatments triggered systematically.' }, { label: 'Administrative time', text: 'Hours spent calling, retyping, and manually following up.' }, { label: 'Response speed', text: 'How many enquiries receive an answer and next step without waiting.' }],
      dataEyebrow: 'DATA AND EXISTING TOOLS', dataTitle: 'The system fits the practice, not the other way around.', dataText: 'We first review your software, calendar, channels, and integration options. If an API exists, we connect it. If not, we define controlled import and export so your team does not do the same job twice.',
      dataPoints: [{ title: 'Data ownership', text: 'Your data remains yours; only authorized roles receive access for the agreed purpose.' }, { title: 'Official channels', text: 'Messages use suitable business channels with your practice identity and tone.' }, { title: 'Minimum necessary data', text: 'We store and transfer only what the specific workflow needs.' }, { title: 'Human control', text: 'Your team can take over a conversation, change a status, or stop automation.' }],
      processEyebrow: 'FROM DISCOVERY TO THE FIRST VERSION', processTitle: 'Start with one focused workflow that immediately relieves the team.', process: [{ phase: '01', title: 'Process discovery', text: 'We map calls, messages, booking, reminders, recall, current software, and team responsibilities.' }, { phase: '02', title: 'Priority and blueprint', text: 'We choose the first module, scenarios, channels, data, integrations, and success metrics.' }, { phase: '03', title: 'Build and testing', text: 'We test real questions, calls, appointments, exceptions, changes, and human handoff.' }, { phase: '04', title: 'Phased rollout', text: 'A focused first version can often run in 2–4 weeks; we expand after the first workflow proves its value.' }],
      faqEyebrow: 'FREQUENTLY ASKED QUESTIONS', faqTitle: 'What dental practices want to know.',
      faqs: [
        { q: 'Can the AI phone agent use our existing number?', a: 'Often, yes, through call forwarding, SIP, or a supported telephony provider. Before implementation, we check the carrier, country, current setup, and fallback when a connection or integration is unavailable.' },
        { q: 'Does it work with the software we already use?', a: 'Yes, where a reliable integration exists. If a tool has no open interface, we review controlled import and export or another practical option that avoids double entry.' },
        { q: 'How long does implementation take?', a: 'A focused first version with reminders and a patient database can often be ready in 2–4 weeks. A broader custom CRM is introduced in phases depending on scope and integrations.' },
        { q: 'How do patients react to automatic messages?', a: 'Messages are most natural when they arrive in a channel patients already use, under the practice identity and in a clear tone. Patients can reply, and staff take over when needed.' },
        { q: 'What about patient data?', a: 'Scope, access, retention, and channels are defined around the purpose and applicable data protection requirements. The AI should not diagnose; sensitive or clinical questions are handed to a responsible person.' },
        { q: 'How much does a system for a practice cost?', a: 'It depends on modules, channels, integrations, and volume. Reminders are a smaller investment than a complete CRM. After consultation, you receive a phased proposal with costs and a clear first outcome.' }
      ],
      ctaTitle: 'You treat patients. The system remembers.', ctaText: 'In a free consultation, we walk through the practice processes and propose what to introduce first, how to connect existing tools, and which metrics will prove the result.', ctaButton: 'Book a consultation'
    };

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: isSr ? 'AI sistemi za stomatološke ordinacije' : 'AI systems for dental practices',
  serviceType: 'Dental practice automation',
  provider: { '@type': 'Organization', name: 'RoutineForge', url: `${SITE_URL}/` },
  areaServed: 'Global', description: content.metaDescription,
  availableChannel: { '@type': 'ServiceChannel', serviceUrl: content.canonical, availableLanguage: ['English', 'Serbian'] }
};
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} canonical={content.canonical} enUrl={content.enUrl} srUrl={content.srUrl} lang={isSr ? 'sr' : 'en'}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <div class="min-h-screen overflow-x-hidden bg-slate-50">
    <Navbar />
    <main>
      <section class="flow-grid-bg relative overflow-hidden border-b border-slate-200/80">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_82%_20%,rgba(14,165,233,0.16),transparent_32%),radial-gradient(circle_at_12%_70%,rgba(34,211,238,0.12),transparent_28%)]"></div>
        <div class="relative mx-auto grid max-w-7xl gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:px-8 lg:py-24">
          <div data-reveal>
            <p class="inline-flex items-center gap-2 rounded-full border border-sky-200 bg-white/80 px-3 py-1 text-sm font-semibold text-sky-700"><IndustryIcon icon="dental" />{content.eyebrow}</p>
            <h1 class="mt-6 max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">{content.title}</h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">{content.intro}</p>
            <div class="mt-8 flex flex-wrap gap-3"><a href={contactHref} class="inline-flex items-center gap-2 rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-200 transition hover:bg-cyan-500">{content.primaryCta}<span>→</span></a><a href="#what-we-build" class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-sky-300 hover:text-sky-700">{content.secondaryCta}<span>↓</span></a></div>
