---
const isSerbianPage = Astro.url.pathname.startsWith('/sr');
const content = isSerbianPage
  ? {
      title: 'Vaša privatnost',
      text: 'Koristimo neophodno čuvanje vašeg izbora. Analitiku i marketing uključujemo samo uz vaš pristanak.',
      privacy: 'Politika privatnosti',
      accept: 'Prihvatam',
      reject: 'Odbijam',
      settings: 'Podešavanja',
      settingsTitle: 'Podešavanja kolačića',
      settingsText: 'Izaberite koje neobavezne kategorije dozvoljavate. Neophodno čuvanje izbora je uvek aktivno.',
      analytics: 'Analitika',
      analyticsText: 'Pomaže nam da razumemo korišćenje sajta.',
      marketing: 'Marketing',
      marketingText: 'Pomaže nam da merimo učinak oglasa.',
      save: 'Sačuvaj izbor',
      necessary: 'Samo neophodno'
    }
  : {
      title: 'Your privacy',
      text: 'We use necessary storage to remember your choice. Analytics and marketing are enabled only with your consent.',
      privacy: 'Privacy Policy',
      accept: 'Accept',
      reject: 'Reject',
      settings: 'Settings',
      settingsTitle: 'Cookie preferences',
      settingsText: 'Choose which optional categories you allow. Necessary preference storage is always enabled.',
      analytics: 'Analytics',
      analyticsText: 'Helps us understand how the website is used.',
      marketing: 'Marketing',
      marketingText: 'Helps us measure advertising performance.',
      save: 'Save preferences',
      necessary: 'Necessary only'
    };
const privacyHref = isSerbianPage ? '/sr/privacy/' : '/privacy/';
---

<section data-cookie-banner class="fixed inset-x-4 bottom-4 z-[70] mx-auto hidden max-w-xl rounded-2xl border border-sky-200/80 bg-white p-5 shadow-[0_24px_70px_-25px_rgba(15,23,42,0.35)] sm:bottom-6 sm:p-6" aria-label={content.title} role="region">
  <div class="flex gap-4">
    <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-sky-100 text-sky-700" aria-hidden="true"><svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8"><path d="M12 3a9 9 0 1 0 9 9" stroke-linecap="round"/><path d="M17.5 3.5a3.5 3.5 0 1 0 3 5.3A9 9 0 0 0 17.5 3.5Z" stroke-linejoin="round"/><circle cx="8.5" cy="10" r="1" fill="currentColor"/><circle cx="12" cy="15" r="1" fill="currentColor"/><circle cx="7" cy="16" r="1" fill="currentColor"/></svg></span>
    <div>
      <h2 class="font-semibold text-slate-950">{content.title}</h2>
      <p class="mt-1 text-sm leading-6 text-slate-600">{content.text} <a href={privacyHref} class="font-medium text-sky-700 underline decoration-sky-300 underline-offset-2 hover:text-sky-950">{content.privacy}</a></p>
    </div>
  </div>
  <div class="mt-5 flex flex-wrap gap-2 sm:justify-end">
    <button type="button" data-cookie-settings class="rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-sky-200 hover:bg-sky-50">{content.settings}</button>
    <button type="button" data-cookie-reject class="rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50">{content.reject}</button>
    <button type="button" data-cookie-accept class="rounded-full bg-sky-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-cyan-500">{content.accept}</button>
  </div>
</section>

<dialog data-cookie-dialog class="w-[calc(100%-2rem)] max-w-md rounded-2xl border border-slate-200 bg-white p-0 text-slate-900 shadow-2xl backdrop:bg-slate-950/45">
  <form data-cookie-form class="p-6">
    <div class="flex items-start justify-between gap-4">
      <div><h2 class="text-xl font-semibold tracking-tight">{content.settingsTitle}</h2><p class="mt-2 text-sm leading-6 text-slate-600">{content.settingsText}</p></div>
      <button type="button" data-cookie-close class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-slate-500 transition hover:bg-slate-100 hover:text-slate-900" aria-label="Close">×</button>
    </div>
    <div class="mt-6 space-y-3">
      <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 bg-slate-50 p-4"><input type="checkbox" checked disabled class="mt-1 h-4 w-4 accent-sky-600" /><span><span class="block text-sm font-semibold">{content.necessary}</span><span class="mt-1 block text-xs leading-5 text-slate-500">localStorage</span></span></label>
      <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 p-4 transition hover:border-sky-200"><input data-cookie-analytics type="checkbox" class="mt-1 h-4 w-4 accent-sky-600" /><span><span class="block text-sm font-semibold">{content.analytics}</span><span class="mt-1 block text-xs leading-5 text-slate-500">{content.analyticsText}</span></span></label>
      <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 p-4 transition hover:border-sky-200"><input data-cookie-marketing type="checkbox" class="mt-1 h-4 w-4 accent-sky-600" /><span><span class="block text-sm font-semibold">{content.marketing}</span><span class="mt-1 block text-xs leading-5 text-slate-500">{content.marketingText}</span></span></label>
    </div>
    <div class="mt-6 flex flex-wrap justify-end gap-2"><button type="button" data-cookie-reject class="rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">{content.necessary}</button><button type="submit" class="rounded-full bg-sky-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-500">{content.save}</button></div>
  </form>
</dialog>

<script>
  const storageKey = 'bol-consent';
  const banner = document.querySelector('[data-cookie-banner]');
  const dialog = document.querySelector('[data-cookie-dialog]');
  const analyticsInput = document.querySelector('[data-cookie-analytics]');
  const marketingInput = document.querySelector('[data-cookie-marketing]');
  const cookieForm = document.querySelector('[data-cookie-form]');
  const consentWindow = window as typeof window & { dataLayer?: unknown[][] };

  const readConsent = () => {
    try {
      const stored = window.localStorage.getItem(storageKey);
      return stored ? JSON.parse(stored) : null;
    } catch {
      return null;
    }
  };

  const updateGoogleConsent = (preferences) => {
    consentWindow.dataLayer = consentWindow.dataLayer || [];
    consentWindow.dataLayer.push(['consent', 'update', {
      analytics_storage: preferences.analytics ? 'granted' : 'denied',
      ad_storage: preferences.marketing ? 'granted' : 'denied',
      ad_user_data: preferences.marketing ? 'granted' : 'denied',
      ad_personalization: preferences.marketing ? 'granted' : 'denied'
    }]);
  };

  const saveConsent = (preferences) => {
    const value = { ...preferences, updatedAt: new Date().toISOString() };
    window.localStorage.setItem(storageKey, JSON.stringify(value));
    updateGoogleConsent(value);
    window.dispatchEvent(new CustomEvent('routineforge:cookie-consent', { detail: value }));
    banner?.classList.add('hidden');
    if (dialog instanceof HTMLDialogElement) dialog.close();
  };

  const openSettings = () => {
    const current = readConsent();
    if (analyticsInput instanceof HTMLInputElement) analyticsInput.checked = Boolean(current?.analytics);
    if (marketingInput instanceof HTMLInputElement) marketingInput.checked = Boolean(current?.marketing);
    if (dialog instanceof HTMLDialogElement) dialog.showModal();
  };

  const existingConsent = readConsent();
  if (existingConsent) updateGoogleConsent(existingConsent);
  else banner?.classList.remove('hidden');

  document.querySelectorAll('[data-cookie-accept]').forEach((button) => button.addEventListener('click', () => saveConsent({ analytics: true, marketing: true })));
  document.querySelectorAll('[data-cookie-reject]').forEach((button) => button.addEventListener('click', () => saveConsent({ analytics: false, marketing: false })));
  document.querySelectorAll('[data-cookie-settings], a[href="#cookie-settings"]').forEach((trigger) => trigger.addEventListener('click', (event) => { event.preventDefault(); openSettings(); }));
  document.querySelector('[data-cookie-close]')?.addEventListener('click', () => { if (dialog instanceof HTMLDialogElement) dialog.close(); });
  cookieForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    saveConsent({ analytics: Boolean((analyticsInput as HTMLInputElement)?.checked), marketing: Boolean((marketingInput as HTMLInputElement)?.checked) });
  });
</script>
