---
import Footer from './Footer.astro';
import Navbar from './Navbar.astro';

const { locale = 'en', type = 'privacy' } = Astro.props;
const isSerbian = locale === 'sr';
const isPrivacy = type === 'privacy';

const content = isSerbian
  ? {
      back: 'Nazad na početnu', language: 'EN', privacy: 'Politika privatnosti', terms: 'Uslovi korišćenja', updated: 'Poslednje ažuriranje: 13. jul 2026.',
      privacyIntro: 'Ova politika objašnjava kako CortexFlow/Ivan Cvetković PR Agencija DBCK Konsalting postupa sa ličnim podacima kada posetite sajt ili nam se obratite sa upitom.',
      privacySections: [
        { title: 'Ko je rukovalac podataka?', body: ['Rukovalac Vaših podataka o ličnosti je Ivan Cvetković PR Agencija DBCK Konsalting, Stanoja Bunuševca 47, 18000 Niš, Srbija. Za sva pitanja o privatnosti pišite na dbckconsult@gmail.com ili pozovite +381 64 2311336.', 'Podatke obrađujemo u skladu sa Zakonom o zaštiti podataka o ličnosti Republike Srbije („Sl. glasnik RS", br. 87/2018 — ZZPL) i Opštom uredbom EU o zaštiti podataka (GDPR).'] },
        { title: 'Koje podatke prikupljamo?', body: ['Prikupljamo samo podatke koje nam sami dostavite i osnovne podatke o korišćenju sajta:'], richItems: [{ label: 'Kontakt forma i direktan kontakt', text: 'ime, e-mail adresa, broj telefona i sadržaj poruke — da bismo odgovorili na Vaš upit.' }, { label: 'Podaci o korišćenju sajta (samo uz Vaš pristanak)', text: 'posećene stranice, trajanje posete, tip uređaja i pregledača, približna lokacija — putem analitičkih alata opisanih ispod.' }] },
        { title: 'Zašto i po kom osnovu obrađujemo podatke?', richItems: [{ label: 'Odgovor na upit i priprema saradnje', text: 'preduzimanje radnji na Vaš zahtev pre zaključenja ugovora (čl. 12 ZZPL / čl. 6(1)(b) GDPR).' }, { label: 'Analitika i unapređenje sajta', text: 'isključivo na osnovu Vašeg pristanka (čl. 12 ZZPL / čl. 6(1)(a) GDPR).' }, { label: 'Marketing merenja (npr. merenje učinka oglasa)', text: 'isključivo na osnovu Vašeg pristanka.' }, { label: 'Bezbednost sajta i ispunjenje pravnih obaveza', text: 'legitimni interes, odnosno zakonska obaveza.' }] },
        { title: 'Koje kolačiće i slične tehnologije koristimo?', body: ['Pri prvoj poseti sajt Vas pita za pristanak. Analitički i marketinški alati se ne uključuju dok ne kliknete „Prihvatam" (Google Consent Mode v2 — podrazumevano stanje je „odbijeno"). Ako odbijete, sajt radi normalno, bez praćenja.'], table: { headers: ['Tehnologija', 'Svrha', 'Trajanje', 'Kategorija'], rows: [['bol-consent (localStorage)', 'Pamti Vaš izbor o kolačićima', '12 meseci', 'Neophodno'], ['_ga, _ga_* (Google Analytics 4)', 'Anonimizovana statistika poseta', 'do 2 godine', 'Analitika — uz pristanak'], ['_fbp (Meta Pixel)', 'Merenje učinka oglasa na Meta platformama', '3 meseca', 'Marketing — uz pristanak'], ['_clck, _clsk (Microsoft Clarity)', 'Analiza korišćenja sajta (toplotne mape)', 'do 13 meseci', 'Analitika — uz pristanak']] }, action: { text: 'Svoj izbor možete promeniti u svakom trenutku:', label: 'Promenite izbor kolačića', href: '#cookie-settings' } },
        { title: 'Ko još ima pristup podacima?', body: ['Podatke ne prodajemo nikome. Koristimo proverene obrađivače koji podatke obrađuju po našim instrukcijama: Google (Analytics, Fonts), Meta Platforms (Pixel), Microsoft (Clarity) i Vercel (hosting sajta). Pojedini obrađivači podatke obrađuju u Velikoj Britaniji, EU ili SAD; prenos je zaštićen odlukama o adekvatnosti, standardnim ugovornim klauzulama, odnosno EU-U.S. Data Privacy Framework sertifikacijom.'] },
        { title: 'Koliko dugo čuvamo podatke?', body: ['Podatke iz upita čuvamo dok traje komunikacija i razuman period nakon nje (najduže 2 godine), osim ako saradnja preraste u ugovor. Analitički podaci se čuvaju prema rokovima iz tabele iznad. Podatke brišemo i ranije na Vaš zahtev.'] },
        { title: 'Koja su Vaša prava?', body: ['Po ZZPL-u i GDPR-u imate pravo na:'], items: ['pristup podacima koje o Vama obrađujemo i njihovu kopiju,', 'ispravku netačnih i dopunu nepotpunih podataka,', 'brisanje podataka („pravo na zaborav"),', 'ograničenje obrade i prigovor na obradu,', 'prenosivost podataka,', 'povlačenje pristanka u bilo kom trenutku — bez uticaja na zakonitost ranije obrade.'], after: 'Zahtev pošaljite na dbckconsult@gmail.com — odgovaramo bez odlaganja, najkasnije u zakonskom roku od 30 dana. Imate i pravo pritužbe Povereniku za informacije od javnog značaja i zaštitu podataka o ličnosti (poverenik.rs), odnosno nadzornom organu u Vašoj zemlji.' },
        { title: 'Kako štitimo podatke?', body: ['Sajt koristi HTTPS enkripciju, pristup podacima imaju samo ovlašćene osobe, a obim prikupljanja držimo na minimumu — sajt je statičan i ne vodi naloge korisnika niti baze posetilaca.'] },
        { title: 'Izmene ove politike', body: ['Politiku ažuriramo kada se promeni način obrade (npr. uvođenje novog alata). Važeća verzija je uvek na ovoj stranici, sa datumom poslednjeg ažuriranja na vrhu.'] }
      ],
      termsIntro: 'Ovi uslovi uređuju korišćenje CortexFlow sajta. Korišćenjem sajta prihvatate ove uslove.',
      termsSections: [
        { title: '1. Svrha sajta', body: ['Sajt pruža opšte informacije o CortexFlow uslugama, uključujući AI automatizaciju, chatbotove i prilagođene sisteme. Sadržaj nije ponuda koja sama po sebi stvara ugovorni odnos.'] },
        { title: '2. Upiti i ponude', body: ['Slanje kontakt forme ili emaila ne predstavlja obavezu CortexFlow-a da pruži uslugu niti stvara ugovor. Obim rada, rokovi, cena i ostali uslovi dogovaraju se odvojeno u pisanoj ponudi ili ugovoru.'] },
        { title: '3. Intelektualna svojina', body: ['Tekst, dizajn, logotipi i drugi sadržaj na sajtu pripadaju CortexFlow-u ili se koriste uz dozvolu. Ne smete ih kopirati, menjati ili koristiti u komercijalne svrhe bez prethodne pisane dozvole.'] },
        { title: '4. Dozvoljeno korišćenje', body: ['Sajt koristite zakonito i bez pokušaja ometanja rada sajta, neovlašćenog pristupa ili slanja štetnog sadržaja.'] },
        { title: '5. Odricanje od odgovornosti', body: ['Sadržaj i informacije na ovom sajtu pružaju se isključivo u opšte informativne svrhe i ne predstavljaju pravni, finansijski, medicinski niti drugi stručni savet. Iako nastojimo da sadržaj bude tačan i ažuran, ne garantujemo da je potpun ili bez grešaka.', 'Procene rezultata, uključujući ROI kalkulator, primeri, izjave klijenata i rezultati iz studija slučaja služe kao ilustracija i ne garantuju iste rezultate za svaki biznis. CortexFlow nije odgovoran za sadržaj ili praksu sajtova i usluga trećih strana na koje ovaj sajt vodi, u meri dozvoljenoj primenljivim zakonom.'] },
        { title: '6. Izmene i kontakt', body: ['Možemo izmeniti ove uslove objavljivanjem nove verzije na ovoj stranici. Za pitanja nas kontaktirajte na dbckconsult@gmail.com.'] }
      ]
    }
  : {
      back: 'Back to home', language: 'SR', privacy: 'Privacy Policy', terms: 'Terms of Use', updated: 'Last updated: July 13, 2026.',
      privacyIntro: 'This policy explains how CortexFlow/Ivan Cvetković PR Agencija DBCK Konsalting handles personal data when you visit this website or contact us with an inquiry.',
      privacySections: [
        { title: 'Who is the data controller?', body: ['The controller of your personal data is Ivan Cvetković PR Agencija DBCK Konsalting, Stanoja Bunuševca 47, 18000 Niš, Serbia. For any privacy questions, email dbckconsult@gmail.com or call +381 64 2311336.', 'We process data in accordance with the Serbian Personal Data Protection Act (Official Gazette of the Republic of Serbia, No. 87/2018) and the EU General Data Protection Regulation (GDPR).'] },
        { title: 'What information do we collect?', body: ['We collect only information you provide to us and basic website usage information:'], richItems: [{ label: 'Contact form and direct contact', text: 'name, email address, phone number, and message content — so that we can respond to your inquiry.' }, { label: 'Website usage information (only with your consent)', text: 'pages visited, visit duration, device and browser type, and approximate location — through the analytics tools described below.' }] },
        { title: 'Why and on what basis do we process information?', richItems: [{ label: 'Responding to your inquiry and preparing a collaboration', text: 'taking steps at your request before entering into a contract (Article 12 of the Serbian Personal Data Protection Act / Article 6(1)(b) GDPR).' }, { label: 'Analytics and website improvement', text: 'solely on the basis of your consent (Article 12 of the Serbian Personal Data Protection Act / Article 6(1)(a) GDPR).' }, { label: 'Marketing measurement (for example, measuring advertising performance)', text: 'solely on the basis of your consent.' }, { label: 'Website security and compliance with legal obligations', text: 'legitimate interest or a legal obligation.' }] },
        { title: 'Which cookies and similar technologies do we use?', body: ['On your first visit, the website asks for your consent. Analytics and marketing tools are not enabled until you click “Accept” (Google Consent Mode v2 — the default state is “denied”). If you decline, the website functions normally without tracking.'], table: { headers: ['Technology', 'Purpose', 'Duration', 'Category'], rows: [['bol-consent (localStorage)', 'Remembers your cookie choice', '12 months', 'Necessary'], ['_ga, _ga_* (Google Analytics 4)', 'Anonymized visit statistics', 'up to 2 years', 'Analytics — with consent'], ['_fbp (Meta Pixel)', 'Measures advertising performance on Meta platforms', '3 months', 'Marketing — with consent'], ['_clck, _clsk (Microsoft Clarity)', 'Website usage analysis (heat maps)', 'up to 13 months', 'Analytics — with consent']] }, action: { text: 'You can change your choice at any time:', label: 'Change cookie preferences', href: '#cookie-settings' } },
        { title: 'Who else can access your information?', body: ['We do not sell information to anyone. We use trusted processors that handle information under our instructions: Google (Analytics, Fonts), Meta Platforms (Pixel), Microsoft (Clarity), and Vercel (website hosting). Some processors handle information in the United Kingdom, the EU, or the United States; transfers are protected by adequacy decisions, Standard Contractual Clauses, or EU-U.S. Data Privacy Framework certification.'] },
        { title: 'How long do we retain information?', body: ['We retain inquiry information while communication is ongoing and for a reasonable period afterwards (no longer than 2 years), unless the collaboration results in a contract. Analytics information is retained according to the periods in the table above. We will delete information earlier at your request.'] },
        { title: 'What are your rights?', body: ['Under the Serbian Personal Data Protection Act and the GDPR, you have the right to:'], items: ['access the information we process about you and receive a copy,', 'correct inaccurate information and complete incomplete information,', 'delete information (the “right to be forgotten”),', 'restrict processing and object to processing,', 'data portability,', 'withdraw consent at any time — without affecting the lawfulness of processing before withdrawal.'], after: 'Send your request to dbckconsult@gmail.com — we respond without undue delay and no later than the statutory deadline of 30 days. You also have the right to complain to the Serbian Commissioner for Information of Public Importance and Personal Data Protection (poverenik.rs), or to the supervisory authority in your country.' },
        { title: 'How do we protect information?', body: ['The website uses HTTPS encryption, only authorized persons have access to information, and we keep collection to a minimum — the website is static and does not maintain user accounts or visitor databases.'] },
        { title: 'Changes to this policy', body: ['We update this policy when the way we process information changes (for example, if we introduce a new tool). The current version is always available on this page, with the date of the latest update at the top.'] }
      ],
      termsIntro: 'These terms govern your use of the CortexFlow website. By using the website, you accept these terms.',
      termsSections: [
        { title: '1. Website purpose', body: ['This website provides general information about CortexFlow services, including AI automation, chatbots, and custom systems. Its content is not an offer that independently creates a contractual relationship.'] },
        { title: '2. Inquiries and proposals', body: ['Submitting a contact form or sending an email does not oblige CortexFlow to provide a service and does not create a contract. Scope, timing, price, and other terms are agreed separately in a written proposal or contract.'] },
        { title: '3. Intellectual property', body: ['The text, design, logos, and other content on this website belong to CortexFlow or are used with permission. You may not copy, modify, or use them commercially without prior written permission.'] },
        { title: '4. Acceptable use', body: ['Use this website lawfully and do not attempt to disrupt it, gain unauthorized access, or submit harmful content.'] },
        { title: '5. Disclaimer', body: ['Website content and information are provided for general information only and do not constitute legal, financial, medical, or other professional advice. While we aim to keep content accurate and current, we do not guarantee it is complete or error-free.', 'Outcome estimates, including the ROI calculator, examples, client testimonials, and case-study results are illustrative and do not guarantee equivalent results for every business. CortexFlow is not responsible for the content or practices of third-party websites and services linked from this website, to the extent permitted by applicable law.'] },
        { title: '6. Changes and contact', body: ['We may update these terms by publishing a new version on this page. For questions, contact dbckconsult@gmail.com.'] }
      ]
    };

const title = isPrivacy ? content.privacy : content.terms;
const intro = isPrivacy ? content.privacyIntro : content.termsIntro;
const sections = isPrivacy ? content.privacySections : content.termsSections;
const linkTargets = {
  'dbckconsult@gmail.com': 'mailto:dbckconsult@gmail.com',
  'hello@cortexflow.ai': 'mailto:hello@cortexflow.ai',
  '+381 64 2311336': 'tel:+381642311336',
  'poverenik.rs': 'https://poverenik.rs'
};
const linkify = (value) => value.split(/(dbckconsult@gmail\.com|hello@cortexflow\.ai|\+381 64 2311336|poverenik\.rs)/g).map((part) => ({
  value: part,
  href: linkTargets[part]
}));
---

<main class="flow-grid-bg min-h-screen">
  <Navbar />

  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
    <div class="border border-slate-200 bg-white p-6 shadow-sm sm:p-10">
      <h1 class="text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">{title}</h1>
      <p class="mt-5 text-base leading-7 text-slate-700">{intro}</p>
      <p class="mt-3 text-sm text-slate-500">{content.updated}</p>
      <div class="mt-9 space-y-7">
        {sections.map((section) => (
          <section>
            <h2 class="text-lg font-bold text-slate-950 sm:text-xl">{section.title}</h2>
            <div class="mt-3 space-y-3 text-sm leading-6 text-slate-700 sm:text-base sm:leading-7">
              {(section.body || []).map((paragraph) => <p>{linkify(paragraph).map((part) => part.href ? <a href={part.href} class="font-medium text-sky-700 underline decoration-sky-300 underline-offset-2 transition hover:text-sky-950">{part.value}</a> : part.value)}</p>)}
              {section.richItems && <ul class="space-y-2.5">{section.richItems.map((item) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-sky-600" aria-hidden="true"></span><span><strong class="font-bold text-slate-950">{item.label}:</strong> {linkify(item.text).map((part) => part.href ? <a href={part.href} class="font-medium text-sky-700 underline decoration-sky-300 underline-offset-2 transition hover:text-sky-950">{part.value}</a> : part.value)}</span></li>)}</ul>}
              {section.items && <ul class="space-y-1.5">{section.items.map((item) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-sky-600" aria-hidden="true"></span><span>{linkify(item).map((part) => part.href ? <a href={part.href} class="font-medium text-sky-700 underline decoration-sky-300 underline-offset-2 transition hover:text-sky-950">{part.value}</a> : part.value)}</span></li>)}</ul>}
              {section.table && <div class="overflow-x-auto rounded-2xl border border-sky-100 bg-white shadow-[0_14px_35px_-28px_rgba(14,116,144,0.55)]"><table class="min-w-[42rem] w-full text-left text-xs leading-5 sm:text-sm"><thead class="bg-gradient-to-r from-slate-950 via-slate-900 to-sky-950 text-white"><tr>{section.table.headers.map((header) => <th class="whitespace-nowrap px-5 py-3.5 font-semibold tracking-wide">{header}</th>)}</tr></thead><tbody>{section.table.rows.map((row, rowIndex) => <tr class:list={[rowIndex % 2 === 0 ? 'bg-sky-50/65' : 'bg-white', 'border-b border-sky-100/80 last:border-b-0 transition hover:bg-sky-100/70']}>{row.map((cell, cellIndex) => <td class:list={[cellIndex === 0 ? 'font-semibold text-slate-900' : 'text-slate-600', 'px-5 py-4 align-middle']}>{linkify(cell).map((part) => part.href ? <a href={part.href} class="font-medium text-sky-700 underline decoration-sky-300 underline-offset-2 transition hover:text-sky-950">{part.value}</a> : part.value)}</td>)}</tr>)}</tbody></table></div>}
              {section.action && <div><p>{linkify(section.action.text).map((part) => part.href ? <a href={part.href} class="font-medium text-sky-700 underline decoration-sky-300 underline-offset-2 transition hover:text-sky-950">{part.value}</a> : part.value)}</p><a href={section.action.href} class="mt-2 inline-flex font-semibold text-sky-700 underline decoration-sky-300 underline-offset-4 transition hover:text-sky-950">{section.action.label}</a></div>}
              {section.after && <p>{linkify(section.after).map((part) => part.href ? <a href={part.href} class="font-medium text-sky-700 underline decoration-sky-300 underline-offset-2 transition hover:text-sky-950">{part.value}</a> : part.value)}</p>}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>
  <Footer />
</main>
