---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import LogoMark from './LogoMark.astro';
import IndustryIcon from './IndustryIcon.astro';
import ServiceIcon from './ServiceIcon.astro';
import { SITE_URL } from '../config/site';

const { lang = 'en' } = Astro.props;
const isSr = lang === 'sr';
const contactHref = isSr ? '/sr#contact' : '/#contact';

const content = isSr
  ? {
      metaTitle: 'AI za e-commerce: prodaja, napuštene korpe i podrška',
      metaDescription: 'RoutineForge gradi AI sisteme za online prodavnice koji prodaju 24/7, vraćaju napuštene korpe i automatizuju praćenje porudžbina i reklamacije.',
      canonical: `${SITE_URL}/sr/ai-za-ecommerce`, enUrl: `${SITE_URL}/ai-for-ecommerce`, srUrl: `${SITE_URL}/sr/ai-za-ecommerce`,
      eyebrow: 'INDUSTRIJE · E-COMMERCE', title: 'Reklame dovode kupce. AI ih ne pušta.',
      intro: 'Online prodavnice najviše novca gube na pitanjima bez odgovora i korpama koje kupci napuste. Gradimo AI sistem koji prodaje na sajtu, Instagramu i WhatsAppu 24/7, vraća napuštene korpe i vodi praćenje porudžbina i reklamacije.',
      primaryCta: 'Zakažite besplatnu konsultaciju', secondaryCta: 'Pogledajte prodajni sistem',
      proof: [{ value: '24/7', label: 'odgovori, preporuke i prodaja' }, { value: 'Jedna baza', label: 'proizvodi, zalihe i isporuka' }, { value: 'Svaka korpa', label: 'dobija merljiv sledeći korak' }],
      visualLabel: 'AI PRODAJNI ASISTENT · ILUSTRATIVNI PRIMER', visualTitle: 'Kupac dobija pravi proizvod', visualSub: 'RoutineForge Commerce AI',
      chat: ['Treba mi kaciga za gradsku vožnju, do 120 €. Koja veličina mi treba?', 'Za obim glave 57 cm odgovara veličina M. Ovaj model je na stanju i uklapa se u budžet.', 'Dodaj crnu M u korpu. Da li stiže do petka?'],
      cartItems: [{ name: 'Urban Pro Helmet · M', price: '109 €' }, { name: 'Reflective light set', price: '18 €' }], visualOutcome: 'Korpa spremna · isporuka potvrđena · checkout otvoren',
      painEyebrow: 'GDE ONLINE PRODAVNICE GUBE PRODAJU', painTitle: 'Saobraćaj je plaćen, interesovanje postoji — ali kupac odlazi kada odgovor ili sledeći korak kasni.', painIntro: 'AI ne zamenjuje dobar proizvod i ponudu. On uklanja trenje između pitanja, izbora, plaćanja i postprodajne podrške.',
      pains: [
        { number: '01', title: 'Napuštene korpe odnose najveći deo prodaje', text: 'Kupac doda proizvod, pojavi se sumnja o veličini, isporuci ili povratu i kupovina stane. Generički mejl često stiže kasno i bez odgovora na pravi razlog odustajanja.' },
        { number: '02', title: 'Tim odgovara na ista pitanja umesto da prodaje', text: '„Gde je porudžbina?”, „Koja veličina?”, „Kada stiže?” i „Kako vraćam proizvod?” troše sate i prekidaju posao koji zaista zahteva čoveka.' },
        { number: '03', title: 'Upiti van radnog vremena propadaju', text: 'Kupovine se često dešavaju uveče i vikendom. Ako odgovor stigne tek sutra, kupac je možda već završio kupovinu kod konkurencije.' },
        { number: '04', title: 'Reklamacije se gube kroz mejlove i pozive', text: 'Bez jasnog toka, fotografije, račun, rok i status ostaju u različitim inboxima. Kupac gubi strpljenje, a tim pregled nad odgovornošću i sledećim korakom.' }
      ],
      buildEyebrow: 'ŠTA GRADIMO ZA ONLINE PRODAVNICE', buildTitle: 'Jedan AI sloj preko prodavnice i kanala koje kupci već koriste.', buildIntro: 'Sistem se povezuje sa katalogom, zalihama, porudžbinama i odobrenim pravilima. Ne menjamo ono što već radi — povezujemo prodaju i podršku u merljiv tok.',
      builds: [
        { icon: 'chat', title: 'AI chatbot koji prodaje na svakom kanalu', text: 'Odgovara o proizvodima, zalihama, veličinama i isporuci na sajtu, Instagramu i WhatsAppu, preporučuje proizvode i vodi kupca ka plaćanju.', outcome: 'Kupac svuda dobija isti, ažuran odgovor iz jedne baze.' },
        { icon: 'workflow', title: 'Vraćanje napuštenih korpi', text: 'Kupac sa dozvolom dobija pravovremenu WhatsApp poruku i može odmah da reši pitanje zbog kog je kupovina stala.', outcome: 'Svaka vraćena korpa i prihod mogu da se izmere.' },
        { icon: 'custom', title: 'Praćenje porudžbina i reklamacija', text: 'Kupac sam proverava status, dok reklamacije prolaze kroz definisan tok sa dokumentima, rokovima, odgovornom osobom i jasnim koracima.', outcome: 'Tim vidi sve na jednom mestu, a slučajevi ne nestaju u inboxu.' },
        { icon: 'workflow', title: 'Podsetnici i kampanje za ponovnu kupovinu', text: 'Sistem koristi dozvoljene podatke o kupovini da podseti na dopunu potrošnog proizvoda, ponovnu kupovinu ili relevantnu akciju.', outcome: 'Poruka ide segmentu kome ponuda ima smisla, ne celoj bazi.' }
      ],
      commerceEyebrow: 'OD PITANJA DO PLAĆANJA', commerceTitle: 'AI ne prikazuje samo FAQ. On razume nameru, proverava katalog i vodi ka odluci.', commerceText: 'Preporuka koristi odobrene karakteristike, cenu i stanje zaliha. Kada AI nema dovoljno informacija ili kupac traži izuzetak, razgovor prelazi čoveku sa celim kontekstom.',
      productCards: [
        { tag: 'Najbolji izbor', name: 'Urban Pro Helmet', detail: 'Veličina M · crna · na stanju', price: '109 €' },
        { tag: 'Alternativa', name: 'City Air Helmet', detail: 'Veličina M · plava · na stanju', price: '89 €' },
        { tag: 'Dodatak', name: 'Reflective light set', detail: 'Kompatibilno · spremno za isporuku', price: '18 €' }
      ],
      commerceSteps: ['Pitanje i namera prepoznati', 'Katalog i zalihe provereni', 'Preporuka objašnjena', 'Korpa i checkout pripremljeni'],
      productMatchLabel: 'ROUTINEFORGE PREPORUKE', productMatchSub: '3 preporuke iz aktuelnog kataloga', productStock: '● Lager uživo',
      cartEyebrow: 'NAPUŠTENA KORPA · PRAVI KANAL, PRAVI TRENUTAK', cartTitle: 'Podsetnik vredi više kada kupac može odmah da odgovori.', cartText: 'Umesto generičke poruke, sistem vraća kontekst korpe i otvara razgovor. Kupac može da pita o veličini, roku isporuke, plaćanju ili povratu — i nastavi kupovinu iz iste poruke.',
      cartMessages: ['Vidimo da su proizvodi ostali u korpi. Da li Vas je zaustavilo pitanje o veličini ili isporuci?', 'Da li crna kaciga M može da stigne do petka?', 'Može. Trenutno je na stanju, a procenjena isporuka je četvrtak. Želite li link za završetak kupovine?'],
      cartRecoveryLabel: 'WhatsApp vraćanje korpe', cartRecoveryStatus: '● Kupac je dao saglasnost · kontekst korpe vraćen',
      benchmarkTitle: 'Referentni benchmark za vraćanje korpi',
      benchmarks: [{ value: '70%', label: 'korpi u proseku bude napušteno' }, { value: '20–30%', label: 'napuštenih korpi može vratiti WhatsApp poruka' }, { value: '3–5%', label: 'naspram tipičnog povraćaja kroz mejl' }],
      benchmarkNote: 'Brojevi su industrijski benchmarki navedeni na referentnoj Bolutions stranici, ne RoutineForge rezultat ili garancija. U produkciji pratimo stopu slanja, odgovora, povraćaja korpi i dodatni prihod za Vašu prodavnicu.',
      supportEyebrow: 'POSLE PLAĆANJA', supportTitle: 'Status porudžbine i reklamacija postaju transparentan proces, ne potraga po inboxu.', supportText: 'AI prikazuje samo podatke koje kupac sme da vidi, a svaka radnja se beleži. Za osetljive odluke, povraćaj novca ili izuzetak od pravila, slučaj se prosleđuje ovlašćenoj osobi.',
      orderLabel: 'PORUDŽBINA #RF-10482', orderStates: [{ state: 'Plaćanje potvrđeno', detail: 'Danas · 09:14', tone: 'done' }, { state: 'Paket pripremljen', detail: 'Danas · 12:20', tone: 'done' }, { state: 'Predato kuriru', detail: 'Praćenje aktivno', tone: 'active' }, { state: 'Isporučeno', detail: 'Očekivano: petak', tone: 'pending' }],
      claimLabel: 'REKLAMACIJA #CL-281', claimSteps: ['Kupac dostavio broj porudžbine i fotografiju', 'Pravila povrata automatski proverena', 'Slučaj dodeljen odgovornoj osobi', 'Kupac dobija obaveštenje pri svakoj promeni'],
      claimFooter: '✓ Jedna odgovorna osoba · jedan status · kompletan trag',
      proofEyebrow: 'REZULTAT IZ REFERENTNOG PRIMERA', proofTitle: 'Svaki razgovor može biti podrška — i prilika za relevantnu dodatnu prodaju.', proofText: 'Referentna stranica opisuje AI asistenta za Dualtron Srbija koji odgovara o proizvodima, delovima, cenama i zalihama i van radnog vremena, preporučuje dodatnu opremu i predaje čoveku samo razgovore koji to zahtevaju.',
      proofMetrics: [{ value: '2×', label: 'više prodate dodatne opreme kroz AI asistenta' }, { value: '−50%', label: 'vremena utrošenog po upitu kupca' }, { value: '24/7', label: 'odgovori o proizvodima i isporuci' }],
      proofBullets: ['Odgovori koriste stvarne podatke o proizvodima, zalihama i isporuci', 'Preporuka dodatka pojavljuje se samo kada ima smisla za kupca', 'Tim preuzima razgovore u kojima je čovek zaista potreban'],
      proofNote: 'Ovo su rezultati i tvrdnje treće strane sa referentne stranice, a ne RoutineForge rezultat. Za Vašu prodavnicu definišemo bazne metrike i merimo odgovore, konverzije, povraćene korpe, vreme podrške i dodatnu prodaju.',
      campaignsEyebrow: 'PONOVNA KUPOVINA BEZ GENERIČKOG SPAMA', campaignsTitle: 'Prava poruka ide kupcu kada proizvod, vreme i dozvola imaju smisla.', campaignsText: 'Sistem segmentira na osnovu dozvoljenih podataka i poslovnih pravila. Kupac može dobiti podsetnik za dopunu, kompatibilan dodatak, obaveštenje da je proizvod ponovo na stanju ili kampanju koja odgovara njegovom interesovanju.',
      campaigns: [
        { timing: '30 dana nakon kupovine', title: 'Dopuna potrošnog proizvoda', text: 'Podsetnik stiže približno kada prethodna količina treba da bude potrošena.' },
        { timing: 'Proizvod ponovo na stanju', title: 'Back-in-stock poruka', text: 'Obaveštenje ide samo kupcima koji su pokazali interesovanje za taj proizvod ili varijantu.' },
        { timing: 'Posle isporuke', title: 'Relevantan dodatak', text: 'Preporuka je kompatibilna sa kupljenim proizvodom, umesto nasumičnog cross-sella.' },
        { timing: 'Sezonski trenutak', title: 'Segmentirana kampanja', text: 'Ponuda se šalje odabranom segmentu uz saglasnost i kontrolu učestalosti.' }
      ],
      platformsEyebrow: 'POVEZANO SA POSTOJEĆOM PRODAVNICOM', platformsTitle: 'Ne morate da menjate platformu da biste povezali prodaju i podršku.', platformsText: 'Shopify, WooCommerce i custom prodavnice su tipični izvori kataloga i porudžbina. Za druge platforme prvo proveravamo API i dostupne integracije, pre bilo kakve obaveze.',
      platforms: ['Shopify', 'WooCommerce', 'Custom storefront / API', 'WhatsApp Business', 'Instagram & Messenger', 'CRM / help desk', 'Kurirski i fulfillment sistemi', 'E-mail i analitika'],
      processEyebrow: 'KAKO UVODIMO SISTEM', processTitle: 'Prvo pronalazimo gde prodaja curi. Zatim automatizujemo merljiv deo toka.',
      process: [
        { phase: '01', title: 'Snimak kupovnog puta', text: 'Mapiramo katalog, kanale, pitanja, checkout, napuštene korpe, porudžbine, reklamacije i postprodajnu komunikaciju.' },
        { phase: '02', title: 'Podaci i pravila', text: 'Definišemo izvore cena i zaliha, politike isporuke i povrata, preporuke, saglasnosti i granice AI odgovora.' },
        { phase: '03', title: 'Integracije i testiranje', text: 'Povezujemo prvi kanal i platformu, zatim testiramo promene zaliha, kupone, porudžbine, reklamacije i human handoff.' },
        { phase: '04', title: 'Lansiranje i optimizacija', text: 'Merimo odgovore i konverzije, pa dodajemo vraćanje korpi, kampanje i sledeće kanale prema prioritetu.' }
      ],
      faqEyebrow: 'ČESTA PITANJA', faqTitle: 'Šta online prodavnice žele da znaju.',
      faqs: [
        { q: 'Sa kojim platformama se sistem povezuje?', a: 'Shopify, WooCommerce i custom prodavnice su standardni slučajevi. Ako koristite drugu platformu, pre predloga proveravamo API, webhooks i dostupne integracije.' },
        { q: 'Da li su WhatsApp poruke kupcima dozvoljene?', a: 'Da, kada se koriste zvanična WhatsApp Business platforma, odgovarajući template-i i validna saglasnost kupca. Tok projektujemo tako da beleži osnov i poštuje odjavu i pravila kanala.' },
        { q: 'Šta ako AI ne zna odgovor?', a: 'AI odgovara iz odobrene baze i ne treba da izmišlja cenu, zalihu ili rok. Kada nema pouzdan odgovor ili kupac traži izuzetak, razgovor sa celim kontekstom prelazi čoveku.' },
        { q: 'Koliko brzo može da se vidi rezultat?', a: 'Automatski odgovori i vraćanje korpi mogu se meriti čim sistem uđe u produkciju. Vreme do statistički korisnog zaključka zavisi od saobraćaja, broja korpi i sezonalnosti prodavnice.' },
        { q: 'Koliko košta AI sistem za online prodavnicu?', a: 'Zavisi od platforme, kanala i obima. Chatbot za pitanja i preporuke je manja investicija od kompletnog sistema sa napuštenim korpama, reklamacijama, kampanjama i više integracija.' },
        { q: 'Na kojim jezicima AI prodaje?', a: 'Na srpskom, engleskom i drugim jezicima prema tržištu. Isti sistem može da vodi razgovor na jeziku kupca, koristeći jednu odobrenu bazu proizvoda i pravila.' }
      ],
      ctaTitle: 'Pokažite nam prodavnicu. Pokazaćemo gde prodaja curi.', ctaText: 'Na besplatnoj konsultaciji prolazimo kroz pitanja kupaca, napuštene korpe, porudžbine i reklamacije i predlažemo prvi merljiv korak — bez prodaje sistema koji Vam ne treba.', ctaButton: 'Zakažite konsultaciju'
    }
  : {
      metaTitle: 'AI for e-commerce: sales, abandoned carts, and support',
      metaDescription: 'RoutineForge builds AI systems for online stores that sell 24/7, recover abandoned carts, and automate order tracking and returns workflows.',
      canonical: `${SITE_URL}/ai-for-ecommerce`, enUrl: `${SITE_URL}/ai-for-ecommerce`, srUrl: `${SITE_URL}/sr/ai-za-ecommerce`,
      eyebrow: 'INDUSTRIES · E-COMMERCE', title: 'Ads bring shoppers in. AI keeps the sale moving.',
      intro: 'Online stores lose the most revenue to unanswered questions and abandoned carts. We build an AI system that sells across web, Instagram, and WhatsApp 24/7, recovers abandoned carts, and runs order tracking and returns workflows.',
      primaryCta: 'Book a free consultation', secondaryCta: 'See the sales system',
      proof: [{ value: '24/7', label: 'answers, recommendations, and sales' }, { value: 'One source', label: 'products, inventory, and delivery' }, { value: 'Every cart', label: 'gets a measurable next step' }],
      visualLabel: 'AI SALES ASSISTANT · ILLUSTRATIVE EXAMPLE', visualTitle: 'The shopper finds the right product', visualSub: 'RoutineForge Commerce AI',
      chat: ['I need a helmet for city riding under €120. Which size should I get?', 'For a 57 cm head circumference, size M should fit. This model is in stock and within budget.', 'Add the black M to my cart. Can it arrive by Friday?'],
      cartItems: [{ name: 'Urban Pro Helmet · M', price: '€109' }, { name: 'Reflective light set', price: '€18' }], visualOutcome: 'Cart ready · delivery confirmed · checkout opened',
      painEyebrow: 'WHERE ONLINE STORES LOSE SALES', painTitle: 'The traffic is paid for and interest exists — but the shopper leaves when the answer or next step arrives too late.', painIntro: 'AI does not replace a good product and offer. It removes friction between the question, choice, payment, and post-purchase support.',
      pains: [
        { number: '01', title: 'Abandoned carts take the largest share of sales', text: 'A shopper adds a product, hesitates about size, delivery, or returns, and the purchase stops. A generic recovery email often arrives late and cannot resolve the real objection.' },
        { number: '02', title: 'The team repeats answers instead of selling', text: '“Where is my order?”, “Which size?”, “When will it arrive?” and “How do I return it?” consume hours and interrupt work that genuinely needs a person.' },
        { number: '03', title: 'After-hours enquiries disappear', text: 'Shopping often happens in the evening and at weekends. If the answer waits until morning, the customer may already have bought from a competitor.' },
        { number: '04', title: 'Returns and complaints disappear into email threads', text: 'Without a defined workflow, photos, receipts, deadlines, and status live in different inboxes. The customer loses patience and the team loses ownership of the next step.' }
      ],
      buildEyebrow: 'WHAT WE BUILD FOR ONLINE STORES', buildTitle: 'One AI layer across the store and the channels shoppers already use.', buildIntro: 'The system connects to the catalogue, stock, orders, and approved policies. We do not replace what already works — we connect sales and support into a measurable workflow.',
      builds: [
        { icon: 'chat', title: 'An AI chatbot that sells across channels', text: 'Answers product, stock, size, and delivery questions across web, Instagram, and WhatsApp, recommends products, and guides the shopper toward checkout.', outcome: 'The shopper receives the same current answer from one source everywhere.' },
        { icon: 'workflow', title: 'Abandoned-cart recovery', text: 'A shopper who has opted in receives a timely WhatsApp message and can immediately resolve the question that stopped the purchase.', outcome: 'Every recovered cart and its revenue can be measured.' },
        { icon: 'custom', title: 'Order tracking and returns workflows', text: 'Shoppers self-serve order status, while returns move through a defined workflow with documents, deadlines, ownership, and clear steps.', outcome: 'The team sees everything in one place and cases do not disappear in an inbox.' },
        { icon: 'workflow', title: 'Reminders and repeat-purchase campaigns', text: 'The system uses permitted purchase data to trigger a replenishment reminder, repeat purchase, or relevant offer.', outcome: 'The message reaches a segment for whom the offer makes sense, not the entire database.' }
      ],
      commerceEyebrow: 'FROM QUESTION TO CHECKOUT', commerceTitle: 'AI is more than a visible FAQ. It understands intent, checks the catalogue, and guides the decision.', commerceText: 'Recommendations use approved specifications, prices, and stock. If AI lacks enough information or the shopper asks for an exception, the conversation reaches a person with the full context.',
      productCards: [
        { tag: 'Best match', name: 'Urban Pro Helmet', detail: 'Size M · black · in stock', price: '€109' },
        { tag: 'Alternative', name: 'City Air Helmet', detail: 'Size M · blue · in stock', price: '€89' },
        { tag: 'Add-on', name: 'Reflective light set', detail: 'Compatible · ready to ship', price: '€18' }
      ],
      commerceSteps: ['Question and intent understood', 'Catalogue and stock checked', 'Recommendation explained', 'Cart and checkout prepared'],
      productMatchLabel: 'ROUTINEFORGE PRODUCT MATCH', productMatchSub: '3 recommendations from live catalogue data', productStock: '● Live stock',
      cartEyebrow: 'ABANDONED CART · RIGHT CHANNEL, RIGHT MOMENT', cartTitle: 'A reminder works harder when the shopper can reply immediately.', cartText: 'Instead of a generic message, the system restores cart context and opens a conversation. The shopper can ask about size, delivery, payment, or returns — then continue the purchase from the same message.',
      cartMessages: ['We noticed items are still in your cart. Did a sizing or delivery question stop you?', 'Can the black size M helmet arrive by Friday?', 'Yes. It is currently in stock, with estimated delivery on Thursday. Would you like the checkout link?'],
      cartRecoveryLabel: 'WhatsApp cart recovery', cartRecoveryStatus: '● Opted-in customer · cart context restored',
      benchmarkTitle: 'Reference benchmark for cart recovery',
      benchmarks: [{ value: '70%', label: 'of e-commerce carts are abandoned on average' }, { value: '20–30%', label: 'of abandoned carts may be recovered by WhatsApp' }, { value: '3–5%', label: 'compared with typical email recovery' }],
      benchmarkNote: 'These are industry benchmarks quoted on the referenced Bolutions page, not a RoutineForge result or guarantee. In production, we track send rate, response rate, recovered carts, and incremental revenue for your store.',
      supportEyebrow: 'AFTER PAYMENT', supportTitle: 'Order status and returns become a transparent workflow, not an inbox search.', supportText: 'AI displays only information the shopper is authorised to see, and every action is logged. Sensitive decisions, refunds, and policy exceptions reach an authorised person.',
      orderLabel: 'ORDER #RF-10482', orderStates: [{ state: 'Payment confirmed', detail: 'Today · 09:14', tone: 'done' }, { state: 'Parcel prepared', detail: 'Today · 12:20', tone: 'done' }, { state: 'Handed to courier', detail: 'Tracking is active', tone: 'active' }, { state: 'Delivered', detail: 'Expected: Friday', tone: 'pending' }],
      claimLabel: 'RETURN #CL-281', claimSteps: ['Shopper provided order number and photo', 'Return policy checked automatically', 'Case assigned to the responsible person', 'Shopper is updated after every status change'],
      claimFooter: '✓ One owner · one status · complete audit trail',
      proofEyebrow: 'RESULTS FROM THE REFERENCE CASE', proofTitle: 'Every conversation can solve a support need — and surface a relevant additional sale.', proofText: 'The reference page describes a Dualtron Serbia AI assistant that answers product, part, pricing, and stock questions outside business hours, recommends accessories, and sends only conversations that truly need a person to the team.',
      proofMetrics: [{ value: '2×', label: 'accessory sales through the AI assistant' }, { value: '−50%', label: 'time spent per customer enquiry' }, { value: '24/7', label: 'answers about products and delivery' }],
      proofBullets: ['Answers use real product, stock, and delivery information', 'Add-ons appear only when they are relevant to the shopper', 'The team handles only conversations that genuinely need a person'],
      proofNote: 'These are third-party results and claims from the reference page, not RoutineForge results. For your store, we establish a baseline and measure responses, conversion, recovered carts, support time, and additional sales.',
      campaignsEyebrow: 'REPEAT PURCHASE WITHOUT GENERIC SPAM', campaignsTitle: 'The right message reaches the shopper when product, timing, and permission align.', campaignsText: 'The system segments using permitted data and business rules. A shopper may receive a replenishment reminder, a compatible add-on, a back-in-stock alert, or a campaign relevant to their interests.',
      campaigns: [
        { timing: '30 days after purchase', title: 'Consumable replenishment', text: 'The reminder arrives around the time the previous quantity should be running out.' },
        { timing: 'Back in stock', title: 'Availability alert', text: 'The alert reaches only shoppers who showed interest in that product or variant.' },
        { timing: 'After delivery', title: 'Relevant add-on', text: 'The recommendation is compatible with the purchased product, not a random cross-sell.' },
        { timing: 'Seasonal moment', title: 'Segmented campaign', text: 'The offer reaches an approved segment with consent and frequency controls.' }
      ],
      platformsEyebrow: 'CONNECTED TO YOUR EXISTING STORE', platformsTitle: 'You do not need to replace your platform to connect sales and support.', platformsText: 'Shopify, WooCommerce, and custom stores are common catalogue and order sources. For other platforms, we verify the API and available integrations before any commitment.',
      platforms: ['Shopify', 'WooCommerce', 'Custom storefront / API', 'WhatsApp Business', 'Instagram & Messenger', 'CRM / help desk', 'Courier and fulfilment systems', 'Email and analytics'],
      processEyebrow: 'HOW WE INTRODUCE THE SYSTEM', processTitle: 'First we find where revenue leaks. Then we automate a measurable part of the journey.',
      process: [
        { phase: '01', title: 'Customer-journey discovery', text: 'We map the catalogue, channels, questions, checkout, abandoned carts, orders, returns, and post-purchase communication.' },
        { phase: '02', title: 'Data and rules', text: 'We define sources for price and stock, delivery and returns policies, recommendations, consent, and clear AI boundaries.' },
        { phase: '03', title: 'Integration and testing', text: 'We connect the first channel and platform, then test stock changes, coupons, orders, returns, and human handoff.' },
        { phase: '04', title: 'Launch and optimisation', text: 'We measure replies and conversions, then add cart recovery, campaigns, and additional channels by priority.' }
      ],
      faqEyebrow: 'FREQUENTLY ASKED QUESTIONS', faqTitle: 'What online stores want to know.',
      faqs: [
        { q: 'Which platforms can the system connect to?', a: 'Shopify, WooCommerce, and custom stores are standard cases. If you use another platform, we check its API, webhooks, and available integrations before proposing a solution.' },
        { q: 'Are WhatsApp messages to shoppers permitted?', a: 'Yes, when the official WhatsApp Business platform, the appropriate templates, and valid customer consent are used. We design the flow to record the basis, honour opt-out, and follow channel rules.' },
        { q: 'What happens if AI does not know the answer?', a: 'AI answers from approved sources and should not invent a price, stock level, or delivery date. When it lacks a reliable answer or the shopper requests an exception, the full conversation reaches a person.' },
        { q: 'How quickly can results become visible?', a: 'Automated answers and cart recovery can be measured as soon as the system enters production. The time to a statistically useful conclusion depends on traffic, cart volume, and seasonality.' },
        { q: 'How much does an e-commerce AI system cost?', a: 'It depends on the platform, channels, and scope. A chatbot for questions and recommendations is a smaller investment than a complete system with abandoned carts, returns, campaigns, and multiple integrations.' },
        { q: 'Which languages can AI sell in?', a: 'Serbian, English, and other languages according to the market. The same system can speak the shopper’s language while using one approved product and policy source.' }
      ],
      ctaTitle: 'Show us the store. We will show you where sales leak.', ctaText: 'In a free consultation, we review customer questions, abandoned carts, orders, and returns, then propose the first measurable step — without selling you a system you do not need.', ctaButton: 'Book a consultation'
    };

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: isSr ? 'AI sistemi za online prodavnice' : 'AI systems for e-commerce stores',
  serviceType: 'E-commerce sales and customer support automation',
  provider: { '@type': 'Organization', name: 'RoutineForge', url: SITE_URL },
  areaServed: 'Global', description: content.metaDescription,
  availableChannel: { '@type': 'ServiceChannel', serviceUrl: content.canonical, availableLanguage: ['English', 'Serbian'] }
};
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} canonical={content.canonical} enUrl={content.enUrl} srUrl={content.srUrl} lang={isSr ? 'sr' : 'en'}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <div class="min-h-screen overflow-x-hidden bg-slate-50">
    <Navbar />
    <main>
      <section class="flow-grid-bg relative overflow-hidden border-b border-slate-200/80"><div class="absolute inset-0 bg-[radial-gradient(circle_at_82%_20%,rgba(14,165,233,0.16),transparent_32%),radial-gradient(circle_at_12%_70%,rgba(34,211,238,0.12),transparent_28%)]"></div><div class="relative mx-auto grid max-w-7xl gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:px-8 lg:py-24"><div data-reveal><p class="inline-flex items-center gap-2 rounded-full border border-sky-200 bg-white/80 px-3 py-1 text-sm font-semibold text-sky-700"><IndustryIcon icon="ecommerce" />{content.eyebrow}</p><h1 class="mt-6 max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">{content.title}</h1><p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">{content.intro}</p><div class="mt-8 flex flex-wrap gap-3"><a href={contactHref} class="inline-flex items-center gap-2 rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-200 transition hover:bg-cyan-500">{content.primaryCta}<span>→</span></a><a href="#ecommerce-system" class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-sky-300 hover:text-sky-700">{content.secondaryCta}<span>↓</span></a></div><div class="mt-10 grid gap-3 sm:grid-cols-3">{content.proof.map((item) => <div class="rounded-2xl border border-white bg-white/75 p-4 shadow-sm backdrop-blur"><p class="font-semibold text-slate-950">{item.value}</p><p class="mt-1 text-xs leading-5 text-slate-500">{item.label}</p></div>)}</div></div><div data-reveal class="mx-auto w-full max-w-md rounded-[2.2rem] border border-sky-300/30 bg-slate-950 p-3 text-white shadow-[0_30px_80px_-28px_rgba(2,132,199,0.6)]"><div class="rounded-[1.7rem] bg-white p-5 text-slate-950"><div class="flex items-center justify-between border-b border-slate-100 pb-4"><div><p class="text-[11px] font-semibold tracking-[0.15em] text-sky-700">{content.visualLabel}</p><h2 class="mt-2 text-xl font-semibold">{content.visualTitle}</h2><p class="mt-1 text-sm text-slate-500">{content.visualSub}</p></div><span class="rounded-2xl bg-sky-50 p-3 text-sky-700"><LogoMark size={34} /></span></div><div class="mt-5 space-y-3">{content.chat.map((message, index) => <div class:list={["max-w-[88%] rounded-2xl px-4 py-3 text-sm leading-6", index === 1 ? 'ml-auto bg-sky-500 text-white' : 'bg-slate-100 text-slate-700']}>{message}</div>)}</div><div class="mt-5 rounded-2xl border border-sky-200 bg-sky-50 p-4"><div class="space-y-2">{content.cartItems.map((item) => <div class="flex items-center justify-between gap-3 text-xs"><span class="font-semibold text-slate-700">{item.name}</span><span class="font-semibold text-sky-700">{item.price}</span></div>)}</div><p class="mt-3 border-t border-sky-100 pt-3 text-xs font-semibold text-emerald-700">✓ {content.visualOutcome}</p></div></div></div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.painEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.painTitle}</h2><p class="mt-5 text-lg leading-8 text-slate-600">{content.painIntro}</p></div><div class="mt-10 grid gap-5 md:grid-cols-2">{content.pains.map((item, index) => <article data-reveal style={`--reveal-delay:${(index % 2) * 80}ms`} class="rounded-3xl border border-slate-200 bg-white/90 p-7 shadow-sm"><span class="text-xs font-semibold tracking-[0.18em] text-sky-700">{item.number}</span><h3 class="mt-4 text-xl font-semibold text-slate-950">{item.title}</h3><p class="mt-3 leading-7 text-slate-600">{item.text}</p></article>)}</div></section>

      <section id="ecommerce-system" class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.buildEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">{content.buildTitle}</h2><p class="mt-5 text-lg leading-8 text-slate-300">{content.buildIntro}</p></div><div class="mt-10 grid gap-5 md:grid-cols-2">{content.builds.map((item, index) => <article data-reveal style={`--reveal-delay:${(index % 2) * 80}ms`} class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-7"><span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-sky-400/20 bg-sky-400/10 text-sky-300"><ServiceIcon icon={item.icon} /></span><h3 class="mt-5 text-xl font-semibold">{item.title}</h3><p class="mt-3 flex-1 leading-7 text-slate-300">{item.text}</p><p class="mt-5 border-t border-white/10 pt-4 text-sm font-semibold text-sky-200">{item.outcome}</p></article>)}</div></div></section>

      <section class="mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-center lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.commerceEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.commerceTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.commerceText}</p><ul class="mt-6 space-y-3">{content.commerceSteps.map((item) => <li class="flex items-start gap-3 text-sm leading-6 text-slate-700"><span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">✓</span>{item}</li>)}</ul></div><div data-reveal class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-xl"><div class="flex items-center justify-between border-b border-slate-100 pb-4"><div><p class="text-xs font-semibold tracking-[0.14em] text-sky-700">{content.productMatchLabel}</p><p class="mt-1 font-semibold text-slate-950">{content.productMatchSub}</p></div><span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">{content.productStock}</span></div><div class="mt-5 space-y-3">{content.productCards.map((item, index) => <article class:list={["grid gap-3 rounded-2xl border p-4 sm:grid-cols-[1fr_auto] sm:items-center", index === 0 ? 'border-sky-300 bg-sky-50' : 'border-slate-200 bg-slate-50']}><div><p class="text-[10px] font-semibold uppercase tracking-[0.14em] text-sky-700">{item.tag}</p><p class="mt-2 font-semibold text-slate-950">{item.name}</p><p class="mt-1 text-xs text-slate-500">{item.detail}</p></div><p class="text-lg font-semibold text-slate-950">{item.price}</p></article>)}</div></div></section>

      <section class="border-y border-slate-200 bg-gradient-to-br from-sky-50 via-white to-cyan-50 py-20"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-center"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-white px-3 py-1 text-sm font-semibold text-sky-700">{content.cartEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.cartTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.cartText}</p></div><div data-reveal class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-xl"><div class="flex items-center gap-3 border-b border-slate-100 pb-4"><span class="rounded-2xl bg-emerald-50 p-3 text-emerald-700"><svg viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="1.8" aria-hidden="true"><path d="M5 4h14a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H9l-5 4v-4H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/><path d="M8 9h8M8 13h5"/></svg></span><div><p class="font-semibold text-slate-950">{content.cartRecoveryLabel}</p><p class="text-xs text-emerald-600">{content.cartRecoveryStatus}</p></div></div><div class="mt-5 space-y-3">{content.cartMessages.map((message, index) => <div class:list={["max-w-[88%] rounded-2xl px-4 py-3 text-sm leading-6", index === 1 ? 'ml-auto bg-emerald-500 text-white' : 'bg-slate-100 text-slate-700']}>{message}</div>)}</div></div></div><div class="mt-12"><h3 class="text-lg font-semibold text-slate-950">{content.benchmarkTitle}</h3><div class="mt-5 grid gap-4 md:grid-cols-3">{content.benchmarks.map((item) => <article data-reveal class="rounded-3xl border border-sky-200 bg-white p-6 shadow-sm"><p class="text-3xl font-semibold tracking-tight text-sky-700">{item.value}</p><p class="mt-3 text-sm font-semibold leading-6 text-slate-800">{item.label}</p></article>)}</div><p class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-xs leading-6 text-amber-900">{content.benchmarkNote}</p></div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.supportEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.supportTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.supportText}</p></div><div class="mt-10 grid gap-5 lg:grid-cols-2"><div data-reveal class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-xs font-semibold tracking-[0.15em] text-sky-700">{content.orderLabel}</p><div class="mt-5 space-y-3">{content.orderStates.map((item) => <article class:list={["flex gap-3 rounded-2xl border p-4", item.tone === 'active' ? 'border-sky-300 bg-sky-50' : 'border-slate-200 bg-slate-50']}><span class:list={["mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-bold", item.tone === 'done' ? 'bg-emerald-100 text-emerald-700' : item.tone === 'active' ? 'bg-sky-500 text-white' : 'bg-slate-200 text-slate-500']}>{item.tone === 'done' ? '✓' : item.tone === 'active' ? '●' : '○'}</span><div><p class="font-semibold text-slate-950">{item.state}</p><p class="mt-1 text-xs text-slate-500">{item.detail}</p></div></article>)}</div></div><div data-reveal class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm"><p class="text-xs font-semibold tracking-[0.15em] text-sky-300">{content.claimLabel}</p><div class="mt-6 space-y-4">{content.claimSteps.map((item, index) => <div class="flex items-start gap-4"><span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-sky-400/25 bg-sky-400/10 text-xs font-semibold text-sky-300">{index + 1}</span><p class="pt-1 text-sm leading-6 text-slate-300">{item}</p></div>)}</div><div class="mt-6 rounded-2xl border border-emerald-400/20 bg-emerald-400/10 p-4 text-sm font-semibold text-emerald-200">{content.claimFooter}</div></div></div></section>

      <section class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start"><div data-reveal><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.proofEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">{content.proofTitle}</h2><p class="mt-5 leading-8 text-slate-300">{content.proofText}</p><ul class="mt-6 space-y-3">{content.proofBullets.map((item) => <li class="flex items-start gap-3 text-sm leading-6 text-slate-300"><span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-400/15 text-emerald-300">✓</span>{item}</li>)}</ul></div><div data-reveal class="grid gap-4 sm:grid-cols-3">{content.proofMetrics.map((item) => <article class="rounded-3xl border border-sky-400/20 bg-white/5 p-6"><p class="text-4xl font-semibold tracking-tight text-cyan-300">{item.value}</p><p class="mt-3 text-sm font-semibold leading-6 text-white">{item.label}</p></article>)}</div></div><p class="mt-8 rounded-2xl border border-amber-300/25 bg-amber-300/10 px-5 py-4 text-xs leading-6 text-amber-100">{content.proofNote}</p></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.campaignsEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.campaignsTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.campaignsText}</p></div><div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">{content.campaigns.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 70}ms`} class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><p class="text-xs font-semibold uppercase tracking-[0.14em] text-sky-700">{item.timing}</p><h3 class="mt-4 font-semibold text-slate-950">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p></article>)}</div></section>

      <section class="border-y border-slate-200 bg-white/70 py-20"><div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-center lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.platformsEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.platformsTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.platformsText}</p></div><div class="grid gap-3 sm:grid-cols-2">{content.platforms.map((item) => <div data-reveal class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white p-4 text-sm font-semibold text-slate-700 shadow-sm"><span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-sky-50 text-sky-700">✓</span>{item}</div>)}</div></div></section>

      <section class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.processEyebrow}</p><h2 class="mt-5 max-w-3xl text-3xl font-semibold tracking-tight sm:text-4xl">{content.processTitle}</h2></div><div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">{content.process.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 80}ms`} class="rounded-3xl border border-white/10 bg-white/5 p-6"><p class="text-xs font-semibold tracking-[0.17em] text-sky-300">{item.phase}</p><h3 class="mt-5 text-lg font-semibold">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-300">{item.text}</p></article>)}</div></div></section>

      <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="text-center"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.faqEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.faqTitle}</h2></div><div class="mt-10 space-y-3">{content.faqs.map((item) => <details data-reveal class="group rounded-2xl border border-slate-200 bg-white/90 p-5 shadow-sm"><summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-slate-950"><span>{item.q}</span><span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-sky-50 text-sky-700 transition group-open:rotate-45">+</span></summary><p class="mt-4 max-w-3xl border-t border-slate-100 pt-4 leading-7 text-slate-600">{item.a}</p></details>)}</div></section>

      <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8"><div data-reveal class="relative overflow-hidden rounded-[2rem] border border-sky-400/20 bg-slate-950 p-8 text-center text-white shadow-[0_30px_90px_-25px_rgba(15,23,42,0.6)] sm:p-12"><div class="absolute left-1/2 top-0 h-64 w-64 -translate-x-1/2 rounded-full bg-sky-400/15 blur-3xl"></div><div class="relative"><h2 class="mx-auto max-w-4xl text-3xl font-semibold tracking-tight sm:text-4xl">{content.ctaTitle}</h2><p class="mx-auto mt-5 max-w-2xl leading-8 text-slate-300">{content.ctaText}</p><a href={contactHref} class="mt-8 inline-flex items-center gap-2 rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-950/30 transition hover:bg-cyan-400">{content.ctaButton}<span>→</span></a></div></div></section>
    </main>
    <Footer />
  </div>
</BaseLayout>
