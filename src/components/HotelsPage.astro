---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import LogoMark from './LogoMark.astro';
import IndustryIcon from './IndustryIcon.astro';
import ServiceIcon from './ServiceIcon.astro';
import { SITE_URL } from '../config/site';

const { lang = 'en' } = Astro.props;
const isSr = lang === 'sr';
const contactHref = isSr ? '/sr#contact' : '/#contact';

const content = isSr
  ? {
      metaTitle: 'AI za hotele: guest app, direktne rezervacije i automatizacija',
      metaDescription: 'RoutineForge gradi hotelske guest aplikacije, AI chatbotove za direktne rezervacije i automatizacije zahteva, smena i komunikacije sa gostima.',
      canonical: `${SITE_URL}/sr/ai-za-hotele`, enUrl: `${SITE_URL}/ai-for-hotels`, srUrl: `${SITE_URL}/sr/ai-za-hotele`,
      eyebrow: 'INDUSTRIJE · HOTELI I UGOSTITELJSTVO', title: 'Gost dobija uslugu odmah. Osoblje dobija prostor da radi svoj posao.',
      intro: 'Gradimo QR guest aplikaciju u sobi, AI chatbot za direktne rezervacije i povezane interne tokove — od e-mailova i pre-arrival pitanja do zahteva gostiju i predaje smene. Sve se oblikuje oko procesa Vašeg hotela.',
      primaryCta: 'Zakažite besplatnu konsultaciju', secondaryCta: 'Pogledajte guest sistem',
      proof: [{ value: 'Bez instalacije', label: 'QR otvara aplikaciju u browseru' }, { value: '24/7', label: 'odgovori i direktne rezervacije' }, { value: 'Jedan tok', label: 'od zahteva do potvrđenog izvršenja' }],
      visualLabel: 'GUEST APP · SOBA 304', guestGreeting: 'Dobro veče, Ana', guestSub: 'Kako možemo da unapredimo Vaš boravak?',
      guestActions: [{ icon: '🍽', label: 'Room service' }, { icon: '🧖', label: 'Spa termin' }, { icon: '🧺', label: 'Dodatni peškiri' }, { icon: '🕒', label: 'Late checkout' }], visualOrder: '2 peškira · Soba 304', visualStatus: ['Zahtev primljen', 'Dodeljeno domaćinstvu', 'Gost obavešten'],
      painEyebrow: 'ŠTA RECEPCIJA TRPI SVAKOG DANA', painTitle: 'Gost očekuje uslugu odmah i na svom jeziku. Recepcija ne može istovremeno biti centrala, concierge i check-in.', painIntro: 'Digitalni sloj preuzima rutinske zahteve i čuva kontekst, dok osoblje ostaje dostupno za goste kojima je stvarno potreban čovek.',
      pains: [
        { number: '01', title: 'Telefon na recepciji ne prestaje', text: 'Do kada je doručak, gde je spa, mogu li dobiti peškire — svaki poziv prekida check-in gosta koji već stoji ispred recepcionera.' },
        { number: '02', title: 'Room service ostaje ispod potencijala', text: 'Gost ne želi da zove i diktira porudžbinu. Digitalni meni sa fotografijama olakšava izbor i podstiče dodatnu stavku.' },
        { number: '03', title: 'Upiti za rezervaciju stižu noću', text: 'Direktna rezervacija propada ako odgovor stigne sutra, a svaki izgubljen direktan gost znači veću zavisnost od posrednika.' },
        { number: '04', title: 'Zahtevi se gube između smena', text: 'Gost traži peškire u 14h, smena se menja u 15h, a zahtev nema vlasnika ni potvrdu izvršenja. Recenzija pamti rezultat.' }
      ],
      buildEyebrow: 'ŠTA GRADIMO ZA HOTELE', buildTitle: 'Sve počinje od procesa hotela, ne od gotovog šablona.', buildIntro: 'Moduli mogu raditi samostalno, ali najviše vrednosti daju kada gost, recepcija, operativa i menadžment koriste isti tok podataka.',
      builds: [
        { icon: 'custom', title: 'Guest app sa QR kodom', text: 'Gost skenira kod u sobi i na svom telefonu vidi meni, hotelske usluge i zahteve, na jeziku koji razume.', outcome: 'Porudžbina stiže direktno odgovornom timu bez prepričavanja.' },
        { icon: 'custom', title: 'Više prihoda po gostu', text: 'Digitalni meni sa fotografijama i preporukama nudi room service, spa, late checkout i izlete u pravom trenutku.', outcome: 'Lakše naručivanje i vidljivije dodatne usluge.' },
        { icon: 'chat', title: 'AI chatbot za direktne rezervacije', text: 'Na sajtu i WhatsAppu odgovara o sobama, cenama, sadržajima i dostupnosti 24/7 i vodi gosta ka direktnoj rezervaciji.', outcome: 'Više direktnih upita bez provizije posredniku.' },
        { icon: 'workflow', title: 'AI optimizacija internih procesa', text: 'Zahtev se prati od prijema do izvršenja, smene se automatski predaju, a AI pomaže kod e-mailova i pre-arrival upita.', outcome: 'Ništa ne ostaje samo u pozivu, poruci ili sećanju.' },
        { icon: 'phone', title: 'Opcioni AI telefonski agent', text: 'Odgovara na rutinska pitanja, prepoznaje nameru, beleži zahtev i prosleđuje složene ili osetljive pozive recepciji.', outcome: 'Telefon manje prekida rad, a gost ipak dobija odgovor.' }
      ],
      appEyebrow: 'CUSTOM GUEST APP · BEZ PREUZIMANJA', appTitle: 'QR kod otvara hotelske usluge na telefonu gosta.', appText: 'Nema instalacije, registracije ni učenja novog interfejsa. Gost otvara browser, bira jezik, naručuje ili šalje zahtev, a osoblje ga odmah vidi u operativnoj aplikaciji.',
      appBenefits: ['Meni, usluge, informacije i zahtevi u jednom mestu', 'Više jezika iz istog sadržaja i istih pravila', 'Status zahteva vidljiv gostu i odgovornom timu', 'Prilagođeno identitetu, ponudi i procedurama hotela'],
      staffLabel: 'OPERATIVNA APLIKACIJA', staffTasks: [{ room: '304', request: 'Dodatni peškiri', team: 'Domaćinstvo', status: 'U toku' }, { room: '118', request: 'Room service', team: 'F&B', status: 'Primljeno' }, { room: '507', request: 'Late checkout', team: 'Recepcija', status: 'Čeka potvrdu' }],
      revenueEyebrow: 'VIŠE VREDNOSTI PO BORAVKU', revenueTitle: 'Digitalni meni ne čeka da gost pita šta još nudite.', revenueText: 'Fotografije, jasne cene i preporuke prema trenutku boravka čine dodatne usluge lakšim za otkrivanje i kupovinu, bez pritiska na recepciju.',
      upsells: [{ time: 'Dolazak', title: 'Transfer i rana prijava', text: 'Relevantna ponuda pre ili neposredno po dolasku.' }, { time: 'Tokom boravka', title: 'Room service i spa', text: 'Vizuelna ponuda kada gost najlakše može da je koristi.' }, { time: 'Poslednje veče', title: 'Late checkout', text: 'Ponuda prema raspoloživosti, bez dodatnog poziva.' }, { time: 'Lokalno iskustvo', title: 'Izleti i aktivnosti', text: 'Preporuke povezane sa interesovanjem gosta.' }],
      bookingEyebrow: 'AI CHATBOT · DIREKTNE REZERVACIJE', bookingTitle: 'Noćni upit dobija odgovor dok je namera za rezervaciju još jaka.', bookingText: 'Chatbot koristi odobrene informacije o sobama, cenama, sadržajima i pravilima. Prikuplja datume, broj gostiju i potrebe, zatim vodi ka booking engine-u ili predaje pripremljen upit recepciji.',
      bookingMessages: ['Da li imate dvokrevetnu sobu od 12. do 15. avgusta?', 'Dostupne su Standard i Superior soba. Putujete li sa detetom?', 'Ne, dve odrasle osobe. Želim direktnu ponudu.'], bookingStates: ['Datumi kvalifikovani', 'Tip sobe izabran', 'Direktan booking otvoren'],
      opsEyebrow: 'OD ZAHTEVA DO IZVRŠENJA', opsTitle: 'Smena se menja. Kontekst ostaje.', opsText: 'Svaki zahtev dobija vreme, sobu, kategoriju, odgovorni tim, prioritet i status. Sledeća smena vidi otvorene obaveze, a menadžment vreme odgovora i ponavljajuće probleme.',
      opsSteps: [{ phase: '01', title: 'Gost šalje zahtev', text: 'QR app, chatbot, telefon ili recepcija stvaraju isti strukturiran zapis.' }, { phase: '02', title: 'Automatsko usmeravanje', text: 'Domaćinstvo, F&B, održavanje ili recepcija dobijaju pravi zadatak.' }, { phase: '03', title: 'Praćenje i eskalacija', text: 'Sistem prati rok, podseća i eskalira zahtev koji predugo čeka.' }, { phase: '04', title: 'Potvrda i handover', text: 'Gost dobija status, a otvoreni zadaci prelaze u sledeću smenu.' }],
      managementEyebrow: 'UPRAVLJANJE NA OSNOVU PODATAKA', managementTitle: 'Menadžment vidi šta gosti traže i koliko brzo hotel odgovara.', managementText: 'Umesto oslanjanja na utisak, dashboard prikazuje zahteve, porudžbine, vreme prvog odgovora, vreme izvršenja, opterećenje smena i najtraženije usluge.',
      managementCards: [{ label: 'Otvoreni zahtevi', value: '12', detail: '3 zahtevaju pažnju' }, { label: 'Medijana odgovora', value: '2m 18s', detail: 'Sve smene danas' }, { label: 'Najčešći zahtev', value: 'Peškiri', detail: '18% zahteva ove nedelje' }, { label: 'Dodatne usluge', value: '34', detail: 'Room service, spa, late checkout' }],
      benchmarkEyebrow: 'SELF-SERVICE U HOTELIJERSTVU', benchmarkTitle: 'Gosti žele kontrolu na telefonu — bez gubitka ljudskog gostoprimstva.', benchmarks: [{ value: '73%', label: 'putnika preferira hotele sa self-service tehnologijom', source: 'travel-industry benchmark naveden na referentnoj stranici' }, { value: '50%', label: 'gostiju preferira mobilni check-in i check-out umesto čekanja', source: 'hospitality benchmark naveden na referentnoj stranici' }, { value: '0%', label: 'provizije posredniku kada se rezervacija završi direktno', source: 'ne uključuje payment ili druge operativne troškove' }],
      benchmarkNote: 'Eksterni benchmark podaci opisuju ponašanje tržišta i nisu RoutineForge garancija rezultata. Za hotel merimo direktne upite, vreme odgovora, završene zahteve i prihod od dodatnih usluga pre i posle implementacije.',
      integrationsEyebrow: 'POSTOJEĆI HOTELSKI SISTEMI', integrationsTitle: 'Guest app se gradi oko procesa i povezuje tamo gde postoji pouzdan pristup.', integrationsText: 'Pre predloga proveravamo PMS, booking engine, POS, komunikacione kanale i API mogućnosti. Ako direktna integracija nije dostupna, definišemo kontrolisan način razmene podataka bez duplog rada.',
      integrations: ['PMS / property management system', 'Booking engine i dostupnost', 'POS / room service', 'WhatsApp i e-mail', 'Housekeeping i maintenance tokovi', 'Dashboard i izveštaji'],
      processEyebrow: 'OD PROCESA DO PRVE SOBE', processTitle: 'Počnite jasnim opsegom, pa povežite ceo boravak.', process: [{ phase: '01', title: 'Snimak guest journey-a', text: 'Mapiramo rezervaciju, dolazak, boravak, zahteve, dodatne usluge, smene i postojeće sisteme.' }, { phase: '02', title: 'Prioritet i prototip', text: 'Biramo prvi tok, jezike, sadržaj, timove, statuse, integracije i metrike uspeha.' }, { phase: '03', title: 'Izrada i testiranje', text: 'Testiramo QR pristup, porudžbine, zahteve, nedostupnost usluge, predaju smene i human handoff.' }, { phase: '04', title: 'Fazno lansiranje', text: 'Krećemo od dela soba ili jednog modula, merimo korišćenje i širimo sistem prema rezultatu.' }],
      faqEyebrow: 'ČESTA PITANJA', faqTitle: 'Šta hotelijeri žele da znaju.',
      faqs: [
        { q: 'Da li gost mora da instalira aplikaciju?', a: 'Ne. Skenira QR kod i guest app se otvara u browseru telefona, bez instalacije i registracije. Jezik se bira automatski ili ručno.' },
        { q: 'Da li radi sa našim postojećim PMS-om?', a: 'Povezujemo sistem gde PMS ili drugi alat ima pouzdan API ili podržan način razmene podataka. Integracije proveravamo tokom snimka procesa pre konačnog predloga.' },
        { q: 'Šta dobija menadžment?', a: 'Pregled svih porudžbina i zahteva, otvorenih zadataka, vremena odgovora i izvršenja po smeni, kao i podatke o najčešćim potrebama i korišćenju dodatnih usluga.' },
        { q: 'Da li je ovo samo za velike hotele?', a: 'Ne. Opseg se prilagođava objektu, od boutique hotela do većih sistema. Manjem timu digitalni self-service često donosi još veću vrednost jer smanjuje prekide.' },
        { q: 'Koliko košta hotelska guest aplikacija?', a: 'Zavisi od modula, jezika, dizajna, integracija i broja operativnih tokova. Osnovni meni i zahtevi su manja investicija od kompletnog sistema sa chatbotom, PMS-om i internim automatizacijama.' },
        { q: 'Na koliko jezika rade aplikacija i chatbot?', a: 'Na onoliko koliko je potrebno gostima. Srpski i engleski mogu biti početni jezici, a drugi se dodaju uz prevod i proveru hotelskog sadržaja i pravila.' }
      ],
      ctaTitle: 'Gost naručuje iz sobe. Osoblje konačno diše.', ctaText: 'Na konsultaciji prolazimo kroz procese hotela i pokazujemo kako bi guest app, direktne rezervacije i povezani zahtevi izgledali u Vašem objektu.', ctaButton: 'Zakažite konsultaciju'
    }
  : {
      metaTitle: 'AI for hotels: guest app, direct bookings, and automation',
      metaDescription: 'RoutineForge builds hotel guest apps, AI chatbots for direct bookings, and automation for guest requests, shift handover, and communication.',
      canonical: `${SITE_URL}/ai-for-hotels`, enUrl: `${SITE_URL}/ai-for-hotels`, srUrl: `${SITE_URL}/sr/ai-za-hotele`,
      eyebrow: 'INDUSTRIES · HOTELS & HOSPITALITY', title: 'Guests receive service instantly. Staff get room to do their work.',
      intro: 'We build an in-room QR guest app, an AI chatbot for direct bookings, and connected internal workflows — from emails and pre-arrival questions to guest requests and shift handover. Everything is shaped around your hotel processes.',
      primaryCta: 'Book a free consultation', secondaryCta: 'See the guest system',
      proof: [{ value: 'No installation', label: 'QR opens the app in a browser' }, { value: '24/7', label: 'answers and direct booking' }, { value: 'One workflow', label: 'from request to confirmed completion' }],
      visualLabel: 'GUEST APP · ROOM 304', guestGreeting: 'Good evening, Ana', guestSub: 'How can we improve your stay?',
      guestActions: [{ icon: '🍽', label: 'Room service' }, { icon: '🧖', label: 'Spa booking' }, { icon: '🧺', label: 'Extra towels' }, { icon: '🕒', label: 'Late checkout' }], visualOrder: '2 towels · Room 304', visualStatus: ['Request received', 'Assigned to housekeeping', 'Guest notified'],
      painEyebrow: 'WHAT RECEPTION ENDURES EVERY DAY', painTitle: 'Guests expect instant service in their own language. Reception cannot be switchboard, concierge, and check-in at once.', painIntro: 'A digital layer handles routine requests and preserves context, while staff remain available for guests who genuinely need a person.',
      pains: [
        { number: '01', title: 'The reception phone never stops', text: 'When does breakfast end, where is the spa, can I get towels — every call interrupts the check-in of a guest already standing at the desk.' },
        { number: '02', title: 'Room service remains below its potential', text: 'Guests do not want to call and dictate an order. A digital menu with photos makes selection easier and encourages one more item.' },
        { number: '03', title: 'Booking enquiries arrive at night', text: 'A direct booking falls through if the reply comes tomorrow, and every lost direct guest increases dependence on intermediaries.' },
        { number: '04', title: 'Requests disappear between shifts', text: 'A guest asks for towels at 14:00, the shift changes at 15:00, and the request has no owner or completion confirmation. The review remembers the outcome.' }
      ],
      buildEyebrow: 'WHAT WE BUILD FOR HOTELS', buildTitle: 'Everything starts from hotel processes, not an off-the-shelf template.', buildIntro: 'Modules can work independently, but create the most value when the guest, reception, operations, and management share one data workflow.',
      builds: [
        { icon: 'custom', title: 'Guest app with a QR code', text: 'Guests scan a code in the room and see the menu, hotel services, and requests on their own phone in a language they understand.', outcome: 'The order reaches the responsible team without retelling.' },
        { icon: 'custom', title: 'More revenue per guest', text: 'A digital menu with photos and recommendations offers room service, spa, late checkout, and excursions at the right moment.', outcome: 'Simpler ordering and more visible additional services.' },
        { icon: 'chat', title: 'AI chatbot for direct bookings', text: 'On the website and WhatsApp, it answers about rooms, prices, amenities, and availability 24/7 and guides guests toward direct booking.', outcome: 'More direct enquiries without intermediary commission.' },
        { icon: 'workflow', title: 'AI optimization of internal processes', text: 'Requests are tracked from intake to completion, shifts hand over automatically, and AI helps with emails and pre-arrival enquiries.', outcome: 'Nothing remains only in a call, message, or memory.' },
        { icon: 'phone', title: 'Optional AI phone agent', text: 'It answers routine questions, identifies intent, records requests, and transfers complex or sensitive calls to reception.', outcome: 'The phone interrupts less while guests still receive an answer.' }
      ],
      appEyebrow: 'CUSTOM GUEST APP · NO DOWNLOAD', appTitle: 'A QR code opens hotel services on the guest’s phone.', appText: 'There is no installation, registration, or new interface to learn. Guests open a browser, choose a language, order or submit a request, and staff see it immediately in the operations app.',
      appBenefits: ['Menu, services, information, and requests in one place', 'Multiple languages from the same content and rules', 'Request status visible to guest and responsible team', 'Shaped around the hotel identity, offer, and procedures'],
      staffLabel: 'OPERATIONS APP', staffTasks: [{ room: '304', request: 'Extra towels', team: 'Housekeeping', status: 'In progress' }, { room: '118', request: 'Room service', team: 'F&B', status: 'Received' }, { room: '507', request: 'Late checkout', team: 'Reception', status: 'Awaiting approval' }],
      revenueEyebrow: 'MORE VALUE PER STAY', revenueTitle: 'A digital menu does not wait for guests to ask what else you offer.', revenueText: 'Photos, clear prices, and recommendations matched to the stay make additional services easier to discover and buy without adding pressure to reception.',
      upsells: [{ time: 'Arrival', title: 'Transfer and early check-in', text: 'A relevant offer before or immediately after arrival.' }, { time: 'During the stay', title: 'Room service and spa', text: 'A visual offer when the guest can use it most easily.' }, { time: 'Final evening', title: 'Late checkout', text: 'Offered according to availability without another call.' }, { time: 'Local experience', title: 'Excursions and activities', text: 'Recommendations connected to guest interests.' }],
      bookingEyebrow: 'AI CHATBOT · DIRECT BOOKINGS', bookingTitle: 'A night-time enquiry receives an answer while booking intent is still strong.', bookingText: 'The chatbot uses approved information about rooms, prices, amenities, and rules. It captures dates, party size, and needs, then guides guests to the booking engine or hands a prepared enquiry to reception.',
      bookingMessages: ['Do you have a double room from 12 to 15 August?', 'Standard and Superior rooms are available. Are you travelling with a child?', 'No, two adults. I would like a direct offer.'], bookingStates: ['Dates qualified', 'Room type selected', 'Direct booking opened'],
      opsEyebrow: 'FROM REQUEST TO COMPLETION', opsTitle: 'The shift changes. Context remains.', opsText: 'Every request receives a time, room, category, responsible team, priority, and status. The next shift sees open duties, while management sees response time and recurring issues.',
      opsSteps: [{ phase: '01', title: 'Guest submits a request', text: 'QR app, chatbot, phone, or reception creates the same structured record.' }, { phase: '02', title: 'Automatic routing', text: 'Housekeeping, F&B, maintenance, or reception receives the right task.' }, { phase: '03', title: 'Tracking and escalation', text: 'The system monitors the deadline, reminds, and escalates a request waiting too long.' }, { phase: '04', title: 'Confirmation and handover', text: 'The guest receives status, and open tasks move into the next shift.' }],
      managementEyebrow: 'MANAGEMENT BY DATA', managementTitle: 'Management sees what guests request and how quickly the hotel responds.', managementText: 'Instead of relying on impressions, a dashboard shows requests, orders, first-response time, completion time, shift workload, and the most requested services.',
      managementCards: [{ label: 'Open requests', value: '12', detail: '3 require attention' }, { label: 'Median response', value: '2m 18s', detail: 'All shifts today' }, { label: 'Most common request', value: 'Towels', detail: '18% of requests this week' }, { label: 'Additional services', value: '34', detail: 'Room service, spa, late checkout' }],
      benchmarkEyebrow: 'SELF-SERVICE IN HOSPITALITY', benchmarkTitle: 'Guests want control on their phone — without losing human hospitality.', benchmarks: [{ value: '73%', label: 'of travellers prefer hotels with self-service technology', source: 'travel-industry benchmark quoted by the reference page' }, { value: '50%', label: 'of guests prefer mobile check-in and check-out over waiting', source: 'hospitality benchmark quoted by the reference page' }, { value: '0%', label: 'intermediary commission when booking completes directly', source: 'does not include payment or other operating costs' }],
      benchmarkNote: 'External benchmarks describe market behavior and are not a RoutineForge performance guarantee. For your hotel, we measure direct enquiries, response time, completed requests, and additional-service revenue before and after implementation.',
      integrationsEyebrow: 'EXISTING HOTEL SYSTEMS', integrationsTitle: 'The guest app is built around your processes and connects where reliable access exists.', integrationsText: 'Before proposing a solution, we review the PMS, booking engine, POS, communication channels, and API options. If direct integration is unavailable, we define a controlled exchange that avoids duplicate work.',
      integrations: ['PMS / property management system', 'Booking engine and availability', 'POS / room service', 'WhatsApp and email', 'Housekeeping and maintenance workflows', 'Dashboard and reporting'],
      processEyebrow: 'FROM PROCESS TO THE FIRST ROOM', processTitle: 'Start with a clear scope, then connect the entire stay.', process: [{ phase: '01', title: 'Guest-journey discovery', text: 'We map booking, arrival, stay, requests, additional services, shifts, and existing systems.' }, { phase: '02', title: 'Priority and prototype', text: 'We choose the first workflow, languages, content, teams, statuses, integrations, and success metrics.' }, { phase: '03', title: 'Build and testing', text: 'We test QR access, orders, requests, service unavailability, shift handover, and human handoff.' }, { phase: '04', title: 'Phased rollout', text: 'We begin with part of the property or one module, measure usage, and expand according to results.' }],
      faqEyebrow: 'FREQUENTLY ASKED QUESTIONS', faqTitle: 'What hoteliers want to know.',
      faqs: [
        { q: 'Does the guest have to install an app?', a: 'No. They scan a QR code and the guest app opens in the phone browser without installation or registration. The language can be selected automatically or manually.' },
        { q: 'Does it work with our existing PMS?', a: 'We connect where the PMS or another system provides a reliable API or supported data exchange. Integrations are reviewed during process discovery before the final proposal.' },
        { q: 'What does management receive?', a: 'A view of all orders and requests, open tasks, response and completion time by shift, plus data on recurring needs and additional-service usage.' },
        { q: 'Is this only for large hotels?', a: 'No. Scope is sized to the property, from boutique hotels to larger systems. For a smaller team, digital self-service can matter even more because it reduces interruptions.' },
        { q: 'How much does a hotel guest app cost?', a: 'It depends on modules, languages, design, integrations, and operational workflows. A basic menu and requests app is a smaller investment than a complete system with chatbot, PMS, and internal automation.' },
        { q: 'How many languages do the app and chatbot support?', a: 'As many as guests require. English and Serbian can be the starting languages, with others added through translation and review of hotel content and rules.' }
      ],
      ctaTitle: 'The guest orders from the room. The staff breathe out.', ctaText: 'In a free consultation, we review hotel processes and show how a guest app, direct booking, and connected requests could work in your property.', ctaButton: 'Book a consultation'
    };

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: isSr ? 'AI sistemi za hotele i ugostiteljstvo' : 'AI systems for hotels and hospitality',
  serviceType: 'Hotel guest experience and operations automation',
  provider: { '@type': 'Organization', name: 'RoutineForge', url: SITE_URL },
  areaServed: 'Global', description: content.metaDescription,
  availableChannel: { '@type': 'ServiceChannel', serviceUrl: content.canonical, availableLanguage: ['English', 'Serbian'] }
};
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} canonical={content.canonical} enUrl={content.enUrl} srUrl={content.srUrl} lang={isSr ? 'sr' : 'en'}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <div class="min-h-screen overflow-x-hidden bg-slate-50">
    <Navbar />
    <main>
