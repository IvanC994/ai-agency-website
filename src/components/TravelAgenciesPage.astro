---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import ContextualLinks from './ContextualLinks.astro';
import LogoMark from './LogoMark.astro';
import IndustryIcon from './IndustryIcon.astro';
import ServiceIcon from './ServiceIcon.astro';
import { SITE_URL } from '../config/site';

const { lang = 'en' } = Astro.props;
const isSr = lang === 'sr';
const contactHref = isSr ? '/sr/#contact' : '/#contact';

const content = isSr
  ? {
      metaTitle: 'AI za turističke agencije i prodaju',
      metaDescription: 'RoutineForge gradi AI chatbotove za turističke agencije, poruke pred put, naknadnu komunikaciju i ponovno aktiviranje putnika preko sajta, Instagrama i WhatsAppa.',
      canonical: `${SITE_URL}/sr/ai-za-turisticke-agencije/`, enUrl: `${SITE_URL}/ai-for-travel-agencies/`, srUrl: `${SITE_URL}/sr/ai-za-turisticke-agencije/`,
      eyebrow: 'INDUSTRIJE · TURISTIČKE AGENCIJE', title: 'Putnik najčešće rezerviše kod agencije koja prva odgovori.',
      intro: 'Gradimo AI prodajnog asistenta koji za nekoliko sekundi odgovara na pitanja o terminima, cenama i uslovima na sajtu, Instagramu i WhatsAppu, kvalifikuje putnika, šalje poruke pred put i ponovo aktivira bazu iz prethodnih sezona.',
      primaryCta: 'Zakažite besplatnu konsultaciju', secondaryCta: 'Pogledajte sistem',
      proof: [{ value: '24/7', label: 'odgovori o aranžmanima' }, { value: '3 kanala', label: 'jedna baza aranžmana' }, { value: '1 sekunda', label: 'do prvog relevantnog odgovora' }],
      visualLabel: 'UPIT ZA ARANŽMAN · ILUSTRATIVNI PRIMER', traveller: 'Putnik', assistant: 'RoutineForge Travel AI',
      messages: ['Da li imate Krit početkom jula za dvoje?', 'Da — imamo polaske 3. i 10. jula. Da li želite 7 ili 10 noćenja?', '7 noćenja, do 1.500 € ukupno.'],
      visualStates: ['Destinacija: Krit', '2 putnika · 7 noći', 'Budžet: do 1.500 €'], visualOutcome: 'Upit spreman za prodajnog agenta',
      painEyebrow: 'GDE AGENCIJE GUBE PUTNIKE', painTitle: 'Ponuda često nije problem. Brzina odgovora i zaboravljena baza jesu.', painIntro: 'U špicu se prodaja gubi dok tim ručno prepisuje cenovnik, odgovara na isti upit peti put ili tek sutra pronalazi putnika koji je već uplatio kod konkurencije.',
      pains: [
        { number: '01', title: 'Isti upit odlazi na pet adresa', text: 'Upit koji stiže Vama istog minuta stiže i konkurenciji. Odgovor posle nekoliko sati često dolazi putniku koji je već rezervisao.' },
        { number: '02', title: 'Tim ponavlja odgovore umesto da prodaje', text: 'Dostupnost, šta je uključeno, depozit, hotel i polazak već postoje u cenovniku, ali ih prodavac iznova kuca umesto da zatvara prodaju.' },
        { number: '03', title: 'Baza prethodnih putnika miruje', text: 'Putnici koji Vas već poznaju najlakše ponovo kupuju, ali bez segmentacije i sistematskog kontakta najvrednija baza ostaje neiskorišćena.' },
        { number: '04', title: 'Grupna obaveštenja zavise od ručnog rada', text: 'Poruke o uplati, dokumentima, polasku i promenama šalju se ručno, pa neko ostane neobavešten ili tim ne zna da li je poruka isporučena.' }
      ],
      buildEyebrow: 'ŠTA GRADIMO ZA AGENCIJE', buildTitle: 'AI koristi Vaše aranžmane i cenovnike — i odgovara kao iskusan prodajni savetnik.', buildIntro: 'Sistem se oblikuje prema destinacijama, grupama, kanalima, pravilima prodaje i alatima koje već koristite.',
      builds: [
        { icon: 'chat', title: 'AI chatbot koji prodaje aranžmane', text: 'Na sajtu, Instagramu i WhatsAppu odgovara o terminima, cenama i uslovima, postavlja prava pitanja i predaje pripremljen upit agentu.', outcome: 'Agent dobija kontekst i fokusira se na zatvaranje prodaje.' },
        { icon: 'workflow', title: 'Poruke pred put', text: 'WhatsApp poruke o uplatama, dokumentima, polascima i promenama prate kalendar svake grupe i status isporuke.', outcome: 'Putnici dobijaju pravovremene i sadržajnije poruke od običnog SMS-a.' },
        { icon: 'custom', title: 'Reaktivacija prethodnih putnika', text: 'Baza se segmentira prema destinaciji, tipu putovanja i profilu: Grčka za prethodne goste Grčke, porodični aranžmani za porodice.', outcome: 'Nova prodaja počinje od ljudi koji Vam već veruju.' },
        { icon: 'workflow', title: 'Dalja komunikacija sa zainteresovanim putnicima', text: 'Putnik koji se raspitivao, ali nije rezervisao, dobija relevantnu poruku dok interesovanje još traje.', outcome: 'Zainteresovan putnik ne ostaje zaboravljen u prijemnom sandučetu.' },
        { icon: 'phone', title: 'Opcioni AI telefonski agent', text: 'Može da primi rutinske pozive, prikupi destinaciju, datum, broj putnika i budžet, pa razgovor ili povratni poziv preda prodavcu.', outcome: 'Telefon postaje još jedan strukturiran ulaz u isti prodajni tok.' }
      ],
      speedEyebrow: 'BRZINA ODGOVORA · PRODAJA PUTOVANJA', speedTitle: 'Prvi koristan odgovor pretvara interesovanje u razgovor dok je namera još jaka.', speedText: 'AI istovremeno vodi veliki broj razgovora, odmah kvalifikuje upit i obaveštava prodavca. Špic sezone više ne mora da znači propuštene poruke.',
      speedBenefits: ['Svaki upit beleži destinaciju, datume, broj putnika i budžet', 'Odgovor koristi aktuelne podatke iz iste baze aranžmana', 'Prodajni savetnik preuzima pripremljen razgovor umesto da sve ponovo pita od početka'],
      benchmarks: [{ value: '78%', label: 'kupaca bira ponuđača koji prvi odgovori', source: 'često citirano istraživanje brzine odgovora na upite' }, { value: '21×', label: 'veća šansa za kvalifikaciju uz odgovor u prvih 5 minuta u odnosu na 30', source: 'MIT / InsideSales istraživanje' }, { value: '−80%', label: 'navedeni pad prodajne šanse kada odgovor kasni 10 umesto 5 minuta', source: 'istraživanje brzine odgovora navedeno na izvornoj stranici' }],
      benchmarkNote: 'Spoljni referentni podaci služe kao ilustracija važnosti brzine, a ne kao garancija RoutineForge rezultata. Za Vašu agenciju merimo početno stanje, vreme odgovora i konverziju pre i posle uvođenja sistema.',
      dataEyebrow: 'JEDNA BAZA ARANŽMANA', dataTitle: 'Cena i dostupnost se menjaju. Odgovor mora da ih prati.', dataText: 'AI se povezuje sa cenovnicima i tabelama ili sa sistemom za rezervacije kada postoji odgovarajući pristup. Kada se podatak promeni u odobrenom izvoru, sledeći odgovor koristi novu informaciju.',
      dataFlow: [{ label: 'Izvori', text: 'Cenovnici, tabele, sistem za rezervacije' }, { label: 'AI sloj', text: 'Pretraga ponude i odobreni odgovori' }, { label: 'Kvalifikacija', text: 'Destinacija, datumi, putnici, budžet' }, { label: 'Prodajni savetnik', text: 'Pripremljen upit i kompletan kontekst' }],
      unknownTitle: 'A kada AI ne zna odgovor?', unknownText: 'Ne nagađa. Razgovor prosleđuje agentu sa svim do tada prikupljenim informacijama, tako da prodavac nastavlja razgovor tamo gde je AI stao.',
      remindersEyebrow: 'OD UPLATE DO POLASKA', remindersTitle: 'Svaka grupa dobija pravu poruku u pravo vreme.', remindersText: 'Automatizacija prati kalendar grupe i status putnika, dok tim zadržava pregled i mogućnost izmene ili ručnog preuzimanja.',
      reminderSteps: [{ time: 'Nakon rezervacije', title: 'Potvrda i depozit', text: 'Sažetak aranžmana, rok i instrukcije za uplatu.' }, { time: 'Pre roka', title: 'Dokumenta i doplata', text: 'Personalizovan podsetnik samo putnicima kojima je potreban.' }, { time: 'Pred polazak', title: 'Vreme i mesto okupljanja', text: 'Sve važne informacije u jednoj WhatsApp poruci.' }, { time: 'Kod promene', title: 'Ažuriranje cele grupe', text: 'Brzo slanje uz vidljiv status isporuke.' }],
      reactivationEyebrow: 'PONOVNO AKTIVIRANJE I DALJA KOMUNIKACIJA', reactivationTitle: 'Najisplativija nova prodaja često počinje od putnika koji Vas već poznaje.', reactivationText: 'Umesto jedne poruke svima, svaka grupa dobija relevantnu ponudu, a svaki odgovor ulazi u prodajni tok sa odgovornom osobom i sledećim korakom.',
      segments: [{ label: 'Grčka prošle sezone', offer: 'Novi termini za Krit i Rodos' }, { label: 'Porodice sa decom', offer: 'Porodični hoteli i fleksibilni polasci' }, { label: 'Zimska putovanja', offer: 'Rani izbor ski aranžmana' }, { label: 'Pitao, nije rezervisao', offer: 'Naknadna poruka dok interesovanje traje' }],
      channelsEyebrow: 'TRI KANALA · JEDAN PRODAJNI TOK', channelsTitle: 'Sajt, Instagram i WhatsApp koriste iste podatke i isti CRM.', channelsText: 'Razgovor ne ostaje zaboravljen u prijemnom sandučetu. AI beleži izvor, interesovanje, kvalifikaciju, odgovornu osobu i sledeću radnju. Čovek može da preuzme razgovor u svakom trenutku.',
      channels: ['Chat na sajtu', 'Privatne poruke na Instagramu', 'WhatsApp Business', 'CRM / Google Sheets', 'Sistem za rezervacije / API', 'E-mail i interna obaveštenja'],
      processEyebrow: 'OD UPITA DO PRVOG SISTEMA', processTitle: 'Počnite jednim kanalom, pa širite ono što daje rezultat.', process: [{ phase: '01', title: 'Snimak prodajnog toka', text: 'Mapiramo izvore upita, aranžmane, cenovnike, način kvalifikacije, predaju prodajnom savetniku i grupna obaveštenja.' }, { phase: '02', title: 'Baza znanja i pravila', text: 'Definišemo izvore, dozvoljene odgovore, jezike, scenarije, predaju razgovora čoveku i metrike uspeha.' }, { phase: '03', title: 'Izrada i testiranje', text: 'Povezujemo prvi kanal i testiramo stvarne aranžmane, izmene cena, nedostupnost, nejasne upite i opterećenje u špicu sezone.' }, { phase: '04', title: 'Puštanje u rad i širenje', text: 'Krećemo sa sajtom ili Instagramom, merimo rezultat, zatim dodajemo WhatsApp, podsetnike i ponovno aktiviranje putnika.' }],
      faqEyebrow: 'ČESTA PITANJA', faqTitle: 'Šta turističke agencije žele da znaju.',
      faqs: [
        { q: 'Kako AI zna cene i dostupnost?', a: 'Povezuje se sa odobrenim cenovnicima i tabelama ili sa sistemom za rezervacije kada postoji mogućnost povezivanja. Kada se izvorni podatak promeni, sistem koristi novu informaciju.' },
        { q: 'Šta ako putnik pita nešto što AI ne zna?', a: 'AI ne nagađa. Razgovor prosleđuje agentu sa destinacijom, datumima, brojem putnika, budžetom i celim kontekstom, pa prodavac ne počinje od nule.' },
        { q: 'Da li radi i u špicu sezone?', a: 'To je trenutak kada donosi najviše vrednosti: sistem paralelno vodi veliki broj razgovora, dok tim vidi prioritete i preuzima upite spremne za prodaju.' },
        { q: 'Možemo li da počnemo samo jednim kanalom?', a: 'Da. Često se počinje sa sajtom ili Instagramom, a WhatsApp, podsetnici i drugi tokovi dodaju se kada prvi kanal pokaže vrednost.' },
        { q: 'Da li radi sa stranim putnicima?', a: 'Da. Sistem može da razgovara na srpskom, engleskom i drugim jezicima koristeći istu bazu aranžmana i ista poslovna pravila.' },
        { q: 'Koliko košta AI sistem za turističku agenciju?', a: 'Zavisi od broja kanala, izvora podataka, jezika i scenarija. Chatbot za upite je manja investicija od povezanog sistema sa podsetnicima, CRM-om i reaktivacijom; posle konsultacije dobijate fazni predlog.' }
      ],
      ctaTitle: 'Vi pravite aranžmane. AI ih prvi predstavlja putniku.', ctaText: 'Pokažite nam kako upiti danas stižu, gde se čuvaju ponude i kako prodajni savetnici nastavljaju komunikaciju. Predložićemo prvi tok koji obrađuje više upita bez dodatnog ručnog rada.', ctaButton: 'Zakažite konsultaciju'
    }
  : {
      metaTitle: 'AI for travel agencies: sales automation',
      metaDescription: 'RoutineForge builds AI chatbots for travel agencies, pre-trip reminders, follow-up, and traveller reactivation across web, Instagram, and WhatsApp.',
      canonical: `${SITE_URL}/ai-for-travel-agencies/`, enUrl: `${SITE_URL}/ai-for-travel-agencies/`, srUrl: `${SITE_URL}/sr/ai-za-turisticke-agencije/`,
      eyebrow: 'INDUSTRIES · TRAVEL AGENCIES', title: 'Travellers message several agencies. The first useful reply wins the booking.',
      intro: 'We build an AI sales assistant that answers questions about dates, prices, and conditions in seconds across your website, Instagram, and WhatsApp, qualifies travellers, sends pre-trip messages, and reactivates your past-season database.',
      primaryCta: 'Book a free consultation', secondaryCta: 'See the system',
      proof: [{ value: '24/7', label: 'answers about packages' }, { value: '3 channels', label: 'one package database' }, { value: '1 second', label: 'to the first relevant reply' }],
      visualLabel: 'PACKAGE ENQUIRY · ILLUSTRATIVE EXAMPLE', traveller: 'Traveller', assistant: 'RoutineForge Travel AI',
      messages: ['Do you have Crete in early July for two people?', 'Yes — departures are available on 3 and 10 July. Would you prefer 7 or 10 nights?', '7 nights, with a total budget up to €1,500.'],
      visualStates: ['Destination: Crete', '2 travellers · 7 nights', 'Budget: up to €1,500'], visualOutcome: 'Enquiry ready for a sales agent',
      painEyebrow: 'WHERE AGENCIES LOSE TRAVELLERS', painTitle: 'The offer is rarely the problem. Reply speed and a forgotten database are.', painIntro: 'During peak season, sales disappear while the team retypes a price list, answers the same question for the fifth time, or finds an enquiry tomorrow after the traveller has already paid a competitor.',
      pains: [
        { number: '01', title: 'The same enquiry goes to five addresses', text: 'The enquiry reaching you reaches competitors in the same minute. A reply hours later often reaches someone who has already booked elsewhere.' },
        { number: '02', title: 'The team repeats answers instead of selling', text: 'Availability, inclusions, deposit, hotel, and departure details already exist in the price list, yet a salesperson types them again instead of closing.' },
        { number: '03', title: 'The past-traveller database sits unused', text: 'Travellers who already know you are easier to win again, but without segmentation and systematic contact, the agency’s most valuable database remains dormant.' },
        { number: '04', title: 'Group notifications depend on manual work', text: 'Messages about payments, documents, departures, and changes go out by hand, so someone remains uninformed or the team cannot confirm delivery.' }
      ],
      buildEyebrow: 'WHAT WE BUILD FOR TRAVEL AGENCIES', buildTitle: 'AI learns from your packages and price lists — and answers like a prepared salesperson.', buildIntro: 'The system is shaped around your destinations, groups, channels, sales rules, and existing tools.',
      builds: [
        { icon: 'chat', title: 'An AI chatbot that sells packages', text: 'Across web, Instagram, and WhatsApp, it answers about dates, prices, and conditions, asks the right questions, and hands a prepared enquiry to an agent.', outcome: 'The agent receives context and focuses on closing.' },
        { icon: 'workflow', title: 'Pre-trip reminders', text: 'WhatsApp messages about payments, documents, departures, and changes follow each group calendar and delivery status.', outcome: 'Travellers receive timely, richer messages than a basic SMS.' },
        { icon: 'custom', title: 'Past-traveller reactivation', text: 'The database is segmented by destination, travel type, and profile: new Greece dates for previous Greece travellers, family packages for families.', outcome: 'New sales begin with people who already trust you.' },
        { icon: 'workflow', title: 'Follow-up that protects warm enquiries', text: 'A traveller who asked but did not book receives a relevant message while interest is still alive.', outcome: 'A warm enquiry does not go cold in an inbox.' },
        { icon: 'phone', title: 'Optional AI phone agent', text: 'It can answer routine calls, capture destination, dates, party size, and budget, then hand the call or callback task to a salesperson.', outcome: 'The phone becomes another structured entry into the same sales workflow.' }
      ],
      speedEyebrow: 'REPLY SPEED · SELLING TRAVEL', speedTitle: 'The first useful reply turns intent into a conversation while it is still strong.', speedText: 'AI handles many conversations at once, qualifies each enquiry immediately, and alerts a salesperson. Peak season no longer has to mean missed messages.',
      speedBenefits: ['Every enquiry captures destination, dates, number of travellers, and budget', 'The reply uses current information from the same package database', 'The agent takes over a prepared conversation instead of asking everything again'],
      benchmarks: [{ value: '78%', label: 'of buyers choose the provider that responds first', source: 'commonly cited lead-response benchmark' }, { value: '21×', label: 'higher qualification likelihood when replying within 5 minutes rather than 30', source: 'MIT / InsideSales benchmark' }, { value: '−80%', label: 'stated drop in sales likelihood when reply takes 10 rather than 5 minutes', source: 'lead-response benchmark on the reference page' }],
      benchmarkNote: 'External benchmark figures illustrate why speed matters; they are not a RoutineForge performance guarantee. For your agency, we measure the baseline, response time, and conversion before and after implementation.',
      dataEyebrow: 'ONE PACKAGE DATABASE', dataTitle: 'Price and availability change. The answer must change with them.', dataText: 'AI connects to approved price lists and spreadsheets or to a booking system when suitable access exists. When the source changes, the next answer uses the updated information.',
      dataFlow: [{ label: 'Sources', text: 'Price lists, spreadsheets, booking system' }, { label: 'AI layer', text: 'Package retrieval and approved answers' }, { label: 'Qualification', text: 'Destination, dates, travellers, budget' }, { label: 'Agent', text: 'Prepared enquiry with full context' }],
      unknownTitle: 'What if the AI does not know?', unknownText: 'It does not guess. It hands the conversation to an agent with everything collected so far, allowing the salesperson to continue where AI stopped.',
      remindersEyebrow: 'FROM PAYMENT TO DEPARTURE', remindersTitle: 'Every group receives the right message at the right time.', remindersText: 'Automation follows the group calendar and traveller status, while your team retains visibility and can edit or take over manually.',
      reminderSteps: [{ time: 'After booking', title: 'Confirmation and deposit', text: 'Package summary, deadline, and payment instructions.' }, { time: 'Before the deadline', title: 'Documents and balance', text: 'A personalized reminder only for travellers who need it.' }, { time: 'Before departure', title: 'Time and meeting point', text: 'All key details in one WhatsApp message.' }, { time: 'When plans change', title: 'Update the whole group', text: 'Fast messaging with visible delivery status.' }],
      reactivationEyebrow: 'REACTIVATION AND FOLLOW-UP', reactivationTitle: 'The cheapest new sale often starts with a traveller who already knows you.', reactivationText: 'Instead of one message to everyone, segments receive relevant offers, and every reply enters a sales workflow with an owner and next step.',
      segments: [{ label: 'Greece last season', offer: 'New Crete and Rhodes dates' }, { label: 'Families with children', offer: 'Family hotels and flexible departures' }, { label: 'Winter travellers', offer: 'Early selection of ski packages' }, { label: 'Asked, did not book', offer: 'Follow-up while interest is alive' }],
      channelsEyebrow: 'THREE CHANNELS · ONE SALES WORKFLOW', channelsTitle: 'Website, Instagram, and WhatsApp use the same data and CRM.', channelsText: 'A conversation does not remain in a lost inbox. AI records the source, interest, qualification, enquiry owner, and next action. A person can take over at any point.',
      channels: ['Website chat', 'Instagram DM', 'WhatsApp Business', 'CRM / Google Sheets', 'Booking system / API', 'Email and internal alerts'],
      processEyebrow: 'FROM ENQUIRY TO THE FIRST SYSTEM', processTitle: 'Start with one channel, then expand what proves itself.', process: [{ phase: '01', title: 'Sales-flow discovery', text: 'We map enquiry sources, packages, price lists, qualification, agent handoff, and group notifications.' }, { phase: '02', title: 'Knowledge and rules', text: 'We define approved sources, answers, languages, scenarios, human handoff, and success metrics.' }, { phase: '03', title: 'Build and testing', text: 'We connect the first channel and test real packages, price changes, unavailability, unclear enquiries, and peak-season load.' }, { phase: '04', title: 'Launch and expansion', text: 'We start with web or Instagram, measure the result, then add WhatsApp, reminders, and reactivation.' }],
      faqEyebrow: 'FREQUENTLY ASKED QUESTIONS', faqTitle: 'What travel agencies want to know.',
      faqs: [
        { q: 'How does AI know prices and availability?', a: 'It connects to approved price lists and spreadsheets or to a booking system when an integration exists. When the source changes, the system uses the updated information.' },
        { q: 'What if a traveller asks something AI does not know?', a: 'AI does not guess. It hands the conversation to an agent with destination, dates, party size, budget, and full context, so the salesperson does not start from scratch.' },
        { q: 'Does it work during peak season?', a: 'That is when it provides the most value: the system handles many conversations in parallel while your team sees priorities and takes over sales-ready enquiries.' },
        { q: 'Can we start with one channel only?', a: 'Yes. Agencies often begin with web or Instagram, then add WhatsApp, reminders, and other workflows once the first channel proves its value.' },
        { q: 'Does it work with international travellers?', a: 'Yes. The system can converse in English, Serbian, and other languages using the same package database and business rules.' },
        { q: 'How much does an AI system for a travel agency cost?', a: 'It depends on channels, data sources, languages, and scenarios. A package-enquiry chatbot is a smaller investment than a connected system with reminders, CRM, and reactivation; after consultation, you receive a phased proposal.' }
      ],
      ctaTitle: 'You build the packages. AI presents them first.', ctaText: 'Show us how enquiries arrive, where offers live, and how agents follow up. We will recommend the first workflow that captures more demand without adding manual work.', ctaButton: 'Book a consultation'
    };

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: isSr ? 'AI sistemi za turističke agencije' : 'AI systems for travel agencies',
  serviceType: 'Travel agency sales automation',
  provider: { '@type': 'Organization', name: 'RoutineForge', url: `${SITE_URL}/` },
  areaServed: 'Global', description: content.metaDescription,
  availableChannel: { '@type': 'ServiceChannel', serviceUrl: content.canonical, availableLanguage: ['English', 'Serbian'] }
};
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} canonical={content.canonical} enUrl={content.enUrl} srUrl={content.srUrl} lang={isSr ? 'sr' : 'en'}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <div class="min-h-screen overflow-x-hidden bg-slate-50">
    <Navbar />
    <main class="deferred-sections">
      <section class="flow-grid-bg relative overflow-hidden border-b border-slate-200/80">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_82%_20%,rgba(14,165,233,0.16),transparent_32%),radial-gradient(circle_at_12%_70%,rgba(34,211,238,0.12),transparent_28%)]"></div>
        <div class="relative mx-auto grid max-w-7xl gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:px-8 lg:py-24">
          <div data-reveal><p class="inline-flex items-center gap-2 rounded-full border border-sky-200 bg-white/80 px-3 py-1 text-sm font-semibold text-sky-700"><IndustryIcon icon="travel" />{content.eyebrow}</p><h1 class="mt-6 max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">{content.title}</h1><p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">{content.intro}</p><div class="mt-8 flex flex-wrap gap-3"><a href={contactHref} class="inline-flex items-center gap-2 rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-200 transition hover:bg-cyan-500">{content.primaryCta}<span>→</span></a><a href="#travel-system" class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-sky-300 hover:text-sky-700">{content.secondaryCta}<span>↓</span></a></div><div class="mt-10 grid gap-3 sm:grid-cols-3">{content.proof.map((item) => <div class="rounded-2xl border border-white bg-white/75 p-4 shadow-sm backdrop-blur"><p class="font-semibold text-slate-950">{item.value}</p><p class="mt-1 text-xs leading-5 text-slate-500">{item.label}</p></div>)}</div></div>
          <div data-reveal class="rounded-[2rem] border border-sky-300/30 bg-slate-950 p-5 text-white shadow-[0_30px_80px_-28px_rgba(2,132,199,0.6)] sm:p-7"><div class="flex items-center justify-between border-b border-white/10 pb-5"><div><p class="text-xs font-semibold tracking-[0.18em] text-sky-300">{content.visualLabel}</p><p class="mt-2 text-sm text-slate-400">Website · Instagram · WhatsApp</p></div><span class="rounded-2xl border border-sky-400/20 bg-sky-400/10 p-3 text-sky-300"><IndustryIcon icon="travel" /></span></div><div class="mt-6 space-y-3"><div class="flex items-center gap-3"><span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-sky-500 text-xs font-bold">T</span><span class="text-sm font-semibold text-slate-200">{content.traveller}</span></div>{content.messages.map((message, index) => <div class:list={["max-w-[90%] rounded-2xl px-4 py-3 text-sm leading-6", index === 1 ? 'ml-auto bg-sky-500 text-white' : 'border border-white/10 bg-white/5 text-slate-200']}>{message}</div>)}</div><div class="mt-5 flex flex-wrap gap-2">{content.visualStates.map((state) => <span class="rounded-full border border-sky-400/20 bg-sky-400/10 px-3 py-1.5 text-xs font-semibold text-sky-200">{state}</span>)}</div><div class="mt-5 flex items-center gap-3 rounded-2xl border border-emerald-400/20 bg-emerald-400/10 p-4 text-sm font-semibold text-emerald-300"><span class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-emerald-400">✓</span>{content.visualOutcome}</div></div>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.painEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.painTitle}</h2><p class="mt-5 text-lg leading-8 text-slate-600">{content.painIntro}</p></div><div class="mt-10 grid gap-5 md:grid-cols-2">{content.pains.map((item, index) => <article data-reveal style={`--reveal-delay:${(index % 2) * 90}ms`} class="rounded-3xl border border-slate-200 bg-white/90 p-7 shadow-sm"><span class="text-xs font-semibold tracking-[0.18em] text-sky-700">{item.number}</span><h3 class="mt-4 text-xl font-semibold text-slate-950">{item.title}</h3><p class="mt-3 leading-7 text-slate-600">{item.text}</p></article>)}</div></section>

      <section id="travel-system" class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.buildEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">{content.buildTitle}</h2><p class="mt-5 text-lg leading-8 text-slate-300">{content.buildIntro}</p></div><div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">{content.builds.map((item, index) => <article data-reveal style={`--reveal-delay:${(index % 3) * 80}ms`} class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-7"><span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-sky-400/20 bg-sky-400/10 text-sky-300"><ServiceIcon icon={item.icon} /></span><h3 class="mt-5 text-xl font-semibold">{item.title}</h3><p class="mt-3 flex-1 leading-7 text-slate-300">{item.text}</p><p class="mt-5 border-t border-white/10 pt-4 text-sm font-semibold text-sky-200">{item.outcome}</p></article>)}</div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.speedEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.speedTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.speedText}</p><ul class="mt-6 space-y-3">{content.speedBenefits.map((item) => <li class="flex items-start gap-3 text-sm leading-6 text-slate-700"><span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">✓</span>{item}</li>)}</ul></div><div data-reveal class="grid gap-3 sm:grid-cols-3">{content.benchmarks.map((item) => <article class="rounded-3xl border border-sky-200 bg-gradient-to-br from-white to-sky-50 p-6 shadow-sm"><p class="text-3xl font-semibold tracking-tight text-sky-700">{item.value}</p><p class="mt-3 text-sm font-semibold leading-6 text-slate-800">{item.label}</p><p class="mt-4 border-t border-sky-100 pt-3 text-[11px] leading-5 text-slate-500">{item.source}</p></article>)}</div></div><p class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-xs leading-6 text-amber-900">{content.benchmarkNote}</p></section>

      <section class="border-y border-slate-200 bg-white/70 py-20"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.dataEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.dataTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.dataText}</p></div><div class="mt-10 grid gap-3 md:grid-cols-4">{content.dataFlow.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 70}ms`} class="relative rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><p class="text-xs font-semibold text-sky-700">0{index + 1} · {item.label}</p><p class="mt-4 text-sm leading-7 text-slate-600">{item.text}</p>{index < content.dataFlow.length - 1 && <span class="absolute -right-3 top-1/2 z-10 hidden h-6 w-6 -translate-y-1/2 items-center justify-center rounded-full bg-sky-500 text-xs text-white md:inline-flex">→</span>}</article>)}</div><div data-reveal class="mt-6 rounded-3xl border border-sky-200 bg-sky-50 p-6"><h3 class="font-semibold text-slate-950">{content.unknownTitle}</h3><p class="mt-3 text-sm leading-7 text-slate-600">{content.unknownText}</p></div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.remindersEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.remindersTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.remindersText}</p></div><div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">{content.reminderSteps.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 80}ms`} class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm"><p class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-700">{item.time}</p><h3 class="mt-4 font-semibold text-slate-950">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p></article>)}</div></section>

      <section class="bg-gradient-to-br from-sky-50 via-white to-cyan-50 py-20"><div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-center lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-white px-3 py-1 text-sm font-semibold text-sky-700">{content.reactivationEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.reactivationTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.reactivationText}</p></div><div data-reveal class="rounded-[2rem] border border-sky-200 bg-white/90 p-6 shadow-xl shadow-sky-100"><div class="grid gap-3 sm:grid-cols-2">{content.segments.map((item) => <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5"><p class="text-xs font-semibold uppercase tracking-[0.14em] text-sky-700">{item.label}</p><p class="mt-3 font-semibold text-slate-950">{item.offer}</p><p class="mt-3 text-xs font-semibold text-emerald-700">✓ {isSr ? 'Grupa spremna' : 'Segment ready'}</p></article>)}</div></div></div></section>

      <section class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.channelsEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">{content.channelsTitle}</h2><p class="mt-5 leading-8 text-slate-300">{content.channelsText}</p></div><div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">{content.channels.map((item) => <div data-reveal class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm font-semibold text-slate-200"><span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-sky-400/10 text-sky-300">✓</span>{item}</div>)}</div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.processEyebrow}</p><h2 class="mt-5 max-w-3xl text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.processTitle}</h2></div><div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">{content.process.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 80}ms`} class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm"><p class="text-xs font-semibold tracking-[0.17em] text-sky-700">{item.phase}</p><h3 class="mt-5 text-lg font-semibold text-slate-950">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p></article>)}</div></section>

      <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="text-center"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.faqEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.faqTitle}</h2></div><div class="mt-10 space-y-3">{content.faqs.map((item) => <details data-reveal class="group rounded-2xl border border-slate-200 bg-white/90 p-5 shadow-sm"><summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-slate-950"><span>{item.q}</span><span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-sky-50 text-sky-700 transition group-open:rotate-45">+</span></summary><p class="mt-4 max-w-3xl border-t border-slate-100 pt-4 leading-7 text-slate-600">{item.a}</p></details>)}</div></section>

      <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8"><div data-reveal class="relative overflow-hidden rounded-[2rem] border border-sky-400/20 bg-slate-950 p-8 text-center text-white shadow-[0_30px_90px_-25px_rgba(15,23,42,0.6)] sm:p-12"><div class="absolute left-1/2 top-0 h-64 w-64 -translate-x-1/2 rounded-full bg-sky-400/15 blur-3xl"></div><div class="relative"><h2 class="mx-auto max-w-4xl text-3xl font-semibold tracking-tight sm:text-4xl">{content.ctaTitle}</h2><p class="mx-auto mt-5 max-w-2xl leading-8 text-slate-300">{content.ctaText}</p><a href={contactHref} class="mt-8 inline-flex items-center gap-2 rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-950/30 transition hover:bg-cyan-400">{content.ctaButton}<span>→</span></a></div></div></section>
      <ContextualLinks />
    </main>
    <Footer />
  </div>
</BaseLayout>
