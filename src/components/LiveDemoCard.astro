---
import LogoMark from './LogoMark.astro';
const {
  eyebrow = 'Live workflow',
  title = 'Customer -> AI Agent -> CRM',
  badge = '24/7 active',
  messages = [
    { sender: 'customer', text: 'Book a consultation for Friday.' },
    { sender: 'ai', text: 'I have a few slots open — what time works best?' },
    { sender: 'customer', text: '2 PM works great.' },
    { sender: 'ai', text: 'Perfect, you are booked for Friday at 2 PM.' }
  ],
  statusLabel = 'System update',
  statusItems = ['CRM updated', 'Calendar booked', 'Email sent'],
  customerLabel = 'Customer'
} = Astro.props;
---

<div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-950 text-white shadow-2xl shadow-sky-900/10">
  <div class="flex items-center justify-between border-b border-slate-800 bg-slate-900/50 px-5 py-3.5">
    <div class="flex items-center gap-2.5">
      <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span></span>
      <div><p class="text-xs font-semibold uppercase tracking-wide text-slate-300">{eyebrow}</p><h2 class="sr-only">{title}</h2></div>
    </div>
    <div class="flex gap-1.5"><span class="sr-only">{badge}</span><span aria-hidden="true" class="h-2 w-2 rounded-full bg-slate-700"></span><span aria-hidden="true" class="h-2 w-2 rounded-full bg-slate-700"></span><span aria-hidden="true" class="h-2 w-2 rounded-full bg-slate-700"></span></div>
  </div>

  <div class="space-y-4 bg-slate-950 px-5 py-4" data-demo-root>
    {messages.map((message, index) => (
      <div data-demo-message data-message-index={index} class="flex items-start gap-2.5 transition-all duration-500">
        {message.sender === 'ai' ? (
          <span class="flex h-7 w-7 shrink-0 items-center justify-center overflow-hidden rounded-full bg-slate-900 ring-1 ring-sky-400/30">
            <LogoMark class="h-6 w-6" id={`demo-${index}`} />
          </span>
        ) : (
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-slate-700 text-slate-300">
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current" stroke-width="2"><circle cx="12" cy="8" r="3.2" /><path d="M5 20c0-3.6 3.1-6.4 7-6.4s7 2.8 7 6.4" stroke-linecap="round" /></svg>
          </span>
        )}
        <div class="min-w-0 rounded-xl border border-slate-700/40 bg-slate-800/60 px-3.5 py-2.5 text-xs leading-relaxed text-slate-200">
          <p class="mb-1 text-[10px] font-semibold uppercase tracking-wide text-slate-500">{message.sender === 'ai' ? 'RoutineForge AI' : customerLabel}</p>
          <p>{message.text}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="flex flex-wrap gap-2 border-t border-slate-800 bg-slate-900 px-5 py-3" data-demo-statuses>
    <span class="sr-only">{statusLabel}</span>
    {statusItems.map((item, index) => (
      <span data-demo-status data-status-index={index} class="inline-flex items-center gap-1.5 rounded-full border border-slate-700/50 bg-slate-800/60 px-2.5 py-1 text-xs font-medium text-slate-500 transition-all duration-300">
        <span data-demo-status-icon class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-slate-600 bg-slate-800 text-transparent transition-all duration-300"><svg viewBox="0 0 20 20" class="h-2.5 w-2.5 fill-none stroke-current" stroke-width="2.5"><path d="m4 10 4 4 8-8" stroke-linecap="round" stroke-linejoin="round" /></svg></span>{item}
      </span>
    ))}
  </div>
</div>

<script>
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll('[data-demo-root]').forEach((root) => {
    const messages = Array.from(root.querySelectorAll('[data-demo-message]'));
    const statuses = Array.from(root.parentElement.querySelectorAll('[data-demo-status]'));
    let phase = reducedMotion ? messages.length + statuses.length : 1;

    const render = () => {
      messages.forEach((message, index) => {
        message.classList.toggle('opacity-0', index >= phase);
        message.classList.toggle('-translate-y-1', index >= phase);
      });
      statuses.forEach((status, index) => {
        const complete = index < Math.max(0, phase - messages.length + 1);
        const icon = status.querySelector('[data-demo-status-icon]');
        status.classList.toggle('border-emerald-900/50', complete);
        status.classList.toggle('bg-emerald-950/40', complete);
        status.classList.toggle('text-emerald-400', complete);
        status.classList.toggle('border-slate-700/50', !complete);
        status.classList.toggle('bg-slate-800/60', !complete);
        status.classList.toggle('text-slate-500', !complete);
        icon.classList.toggle('border-emerald-400/60', complete);
        icon.classList.toggle('bg-emerald-400/15', complete);
        icon.classList.toggle('text-emerald-400', complete);
        icon.classList.toggle('border-slate-600', !complete);
        icon.classList.toggle('bg-slate-800', !complete);
        icon.classList.toggle('text-transparent', !complete);
      });
    };

    render();
    if (!reducedMotion) {
      window.setInterval(() => {
        phase = phase >= messages.length + statuses.length ? 1 : phase + 1;
        render();
      }, 1100);
    }
  });
</script>
