---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import LogoMark from './LogoMark.astro';
import IndustryIcon from './IndustryIcon.astro';
import ServiceIcon from './ServiceIcon.astro';
import { SITE_URL } from '../config/site';

const { lang = 'en' } = Astro.props;
const isSr = lang === 'sr';
const contactHref = isSr ? '/sr/#contact' : '/#contact';

const content = isSr
  ? {
      metaTitle: 'AI za Instagram prodavnice i DM prodaju',
      metaDescription: 'RoutineForge automatizuje Instagram prodaju: AI odgovara u privatnim porukama, vodi izbor proizvoda, prikuplja porudžbine, ažurira CRM i nastavlja komunikaciju sa kupcem.',
      canonical: `${SITE_URL}/sr/ai-za-instagram-prodavnice/`, enUrl: `${SITE_URL}/ai-for-instagram-shops/`, srUrl: `${SITE_URL}/sr/ai-za-instagram-prodavnice/`,
      eyebrow: 'INDUSTRIJE · INSTAGRAM PRODAVNICE', title: 'Vi pravite sadržaj. AI vodi kupca do porudžbine u privatnim porukama.',
      intro: 'Instagram prodaja se odvija u porukama, a kupac odlazi onome ko prvi odgovori. Gradimo AI prodavca koji odgovara u sekundi, vodi izbor proizvoda, završava porudžbinu unutar razgovora i gradi bazu kupaca — u Vašem tonu, 24/7.',
      primaryCta: 'Zakažite besplatnu konsultaciju', secondaryCta: 'Pogledajte DM prodaju',
      proof: [{ value: '1 sekunda', label: 'do prvog odgovora u DM-u' }, { value: '24/7', label: 'od pitanja do potvrđene porudžbine' }, { value: 'Bez sajta', label: 'ceo tok može ostati u porukama' }],
      visualLabel: 'INSTAGRAM DM · ILUSTRATIVNI PRIMER', buyer: '@milica_style', assistant: 'RoutineForge AI',
      messages: ['Ćao, koja je cena bež kompleta i imate li M?', 'Ćao! Bež komplet je 6.490 RSD i M je dostupan. Da li želiš da proverimo mere ili odmah naručujemo? ✨', 'Naručujem. Plaćanje pouzećem.'],
      visualStates: ['Proizvod: bež komplet · M', 'Pouzeće', 'Adresa spremna za potvrdu'], visualOutcome: 'Porudžbina upisana · kupac čeka finalnu potvrdu',
      painEyebrow: 'ZAŠTO PRIJEMNO SANDUČE GUTA PRODAJU', painTitle: 'Instagram prodavnice retko gube kupca zbog cene. Gube ga zbog čekanja i haotičnih poruka.', painIntro: 'Kada je svaka poruka vezana za Vaš telefon, prodaja ne može da raste bez sve više ručnog odgovaranja, prepisivanja i rizika da nešto ostane samo na snimku ekrana.',
      pains: [
        { number: '01', title: 'Kupac piše uveče, odgovor stiže sutra', text: 'Pita za cenu dok skroluje i dobija odgovor kada je impuls već nestao ili je isti proizvod pronašao kod drugog prodavca.' },
        { number: '02', title: 'Ceo biznis zavisi od Vašeg telefona', text: 'Dan odmora, snimanje sadržaja ili gužva znače dan sporije prodaje jer svaka poruka prolazi kroz jednu osobu.' },
        { number: '03', title: 'Porudžbine ostaju u beleškama i snimcima ekrana', text: 'Adrese, dogovori i varijante proizvoda rasuti su kroz poruke, pa nastaju greške u slanju, zaboravljeni kupci i baza koja ne može da podrži ponovnu prodaju.' }
      ],
      buildEyebrow: 'ŠTA GRADIMO ZA IG BRENDOVE', buildTitle: 'Automatizacija trenirana na stvarnim razgovorima, tonu i načinu prodaje Vašeg brenda.', buildIntro: 'AI ne dobija samo katalog. Uči rečnik, stil, tipična pitanja, pravila poručivanja, kada da ponudi proizvod i kada da prepusti razgovor čoveku.',
      builds: [
        { icon: 'chat', title: 'AI prodavac u privatnim porukama', text: 'Odgovara o ceni, veličinama, varijantama i dostavi, vodi kupca kroz izbor i prikuplja podatke za porudžbinu.', outcome: 'Kupac dobija brz odgovor bez čekanja da budete dostupni.' },
        { icon: 'workflow', title: 'Automatski odgovori na priče i komentare', text: 'Reakcija na priču, komentar ili dogovorena ključna reč automatski otvaraju odgovarajući prodajni razgovor.', outcome: 'Svaka objava postaje ulaz u prodaju, a ne samo izvor lajkova.' },
        { icon: 'custom', title: 'Automatski upis porudžbine', text: 'Artikal, varijanta, telefon, adresa, napomena i potvrda odmah ulaze u tabelu ili CRM.', outcome: 'Kurirska lista se izvozi bez ručnog prepisivanja i grešaka.' },
        { icon: 'workflow', title: 'Dalja komunikacija i ponovna prodaja', text: 'Kupac koji je pitao, ali nije kupio, dobija relevantan podsetnik, a prethodni kupci obaveštenje kada stigne nova kolekcija.', outcome: 'Baza kupaca konačno radi umesto da ostane zakopana u prijemnom sandučetu.' }
      ],
      dmEyebrow: 'INSTAGRAM PRODAJA · OD PRVOG PITANJA DO PORUDŽBINE', dmTitle: 'Ceo prodajni tok može da se završi u porukama.', dmText: 'AI vodi neograničen broj paralelnih razgovora, koristi Vaše informacije o proizvodima i dostavi, prikuplja podatke i potvrđuje naredni korak. Sajt nije obavezan, ali se isti sistem može povezati sa njim.',
      dmSteps: [{ phase: '01', title: 'Pitanje ili reakcija', text: 'Privatna poruka, odgovor na priču, komentar ili ključna reč pokreću odgovarajući scenario.' }, { phase: '02', title: 'Izbor proizvoda', text: 'Cena, varijanta, veličina, mere, dostupnost i relevantna preporuka.' }, { phase: '03', title: 'Podaci za porudžbinu', text: 'Ime, telefon, adresa, način plaćanja i napomena kroz prirodan razgovor.' }, { phase: '04', title: 'Potvrda i CRM', text: 'Kupac potvrđuje podatke, a porudžbina dobija status i ulazi u operativni tok.' }],
      triggerEyebrow: 'SADRŽAJ KOJI OTVARA RAZGOVOR', triggerTitle: 'Priča, komentar i ključna reč postaju merljivi prodajni ulazi.', triggerText: 'Svaki pokretač može da otvori drugačiji scenario: pošalji cenu, proveri veličinu, prikaži novu kolekciju ili prikupi interesovanje pre puštanja kolekcije.',
      triggers: [{ action: 'Reakcija na priču 🔥', reply: 'Otvara detalje proizvoda iz priče' }, { action: 'Komentar „CENA”', reply: 'Šalje cenu i dostupne varijante u privatnu poruku' }, { action: 'Ključna reč „NOVA”', reply: 'Pokazuje novu kolekciju i vodi izbor' }, { action: 'Klik sa oglasa', reply: 'Nastavlja razgovor uz kontekst kampanje' }],
      orderEyebrow: 'PORUDŽBINA BEZ PREPISIVANJA', orderTitle: 'Od razgovora do kurirske liste kroz jedan strukturiran zapis.', orderText: 'AI proverava obavezna polja, vraća sažetak kupcu na potvrdu i tek tada upisuje porudžbinu. Plaćanje pouzećem beleži se kao status, a za kartično plaćanje može da se koristi bezbedan link za plaćanje.',
      orderFields: [{ label: 'Kupac', value: 'Milica Jovanović' }, { label: 'Artikal', value: 'Bež komplet · M' }, { label: 'Plaćanje', value: 'Pouzeće' }, { label: 'Dostava', value: 'Novi Sad · potvrđeno' }],
      orderStates: ['Porudžbina #IG-1048', 'Spremno za kurira', 'CRM kontakt ažuriran'],
      followupEyebrow: 'DALJA KOMUNIKACIJA I PONOVNA PRODAJA', followupTitle: 'Interesovanje kratko traje. Baza kupaca ima dugoročnu vrednost.', followupText: 'Sistem razlikuje kupca koji još bira, napušten razgovor, prethodnog kupca i VIP grupu. Poruka mora biti relevantna, dozvoljena i poslata u trenutku koji podržava prodaju bez neželjenih poruka.',
      followups: [{ when: '30–60 min', segment: 'Pitao za veličinu', message: 'Da li želiš da proverimo mere pre porudžbine?' }, { when: 'Sledeći dan', segment: 'Nije potvrdio adresu', message: 'Porudžbina je sačuvana — treba još samo potvrda podataka.' }, { when: 'Nova kolekcija', segment: 'Prethodni kupci', message: 'Stigli su novi modeli slični prethodnoj kupovini.' }, { when: 'Ponovna dostupnost', segment: 'Lista čekanja', message: 'Tražena veličina je ponovo dostupna.' }],
      voiceEyebrow: 'VAŠ TON · LJUDSKA KONTROLA', voiceTitle: 'Kupac prepoznaje stil brenda, a Vi možete da se uključite u svakom trenutku.', voiceText: 'Sistem se podešava na osnovu stvarnih razgovora, odobrenog rečnika, načina obraćanja i načina korišćenja emodžija. Jasna pravila određuju šta AI sme da obeća i kada razgovor mora da preuzme čovek.',
      voiceCards: [{ title: 'Rečnik i stil', text: 'Fraze, nivo formalnosti, dužina odgovora i način preporučivanja.' }, { title: 'Način korišćenja emodžija', text: 'Koriste se samo ako pripadaju autentičnom načinu komunikacije brenda.' }, { title: 'Preuzimanje razgovora', text: 'Vlasnik ili prodavac preuzima reklamacije, složene zahteve i posebne dogovore.' }, { title: 'Vidljiv kontekst', text: 'Čovek vidi ceo razgovor, podatke i predloženi sledeći korak.' }],
      channelsEyebrow: 'ZVANIČNE INTEGRACIJE', channelsTitle: 'Automatizacija koja poštuje pravila platforme i čuva nalog.', channelsText: 'Automatizacija privatnih poruka na Instagramu koristi zvanični Meta API za odgovarajuće poslovne naloge. Ne koristimo nezvanične alate koji oponašaju korisnika. Mogućnosti zavise od tipa naloga, dozvola, pravila API-ja i odobrenih scenarija slanja poruka.',
      channels: [{ title: 'Privatne poruke na Instagramu', text: 'Osnovni prodajni kanal, uz odgovore na priče i komentare.' }, { title: 'Chat na sajtu', text: 'Ista baza znanja i isti podaci o proizvodima.' }, { title: 'WhatsApp Business', text: 'Povezani razgovori, potvrde i dozvoljena dalja komunikacija.' }, { title: 'Viber Business', text: 'Moguće proširenje kada su nalog, provajder i tržišna pravila podržani.' }, { title: 'CRM / Google Sheets', text: 'Kupci, razgovori, porudžbine i statusi na jednom mestu.' }, { title: 'Plaćanje i dostava', text: 'Linkovi za plaćanje, kurirski izvoz i operativna obaveštenja.' }],
      benchmarkEyebrow: 'BRZINA PRODAJE KROZ PORUKE', benchmarkTitle: 'Kupac u privatnim porukama ne čeka kao kupac koji šalje e-mail.', benchmarks: [{ value: '78%', label: 'kupaca bira prodavca koji prvi odgovori', source: 'istraživanje brzine odgovora navedeno na izvornoj stranici' }, { value: '21×', label: 'veća šansa kvalifikacije uz odgovor u prvih 5 minuta', source: 'HBR / MIT istraživanje navedeno na izvornoj stranici' }, { value: '1 mlrd.', label: 'ljudi nedeljno piše kompanijama kroz Meta aplikacije', source: 'Meta podatak naveden na izvornoj stranici' }],
      benchmarkNote: 'Spoljni podaci ilustruju značaj brzine i obim prodaje kroz poruke; nisu garancija RoutineForge prodajnog rezultata. Za brend merimo vreme odgovora, završene porudžbine, greške i ponovnu kupovinu pre i posle uvođenja sistema.',
      processEyebrow: 'OD PRIJEMNOG SANDUČETA DO SISTEMA', processTitle: 'Počinjemo od stvarnih razgovora i pravila prodaje.', process: [{ phase: '01', title: 'Snimak prodaje kroz poruke', text: 'Mapiramo pitanja, proizvode, varijante, način poručivanja, dostavu, plaćanje, dalju komunikaciju i trenutke kada razgovor preuzima čovek.' }, { phase: '02', title: 'Baza i ton brenda', text: 'Uređujemo katalog, dostupnost, pravila, primere razgovora, rečnik i zabranjene tvrdnje.' }, { phase: '03', title: 'Povezivanje i testiranje', text: 'Povezujemo Meta API, CRM ili tabelu i testiramo pokretače, porudžbinu, duplikate, nejasne adrese i reklamacije.' }, { phase: '04', title: 'Kontrolisano puštanje u rad', text: 'Krećemo sa jasnim scenarijima, pratimo razgovore i širimo dalju komunikaciju i kampanje tek kada osnovna prodaja radi pouzdano.' }],
      faqEyebrow: 'ČESTA PITANJA', faqTitle: 'Šta Instagram prodavci žele da znaju.',
      faqs: [
        { q: 'Da li Instagram dozvoljava automatizaciju privatnih poruka?', a: 'Da, kroz zvanični Meta API za odgovarajuće poslovne naloge i dozvoljene scenarije. Ne koristimo nezvanične alate koji ugrožavaju nalog; tačne mogućnosti proveravamo prema važećim Meta pravilima.' },
        { q: 'Da li će kupci primetiti da ne kucam ja?', a: 'AI se prilagođava odobrenom rečniku, tonu i načinu prodaje iz stvarnih razgovora. Ipak, iskustvo treba da bude transparentno tamo gde je potrebno, a Vi možete da preuzmete razgovor u svakom trenutku.' },
        { q: 'Kako radi plaćanje pouzećem?', a: 'AI prikuplja telefon, adresu, artikal i potvrdu porudžbine, a podatke upisuje u CRM ili tabelu spremnu za kurira. Za kartično plaćanje može da pošalje link podržanog sistema za plaćanje.' },
        { q: 'Imam i sajt. Mogu li da rade zajedno?', a: 'Da. Isti AI može da koristi jednu bazu proizvoda i pravila na sajtu, Instagramu i WhatsAppu, tako da kupac dobija dosledan odgovor, a podaci završavaju u istom sistemu.' },
        { q: 'Koliko košta automatizacija Instagram prodaje?', a: 'Zavisi od broja proizvoda, obima poruka, pokretača, načina poručivanja, integracija i scenarija dalje komunikacije. Osnovni AI prodavac u privatnim porukama manja je investicija od kompletnog sistema sa CRM-om i kampanjama.' },
        { q: 'Može li isti sistem da radi na WhatsAppu i Viberu?', a: 'Može da se proširi na podržane poslovne kanale. WhatsApp koristi zvanični Business API, dok Viber zavisi od poslovnog naloga, provajdera, tržišta i odobrenih pravila za slanje poruka.' }
      ],
      ctaTitle: 'Vi pravite sadržaj. AI vodi kupca do porudžbine.', ctaText: 'Pošaljite nam profil i pokažite kako danas izgleda poručivanje. Predložićemo kako da svaka privatna poruka dobije odgovor, porudžbina uredan zapis, a Vi zadržite kontrolu nad prodajom.', ctaButton: 'Zakažite konsultaciju'
    }
  : {
      metaTitle: 'AI for Instagram shops and DM sales',
      metaDescription: 'RoutineForge automates Instagram sales: AI replies in DMs, guides product choice, captures orders, updates CRM, and runs follow-up.',
      canonical: `${SITE_URL}/ai-for-instagram-shops/`, enUrl: `${SITE_URL}/ai-for-instagram-shops/`, srUrl: `${SITE_URL}/sr/ai-za-instagram-prodavnice/`,
      eyebrow: 'INDUSTRIES · INSTAGRAM SHOPS', title: 'You make the content. AI closes the sale inside DMs.',
      intro: 'Instagram sales happen in messages, and buyers go to whoever answers first. We build an AI salesperson that replies in seconds, guides product choice, completes the order inside the conversation, and grows a customer database — in your tone, 24/7.',
      primaryCta: 'Book a free consultation', secondaryCta: 'See DM selling',
      proof: [{ value: '1 second', label: 'to the first DM reply' }, { value: '24/7', label: 'from question to confirmed order' }, { value: 'No website required', label: 'the entire flow can remain in messages' }],
      visualLabel: 'INSTAGRAM DM · ILLUSTRATIVE EXAMPLE', buyer: '@milica_style', assistant: 'RoutineForge AI',
      messages: ['Hi, what is the price of the beige set, and is M available?', 'Hi! The beige set is €55 and M is available. Would you like the measurements or shall we order now? ✨', 'I will order. Cash on delivery.'],
      visualStates: ['Product: beige set · M', 'Cash on delivery', 'Address ready to confirm'], visualOutcome: 'Order recorded · awaiting final customer confirmation',
      painEyebrow: 'WHY THE INBOX SWALLOWS SALES', painTitle: 'Instagram shops rarely lose buyers on price. They lose them on waiting and messy messages.', painIntro: 'When every message depends on your phone, sales cannot grow without more manual replies, retyping, and the risk that an order remains inside a screenshot.',
      pains: [
        { number: '01', title: 'Buyers write in the evening, the reply comes tomorrow', text: 'They ask for a price while scrolling and receive an answer after the impulse has gone or the same product was found elsewhere.' },
        { number: '02', title: 'The whole business depends on your phone', text: 'A day off, a content shoot, or a busy period becomes a day of slower sales because every conversation goes through one person.' },
        { number: '03', title: 'Orders remain in notes and screenshots', text: 'Addresses, agreements, and product variants are scattered across messages, creating shipping mistakes, forgotten buyers, and no usable repeat-sales database.' }
      ],
      buildEyebrow: 'WHAT WE BUILD FOR IG BRANDS', buildTitle: 'Automation trained on the real conversations, tone, and selling style of your brand.', buildIntro: 'AI receives more than a catalog. It learns approved vocabulary, style, common questions, order rules, when to recommend, and when a person must take over.',
      builds: [
        { icon: 'chat', title: 'An AI salesperson inside DMs', text: 'It answers questions about price, sizes, variants, and delivery, guides selection, and captures order details.', outcome: 'Buyers receive an instant answer without waiting for you to be online.' },
        { icon: 'workflow', title: 'Story and comment triggers', text: 'A story reaction, comment, or agreed keyword automatically opens a relevant sales conversation.', outcome: 'Every post becomes a sales entry point, not just a source of likes.' },
        { icon: 'custom', title: 'Orders logged automatically', text: 'Product, variant, phone, address, note, and confirmation immediately enter a spreadsheet or CRM.', outcome: 'Courier lists export without retyping and mistakes.' },
        { icon: 'workflow', title: 'Follow-up and repeat sales', text: 'A buyer who asked but did not purchase receives a relevant reminder, while past buyers hear when a new collection arrives.', outcome: 'The customer database finally works instead of remaining buried in the inbox.' }
      ],
      dmEyebrow: 'INSTAGRAM SALES · FROM FIRST QUESTION TO ORDER', dmTitle: 'The entire sales flow can finish inside messages.', dmText: 'AI handles many conversations in parallel, uses your product and delivery information, captures details, and confirms the next step. A website is optional, but the same system can connect to it.',
      dmSteps: [{ phase: '01', title: 'Question or reaction', text: 'DM, story reply, comment, or keyword starts the appropriate scenario.' }, { phase: '02', title: 'Product selection', text: 'Price, variant, size, measurements, availability, and relevant recommendation.' }, { phase: '03', title: 'Order details', text: 'Name, phone, address, payment method, and note through a natural conversation.' }, { phase: '04', title: 'Confirmation and CRM', text: 'The buyer confirms the data, and the order receives a status and enters operations.' }],
      triggerEyebrow: 'CONTENT THAT OPENS A CONVERSATION', triggerTitle: 'Stories, comments, and keywords become measurable sales entry points.', triggerText: 'Each trigger can open a different scenario: send the price, check size, present a new collection, or collect interest before launch.',
      triggers: [{ action: 'Story reaction 🔥', reply: 'Opens details for the product shown in the story' }, { action: 'Comment “PRICE”', reply: 'Sends price and available variants in a DM' }, { action: 'Keyword “NEW”', reply: 'Shows the new collection and guides selection' }, { action: 'Ad click', reply: 'Continues with campaign context' }],
      orderEyebrow: 'ORDERS WITHOUT RETYPING', orderTitle: 'From conversation to courier list through one structured record.', orderText: 'AI checks required fields, returns a summary for customer confirmation, and only then logs the order. Cash on delivery becomes a status, while card payments can use a secure payment link.',
      orderFields: [{ label: 'Customer', value: 'Milica Jovanović' }, { label: 'Product', value: 'Beige set · M' }, { label: 'Payment', value: 'Cash on delivery' }, { label: 'Delivery', value: 'Novi Sad · confirmed' }],
      orderStates: ['Order #IG-1048', 'Ready for courier', 'CRM contact updated'],
      followupEyebrow: 'FOLLOW-UP AND REPEAT SALES', followupTitle: 'Interest has a short lifetime. A customer database has long-term value.', followupText: 'The system distinguishes a buyer still choosing, an abandoned conversation, a previous buyer, and a VIP segment. Messages must be relevant, permitted, and timed to support sales without spam.',
      followups: [{ when: '30–60 min', segment: 'Asked about size', message: 'Would you like us to check the measurements before ordering?' }, { when: 'Next day', segment: 'Address not confirmed', message: 'Your order is saved — only data confirmation remains.' }, { when: 'New collection', segment: 'Previous buyers', message: 'New styles similar to your previous purchase have arrived.' }, { when: 'Back in stock', segment: 'Waitlist', message: 'The requested size is available again.' }],
      voiceEyebrow: 'YOUR TONE · HUMAN CONTROL', voiceTitle: 'Buyers recognize the brand style, and you can step in at any moment.', voiceText: 'The system is configured from real conversations, approved vocabulary, address style, and emoji habits. Clear rules define what AI may promise and when a person must take over.',
      voiceCards: [{ title: 'Vocabulary and style', text: 'Phrases, formality, reply length, and recommendation style.' }, { title: 'Emoji habits', text: 'Used only when they belong to the authentic communication style of the brand.' }, { title: 'Human takeover', text: 'The owner or salesperson handles complaints, complex requests, and special arrangements.' }, { title: 'Visible context', text: 'A person sees the entire conversation, captured data, and proposed next step.' }],
      channelsEyebrow: 'OFFICIAL INTEGRATIONS', channelsTitle: 'Automation that follows platform rules and protects the account.', channelsText: 'Instagram DM automation uses the official Meta API for eligible business accounts. We do not use grey tools that impersonate users. Capabilities depend on account type, permissions, API rules, and approved messaging scenarios.',
      channels: [{ title: 'Instagram DM', text: 'Core sales channel with story and comment triggers.' }, { title: 'Website chat', text: 'The same knowledge base and product information.' }, { title: 'WhatsApp Business', text: 'Connected conversations, confirmations, and permitted follow-up.' }, { title: 'Viber Business', text: 'Possible extension when the account, provider, and market rules are supported.' }, { title: 'CRM / Google Sheets', text: 'Customers, conversations, orders, and statuses in one place.' }, { title: 'Payment and delivery', text: 'Payment links, courier exports, and operations alerts.' }],
      benchmarkEyebrow: 'SPEED IN MESSAGE COMMERCE', benchmarkTitle: 'A buyer inside DMs does not wait like a buyer in an email inbox.', benchmarks: [{ value: '78%', label: 'of buyers choose the seller who replies first', source: 'lead-response benchmark quoted by the reference page' }, { value: '21×', label: 'higher qualification likelihood with a reply in the first 5 minutes', source: 'HBR / MIT benchmark quoted by the reference page' }, { value: '1 bn', label: 'people message businesses weekly through Meta apps', source: 'Meta figure quoted by the reference page' }],
      benchmarkNote: 'External figures illustrate the importance of speed and the scale of message commerce; they are not a RoutineForge sales guarantee. For your brand, we measure reply time, completed orders, errors, and repeat purchase before and after implementation.',
      processEyebrow: 'FROM INBOX TO SYSTEM', processTitle: 'We begin with real conversations and selling rules.', process: [{ phase: '01', title: 'DM sales discovery', text: 'We map questions, products, variants, ordering, delivery, payment, follow-up, and human takeover moments.' }, { phase: '02', title: 'Knowledge and brand voice', text: 'We organize catalog, availability, rules, conversation examples, vocabulary, and prohibited claims.' }, { phase: '03', title: 'Integration and testing', text: 'We connect Meta API, CRM or spreadsheet and test triggers, orders, duplicates, unclear addresses, and complaints.' }, { phase: '04', title: 'Controlled launch', text: 'We start with clear scenarios, monitor conversations, and expand follow-up and campaigns once core sales work reliably.' }],
      faqEyebrow: 'FREQUENTLY ASKED QUESTIONS', faqTitle: 'What Instagram sellers want to know.',
      faqs: [
        { q: 'Does Instagram allow DM automation?', a: 'Yes, through the official Meta API for eligible business accounts and permitted scenarios. We do not use grey tools that risk the account; exact capabilities are checked against current Meta rules.' },
        { q: 'Will buyers notice it is not me typing?', a: 'AI adapts to approved vocabulary, tone, and selling style from real conversations. The experience should still be transparent where required, and you can take over at any moment.' },
        { q: 'How does cash on delivery work?', a: 'AI captures phone, address, product, and order confirmation, then logs the data in a CRM or spreadsheet ready for the courier. For card payments, it can send a supported payment link.' },
        { q: 'I also have a website. Can they work together?', a: 'Yes. The same AI can use one product database and rules across web, Instagram, and WhatsApp, while customer data reaches the same system.' },
        { q: 'How much does Instagram sales automation cost?', a: 'It depends on products, message volume, triggers, ordering flow, integrations, and follow-up scenarios. A basic DM salesperson is a smaller investment than a complete CRM and campaign system.' },
        { q: 'Can the same system work on WhatsApp and Viber?', a: 'It can extend to supported business channels. WhatsApp uses the official Business API, while Viber depends on the business account, provider, market, and approved messaging rules.' }
      ],
      ctaTitle: 'You make the content. AI closes the sale.', ctaText: 'Send us your profile and show us how ordering works today. We will recommend how every DM gets an answer, every order a clean record, and you retain control of sales.', ctaButton: 'Book a consultation'
    };

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: isSr ? 'AI automatizacija za Instagram prodavnice' : 'AI automation for Instagram shops',
  serviceType: 'Instagram DM sales automation',
  provider: { '@type': 'Organization', name: 'RoutineForge', url: `${SITE_URL}/` },
  areaServed: 'Global', description: content.metaDescription,
  availableChannel: { '@type': 'ServiceChannel', serviceUrl: content.canonical, availableLanguage: ['English', 'Serbian'] }
};
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} canonical={content.canonical} enUrl={content.enUrl} srUrl={content.srUrl} lang={isSr ? 'sr' : 'en'}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <div class="min-h-screen overflow-x-hidden bg-slate-50">
    <Navbar />
    <main class="deferred-sections">
      <section class="flow-grid-bg relative overflow-hidden border-b border-slate-200/80"><div class="absolute inset-0 bg-[radial-gradient(circle_at_82%_20%,rgba(14,165,233,0.16),transparent_32%),radial-gradient(circle_at_12%_70%,rgba(34,211,238,0.12),transparent_28%)]"></div><div class="relative mx-auto grid max-w-7xl gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:px-8 lg:py-24"><div data-reveal><p class="inline-flex items-center gap-2 rounded-full border border-sky-200 bg-white/80 px-3 py-1 text-sm font-semibold text-sky-700"><IndustryIcon icon="instagram" />{content.eyebrow}</p><h1 class="mt-6 max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">{content.title}</h1><p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">{content.intro}</p><div class="mt-8 flex flex-wrap gap-3"><a href={contactHref} class="inline-flex items-center gap-2 rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-200 transition hover:bg-cyan-500">{content.primaryCta}<span>→</span></a><a href="#instagram-system" class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-sky-300 hover:text-sky-700">{content.secondaryCta}<span>↓</span></a></div><div class="mt-10 grid gap-3 sm:grid-cols-3">{content.proof.map((item) => <div class="rounded-2xl border border-white bg-white/75 p-4 shadow-sm backdrop-blur"><p class="font-semibold text-slate-950">{item.value}</p><p class="mt-1 text-xs leading-5 text-slate-500">{item.label}</p></div>)}</div></div><div data-reveal class="mx-auto w-full max-w-md rounded-[2.2rem] border border-sky-300/30 bg-slate-950 p-3 text-white shadow-[0_30px_80px_-28px_rgba(2,132,199,0.6)]"><div class="rounded-[1.7rem] bg-white p-5 text-slate-950"><div class="flex items-center justify-between border-b border-slate-100 pb-4"><div class="flex items-center gap-3"><span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-fuchsia-500 via-rose-500 to-amber-400 text-white"><IndustryIcon icon="instagram" /></span><div><p class="font-semibold">{content.buyer}</p><p class="text-xs text-emerald-600">● Active now</p></div></div><span class="text-xs font-semibold text-slate-400">{content.visualLabel}</span></div><div class="mt-5 space-y-3">{content.messages.map((message, index) => <div class:list={["max-w-[88%] rounded-2xl px-4 py-3 text-sm leading-6", index === 1 ? 'ml-auto bg-sky-500 text-white' : 'bg-slate-100 text-slate-700']}>{message}</div>)}</div><div class="mt-5 flex flex-wrap gap-2">{content.visualStates.map((state) => <span class="rounded-full bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-700">{state}</span>)}</div><div class="mt-4 flex items-center gap-3 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-sm font-semibold text-emerald-800"><span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-emerald-100">✓</span>{content.visualOutcome}</div></div></div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.painEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.painTitle}</h2><p class="mt-5 text-lg leading-8 text-slate-600">{content.painIntro}</p></div><div class="mt-10 grid gap-5 md:grid-cols-3">{content.pains.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 80}ms`} class="rounded-3xl border border-slate-200 bg-white/90 p-7 shadow-sm"><span class="text-xs font-semibold tracking-[0.18em] text-sky-700">{item.number}</span><h3 class="mt-4 text-xl font-semibold text-slate-950">{item.title}</h3><p class="mt-3 leading-7 text-slate-600">{item.text}</p></article>)}</div></section>

      <section id="instagram-system" class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.buildEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">{content.buildTitle}</h2><p class="mt-5 text-lg leading-8 text-slate-300">{content.buildIntro}</p></div><div class="mt-10 grid gap-5 md:grid-cols-2">{content.builds.map((item, index) => <article data-reveal style={`--reveal-delay:${(index % 2) * 90}ms`} class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-7"><span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-sky-400/20 bg-sky-400/10 text-sky-300"><ServiceIcon icon={item.icon} /></span><h3 class="mt-5 text-xl font-semibold">{item.title}</h3><p class="mt-3 flex-1 leading-7 text-slate-300">{item.text}</p><p class="mt-5 border-t border-white/10 pt-4 text-sm font-semibold text-sky-200">{item.outcome}</p></article>)}</div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.dmEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.dmTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.dmText}</p></div><div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">{content.dmSteps.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 80}ms`} class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm"><p class="text-xs font-semibold tracking-[0.17em] text-sky-700">{item.phase}</p><h3 class="mt-5 font-semibold text-slate-950">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p></article>)}</div></section>

      <section class="border-y border-slate-200 bg-gradient-to-br from-fuchsia-50 via-white to-sky-50 py-20"><div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-center lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-fuchsia-200 bg-white px-3 py-1 text-sm font-semibold text-fuchsia-700">{content.triggerEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.triggerTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.triggerText}</p></div><div data-reveal class="grid gap-3 sm:grid-cols-2">{content.triggers.map((item) => <article class="rounded-3xl border border-white bg-white/90 p-5 shadow-sm"><p class="text-sm font-semibold text-fuchsia-700">{item.action}</p><p class="mt-3 text-sm leading-6 text-slate-600">→ {item.reply}</p></article>)}</div></div></section>

      <section class="mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-center lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.orderEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.orderTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.orderText}</p></div><div data-reveal class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-2xl"><div class="flex items-center justify-between border-b border-white/10 pb-4"><p class="font-semibold">RoutineForge · DM Orders</p><span class="rounded-full bg-emerald-400/10 px-3 py-1 text-xs font-semibold text-emerald-300">● Confirmed</span></div><div class="mt-5 grid gap-3 sm:grid-cols-2">{content.orderFields.map((item) => <article class="rounded-2xl border border-white/10 bg-white/5 p-4"><p class="text-xs font-semibold uppercase tracking-[0.14em] text-sky-300">{item.label}</p><p class="mt-2 font-semibold">{item.value}</p></article>)}</div><div class="mt-5 flex flex-wrap gap-2">{content.orderStates.map((state) => <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1.5 text-xs font-semibold text-emerald-300">✓ {state}</span>)}</div></div></section>

      <section class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.followupEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">{content.followupTitle}</h2><p class="mt-5 leading-8 text-slate-300">{content.followupText}</p></div><div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">{content.followups.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 70}ms`} class="rounded-3xl border border-white/10 bg-white/5 p-6"><p class="text-xs font-semibold uppercase tracking-[0.15em] text-sky-300">{item.when}</p><h3 class="mt-4 font-semibold">{item.segment}</h3><p class="mt-3 text-sm leading-7 text-slate-300">“{item.message}”</p></article>)}</div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.voiceEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.voiceTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.voiceText}</p></div><div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">{content.voiceCards.map((item) => <article data-reveal class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm"><h3 class="font-semibold text-slate-950">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p></article>)}</div></section>

      <section class="border-y border-slate-200 bg-white/70 py-20"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.channelsEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.channelsTitle}</h2><p class="mt-5 leading-8 text-slate-600">{content.channelsText}</p></div><div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">{content.channels.map((item) => <article data-reveal class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h3 class="font-semibold text-slate-950">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p></article>)}</div></div></section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="max-w-3xl"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.benchmarkEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.benchmarkTitle}</h2></div><div class="mt-10 grid gap-4 md:grid-cols-3">{content.benchmarks.map((item) => <article data-reveal class="rounded-3xl border border-sky-200 bg-gradient-to-br from-white to-sky-50 p-6 shadow-sm"><p class="text-3xl font-semibold tracking-tight text-sky-700">{item.value}</p><p class="mt-3 font-semibold leading-6 text-slate-800">{item.label}</p><p class="mt-4 border-t border-sky-100 pt-3 text-[11px] leading-5 text-slate-500">{item.source}</p></article>)}</div><p class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-xs leading-6 text-amber-900">{content.benchmarkNote}</p></section>

      <section class="bg-slate-950 py-20 text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div data-reveal><p class="inline-flex rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-sky-300">{content.processEyebrow}</p><h2 class="mt-5 max-w-3xl text-3xl font-semibold tracking-tight sm:text-4xl">{content.processTitle}</h2></div><div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">{content.process.map((item, index) => <article data-reveal style={`--reveal-delay:${index * 80}ms`} class="rounded-3xl border border-white/10 bg-white/5 p-6"><p class="text-xs font-semibold tracking-[0.17em] text-sky-300">{item.phase}</p><h3 class="mt-5 text-lg font-semibold">{item.title}</h3><p class="mt-3 text-sm leading-7 text-slate-300">{item.text}</p></article>)}</div></div></section>

      <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8"><div data-reveal class="text-center"><p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-sm font-semibold text-sky-700">{content.faqEyebrow}</p><h2 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{content.faqTitle}</h2></div><div class="mt-10 space-y-3">{content.faqs.map((item) => <details data-reveal class="group rounded-2xl border border-slate-200 bg-white/90 p-5 shadow-sm"><summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-slate-950"><span>{item.q}</span><span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-sky-50 text-sky-700 transition group-open:rotate-45">+</span></summary><p class="mt-4 max-w-3xl border-t border-slate-100 pt-4 leading-7 text-slate-600">{item.a}</p></details>)}</div></section>

      <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8"><div data-reveal class="relative overflow-hidden rounded-[2rem] border border-sky-400/20 bg-slate-950 p-8 text-center text-white shadow-[0_30px_90px_-25px_rgba(15,23,42,0.6)] sm:p-12"><div class="absolute left-1/2 top-0 h-64 w-64 -translate-x-1/2 rounded-full bg-fuchsia-400/10 blur-3xl"></div><div class="relative"><h2 class="mx-auto max-w-4xl text-3xl font-semibold tracking-tight sm:text-4xl">{content.ctaTitle}</h2><p class="mx-auto mt-5 max-w-2xl leading-8 text-slate-300">{content.ctaText}</p><a href={contactHref} class="mt-8 inline-flex items-center gap-2 rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-950/30 transition hover:bg-cyan-400">{content.ctaButton}<span>→</span></a></div></div></section>
    </main>
    <Footer />
  </div>
</BaseLayout>
