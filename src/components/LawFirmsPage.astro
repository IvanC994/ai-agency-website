---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import LogoMark from './LogoMark.astro';
import IndustryIcon from './IndustryIcon.astro';
import ServiceIcon from './ServiceIcon.astro';
import { SITE_URL } from '../config/site';

const { lang = 'en' } = Astro.props;
const isSr = lang === 'sr';
const contactHref = isSr ? '/sr#contact' : '/#contact';

const content = isSr
  ? {
      metaTitle: 'AI za advokatske kancelarije: dokumenti, pretraga i obuka',
      metaDescription: 'RoutineForge uvodi AI u advokatske kancelarije za nacrte dokumenata, e-mailove, internu pretragu i obuku tima, uz poverljivost i ljudsku kontrolu.',
      canonical: `${SITE_URL}/sr/ai-za-advokatske-kancelarije`, enUrl: `${SITE_URL}/ai-for-law-firms`, srUrl: `${SITE_URL}/sr/ai-za-advokatske-kancelarije`,
      eyebrow: 'INDUSTRIJE · ADVOKATSKE KANCELARIJE', title: 'Manje administracije. Više vremena za pravni rad.',
      intro: 'Uvodimo AI u interne procese kancelarije: prve nacrte ugovora i podnesaka, nacrte e-mailova i mišljenja, pretragu sopstvene dokumentacije i brži onboarding mlađih kolega. Pravnik zadržava procenu, odgovornost i potpis.',
      primaryCta: 'Zakažite besplatnu konsultaciju', secondaryCta: 'Pogledajte šta uvodimo',
      proof: [{ value: 'Human review', label: 'svaki pravni rezultat proverava pravnik' }, { value: 'Private by design', label: 'pravila pristupa pre alata' }, { value: 'SR + EN', label: 'dokumenti i pravna terminologija' }],
      visualLabel: 'INTERNI AI WORKSPACE · ILUSTRATIVNI PRIMER', visualMatter: 'Predmet: Komercijalni ugovor', visualTask: 'Pripremi prvi nacrt prema odobrenom obrascu i činjenicama predmeta.',
      visualSources: ['Obrazac: Ugovor o uslugama v4', 'Prethodni predmet: AL-2025-017', 'Napomene odgovornog advokata'], visualStatus: ['Izvori navedeni', 'Rizici označeni', 'Čeka pravni pregled'],
      painEyebrow: 'GDE NESTAJU NAPLATIVE SATNICE', painTitle: 'Pravo je znanje i procena. Sve oko toga ne mora da ostane ručni rad.', painIntro: 'Cilj nije da AI bude pravnik, već da sa stola ukloni ponavljanje, pretragu i pripremu kako bi pravnici više vremena ulagali u strategiju, pregovore i savetovanje.',
      pains: [
        { number: '01', title: 'Prvi nacrt uvek kreće od nule', text: 'Ugovor, podnesak ili odgovor klijentu sklapa se ručnim kopiranjem iz starih predmeta. Sat odlazi na posao koji AI može da pripremi za pregled.' },
        { number: '02', title: 'E-mailovi i mišljenja troše naplativo vreme', text: 'Pitanja se ponavljaju, a formatiranje, sređivanje i prilagođavanje tona oduzimaju vreme koje klijent ne prepoznaje kao pravnu vrednost.' },
        { number: '03', title: 'Znanje je zaključano u predmetima', text: 'Zaključak iz sličnog slučaja zna samo osoba koja je na njemu radila. Pretraga arhive ponekad traje duže od ponovnog pisanja.' },
        { number: '04', title: 'Onboarding mlađih kolega traje mesecima', text: 'Junior uči obrasce, precedents i način rada oslanjajući se na vreme seniora, iako veliki deo odgovora već postoji u internoj dokumentaciji.' }
      ],
      buildEyebrow: 'ŠTA UVODIMO U KANCELARIJU', buildTitle: 'Prvo pravila i bezbedno okruženje. Tek onda AI alati.', buildIntro: 'Nema eksperimenata sa podacima klijenata. Svaki modul dobija odobrene izvore, korisničke uloge, granice, evidenciju i obaveznu tačku pravnog pregleda.',
      builds: [
        { icon: 'workflow', title: 'Prvi nacrti ugovora i podnesaka', text: 'AI sastavlja radni nacrt iz odobrenih obrazaca, činjenica predmeta i relevantnih prethodnih dokumenata.', outcome: 'Advokat pregleda, menja i odlučuje umesto da počinje od prazne strane.' },
        { icon: 'chat', title: 'Nacrti e-mailova i pravnih mišljenja', text: 'Priprema odgovor u tonu kancelarije, uz upućivanje na dokumente konkretnog predmeta i jasno označene otvorene tačke.', outcome: 'Rutinska priprema se skraćuje, a pravna procena ostaje kod advokata.' },
        { icon: 'custom', title: 'AI pretraga interne dokumentacije', text: 'Interni asistent odgovara iz predmeta, obrazaca, internih pravila i odobrene prakse, uz prikaz izvora na kojima zasniva odgovor.', outcome: 'Znanje kancelarije manje zavisi od sećanja jedne osobe.' },
        { icon: 'custom', title: 'AI obuka za pravnike i osoblje', text: 'Praktične radionice: šta sme u AI, šta ne sme, kako se štiti poverljivost i kako se pišu promptovi koji daju upotrebljiv rezultat.', outcome: 'Tim dobija pravila i alate koje može bezbedno da koristi istog dana.' }
      ],
      safetyEyebrow: 'POVERLJIVOST PRE PRODUKTIVNOSTI', safetyTitle: 'AI se uvodi kao kontrolisan interni alat, ne kao otvoren prozor ka podacima klijenata.', safetyText: 'Pre izbora modela mapiramo vrste podataka, profesionalne obaveze, svrhu, dozvoljene korisnike, rokove čuvanja i ugovore sa obrađivačima. Konfiguracija se bira tako da podaci nisu korišćeni za treniranje javnih modela, a svaki izuzetak mora biti poznat i odobren.',
      safetyPoints: [{ title: 'Dozvoljeno i zabranjeno', text: 'Jasna matrica podataka i zadataka koji smeju ili ne smeju da uđu u AI proces.' }, { title: 'Pristup po ulozi', text: 'Korisnik vidi samo predmete, izvore i funkcije koje su mu potrebne.' }, { title: 'Izvori i audit trag', text: 'Odgovor pokazuje korišćene dokumente, a važne akcije ostaju evidentirane.' }, { title: 'Čuvanje i brisanje', text: 'Rokovi, logovi, kopije i brisanje definišu se pre produkcije, ne naknadno.' }],
      disclaimerTitle: 'AI ne daje samostalan pravni savet.', disclaimerText: 'Sistem priprema nacrte, izvlači podatke, poredi verzije i pronalazi materijal. Odgovorni pravnik proverava činjenice, pravo, strategiju i konačan tekst — kao senior koji pregleda rad juniora koji nikada ne potpisuje sam.',
      draftEyebrow: 'OD OBRASCA DO PRVOG NACRTA', draftTitle: 'Prazna strana postaje strukturiran dokument za pravni pregled.', draftText: 'Workflow prikuplja činjenice, bira odobren obrazac, predlaže klauzule, označava nedostajuće podatke i vraća dokument sa izvorima i otvorenim pitanjima.',
      draftSteps: [{ phase: '01', title: 'Činjenice predmeta', text: 'Strane, rokovi, vrednosti, jurisdikcija i posebni zahtevi.' }, { phase: '02', title: 'Odobreni izvori', text: 'Obrasci, prethodni dokumenti i interna pravila kancelarije.' }, { phase: '03', title: 'AI radni nacrt', text: 'Struktura, predložene odredbe, alternative i označene nepoznanice.' }, { phase: '04', title: 'Pravni pregled', text: 'Advokat proverava, menja, odobrava i preuzima odgovornost.' }],
      searchEyebrow: 'INTERNA AI PRETRAGA', searchTitle: 'Pitanje kancelarije dobija odgovor iz znanja kancelarije.', searchText: 'Umesto opšteg odgovora sa interneta, asistent pretražuje samo odobren korpus: predmete, mišljenja, obrasce, memorandume i interne procedure. Svaki odgovor treba da pokaže dokumente na kojima se zasniva.',
      query: 'Kako smo poslednji put rešili ograničenje odgovornosti kod sličnog SaaS ugovora?', searchResults: [{ title: 'Predmet AL-2025-017', detail: 'Konačni ugovor · klauzula 12' }, { title: 'Interni memorandum', detail: 'SaaS rizici · verzija 3' }, { title: 'Obrazac ugovora v4', detail: 'Odobrena alternativna formulacija' }],
      onboardingTitle: 'Onboarding koji ne prekida seniora za svako pitanje.', onboardingText: 'Mlađi kolega dobija smernice iz odobrenih obrazaca i interne prakse kada su mu potrebne. Senior ostaje mentor za procenu i strategiju, umesto pretraživač arhive.',
      trainingEyebrow: 'OBUKA JE TEMELJ', trainingTitle: 'Tim mora da zna gde AI pomaže — i gde mora da stane.', trainingText: 'Radionice koriste primere iz Vaše prakse, ne generičku teoriju. Rezultat su pravila korišćenja, biblioteka proverenih promptova i praktični tokovi za svakodnevni rad.',
      trainingItems: ['Poverljivost, profesionalna tajna i klasifikacija podataka', 'Promptovi za nacrte, pregled, sažimanje i pretragu', 'Provera činjenica, izvora, citata i halucinacija', 'Kada je human review obavezan i ko odobrava', 'Bezbedna upotreba na srpskom i engleskom', 'Kako se meri vreme, kvalitet i usvajanje u timu'],
      researchEyebrow: 'AI U PRAVNOJ PRAKSI', researchTitle: 'Istraživanja pokazuju obrazac: AI vraća vreme, a pravnik zadržava procenu i odgovornost.', researchText: 'Najveći potencijal je u standardizovanom pregledu ugovora, pripremi nacrta i pretrazi dokumentacije. Kancelarije koje ranije uvedu kontrolisan sistem mogu brže odgovoriti i konkurisati efikasnijom cenom.',
      benchmarks: [{ value: '~30 dana', label: 'radnog vremena godišnje po pravniku', source: 'Thomson Reuters / Everlaw, 2025 — navod sa referentne stranice' }, { value: '80–85%', label: 'brži pregled standardnih komercijalnih ugovora', source: 'industry research — navod sa referentne stranice' }, { value: '92%', label: 'pravnih profesionalaca koristi najmanje jedan AI alat', source: 'industry survey, 2025 — navod sa referentne stranice' }],
      benchmarkNote: 'Eksterni benchmark podaci opisuju industrijski potencijal i nisu garancija RoutineForge rezultata. U Vašoj kancelariji merimo vreme pre i posle, kvalitet nacrta, broj korekcija i usvajanje u timu.',
      processEyebrow: 'OD PRAVILA DO SVAKODNEVNOG RADA', processTitle: 'Počinjemo tamo gde odlaze nenaplativi sati.', process: [{ phase: '01', title: 'Snimak procesa i rizika', text: 'Mapiramo dokumente, e-mailove, pretragu, onboarding, vrste podataka, postojeće alate i odgovorne osobe.' }, { phase: '02', title: 'Politika i siguran pilot', text: 'Definišemo dozvoljeno korišćenje, korisnike, izvore, model, čuvanje i jedan ograničen use case.' }, { phase: '03', title: 'Obuka i testiranje', text: 'Tim radi sa realističnim primerima, meri tačnost i korisnost i proverava gde sistem mora da eskalira.' }, { phase: '04', title: 'Fazno širenje', text: 'Najčešće krećemo obukom i pripremom dokumenata, zatim dodajemo internu pretragu i automatizacije.' }],
      faqEyebrow: 'ČESTA PITANJA', faqTitle: 'Šta advokatske kancelarije žele da znaju.',
      faqs: [
        { q: 'Šta je sa poverljivošću podataka klijenata?', a: 'To je prva tema projekta. Definišemo šta sme u sistem, biramo konfiguraciju u kojoj podaci nisu korišćeni za treniranje javnih modela, uređujemo pristup, čuvanje i brisanje i ugrađujemo pravila u obuku tima.' },
        { q: 'Da li AI piše pravni savet?', a: 'Ne samostalno. AI priprema nacrt i pronalazi materijal, dok pravnik proverava činjenice i pravo, donosi procenu, odobrava tekst i potpisuje.' },
        { q: 'Naš tim nema tehničko znanje. Da li je to problem?', a: 'Nije. Radionice koriste praktične primere iz kancelarije i jasne procedure, tako da korisnici ne moraju da razumeju tehničku pozadinu modela da bi alat koristili odgovorno.' },
        { q: 'Odakle počinjemo?', a: 'Snimkom mesta na kojima odlaze nenaplativi sati. Čest prvi korak su politika korišćenja, obuka i priprema dokumenata, pa tek zatim interna pretraga i povezane automatizacije.' },
        { q: 'Koliko košta uvođenje AI-a u kancelariju?', a: 'Zavisi od broja korisnika, vrsta podataka, integracija i use case-ova. Obuka je najmanji i čest prvi korak; interni asistent i automatizacije uvode se fazno nakon jasnog predloga.' },
        { q: 'Da li AI radi sa dokumentima na srpskom?', a: 'Da. Rešenja mogu da rade na srpskom i engleskom, uključujući pravnu terminologiju, ali se kvalitet obavezno testira na Vašim obrascima, stilovima i tipičnim dokumentima.' }
      ],
      ctaTitle: 'Manje administracije. Više prava.', ctaText: 'Na konsultaciji prolazimo kroz rad kancelarije i predlažemo šta AI može da preuzme već u prvoj fazi — bez ugrožavanja poverljivosti i bez preskakanja pravnog pregleda.', ctaButton: 'Zakažite konsultaciju'
    }
  : {
      metaTitle: 'AI for law firms: drafting, internal search, and training',
      metaDescription: 'RoutineForge brings AI into law firms for document drafts, email preparation, internal search, and team training with confidentiality and human control.',
      canonical: `${SITE_URL}/ai-for-law-firms`, enUrl: `${SITE_URL}/ai-for-law-firms`, srUrl: `${SITE_URL}/sr/ai-za-advokatske-kancelarije`,
      eyebrow: 'INDUSTRIES · LAW FIRMS', title: 'Less administration. More time for legal work.',
      intro: 'We bring AI into the firm’s internal processes: first drafts of contracts and filings, draft emails and opinions, search across your own documentation, and faster onboarding of junior colleagues. Lawyers retain judgment, responsibility, and signature.',
      primaryCta: 'Book a free consultation', secondaryCta: 'See what we introduce',
      proof: [{ value: 'Human review', label: 'a lawyer reviews every legal output' }, { value: 'Private by design', label: 'access rules before tools' }, { value: 'EN + SR', label: 'documents and legal terminology' }],
      visualLabel: 'INTERNAL AI WORKSPACE · ILLUSTRATIVE EXAMPLE', visualMatter: 'Matter: Commercial agreement', visualTask: 'Prepare a first draft from the approved template and matter facts.',
      visualSources: ['Template: Services Agreement v4', 'Previous matter: AL-2025-017', 'Responsible lawyer’s notes'], visualStatus: ['Sources listed', 'Risks flagged', 'Awaiting legal review'],
      painEyebrow: 'WHERE BILLABLE HOURS DISAPPEAR', painTitle: 'Law is knowledge and judgment. Everything around it does not have to remain manual.', painIntro: 'The goal is not to make AI a lawyer. It is to remove repetition, searching, and preparation so lawyers spend more time on strategy, negotiation, and advice.',
      pains: [
        { number: '01', title: 'The first draft always starts from zero', text: 'A contract, filing, or client reply is assembled by copying from old matters. An hour goes to work AI can prepare for review.' },
        { number: '02', title: 'Emails and opinions consume billable time', text: 'Questions repeat, while formatting, cleanup, and tone adaptation consume time the client does not recognize as legal value.' },
        { number: '03', title: 'Knowledge remains locked inside matters', text: 'A conclusion from a similar matter is known only to the person who worked on it. Searching the archive can take longer than rewriting.' },
        { number: '04', title: 'Junior onboarding takes months', text: 'A junior learns templates, precedents, and the firm’s way of working by consuming senior time, although many answers already exist in internal documents.' }
      ],
      buildEyebrow: 'WHAT WE BRING INTO THE FIRM', buildTitle: 'Rules and a safe environment first. AI tools second.', buildIntro: 'There are no experiments with client data. Every module receives approved sources, user roles, boundaries, logging, and a mandatory legal-review point.',
      builds: [
        { icon: 'workflow', title: 'First drafts of contracts and filings', text: 'AI assembles a working draft from approved templates, matter facts, and relevant previous documents.', outcome: 'The lawyer reviews, changes, and decides instead of starting with a blank page.' },
        { icon: 'chat', title: 'Draft emails and legal opinions', text: 'It prepares a reply in the firm’s tone, referencing matter documents and clearly marking open questions.', outcome: 'Routine preparation becomes faster while legal judgment remains with the lawyer.' },
        { icon: 'custom', title: 'AI search across internal documentation', text: 'An internal assistant answers from matters, templates, firm rules, and approved practice, showing the sources behind its response.', outcome: 'Firm knowledge depends less on one person’s memory.' },
        { icon: 'custom', title: 'AI training for lawyers and staff', text: 'Practical workshops cover what may enter AI, what may not, confidentiality protection, and prompts that produce usable work.', outcome: 'The team leaves with rules and tools it can use safely the same day.' }
      ],
      safetyEyebrow: 'CONFIDENTIALITY BEFORE PRODUCTIVITY', safetyTitle: 'AI enters as a controlled internal tool, not an open window into client data.', safetyText: 'Before selecting a model, we map data types, professional duties, purpose, permitted users, retention, and processor contracts. The setup is chosen so client data is not used to train public models, and every exception must be known and approved.',
      safetyPoints: [{ title: 'Allowed and prohibited', text: 'A clear matrix of data and tasks that may or may not enter an AI workflow.' }, { title: 'Role-based access', text: 'Users see only the matters, sources, and functions required for their work.' }, { title: 'Sources and audit trail', text: 'Responses show the documents used, while important actions remain logged.' }, { title: 'Retention and deletion', text: 'Retention, logs, copies, and deletion are defined before production, not afterwards.' }],
      disclaimerTitle: 'AI does not provide independent legal advice.', disclaimerText: 'The system prepares drafts, extracts data, compares versions, and finds material. A responsible lawyer checks facts, law, strategy, and final wording — like a senior reviewing the work of a junior who never signs alone.',
      draftEyebrow: 'FROM TEMPLATE TO FIRST DRAFT', draftTitle: 'A blank page becomes a structured document ready for legal review.', draftText: 'The workflow gathers facts, selects an approved template, proposes clauses, flags missing information, and returns a document with sources and open questions.',
      draftSteps: [{ phase: '01', title: 'Matter facts', text: 'Parties, deadlines, values, jurisdiction, and special requirements.' }, { phase: '02', title: 'Approved sources', text: 'Templates, previous documents, and internal firm rules.' }, { phase: '03', title: 'AI working draft', text: 'Structure, proposed clauses, alternatives, and flagged unknowns.' }, { phase: '04', title: 'Legal review', text: 'The lawyer checks, changes, approves, and assumes responsibility.' }],
      searchEyebrow: 'INTERNAL AI SEARCH', searchTitle: 'A firm question receives an answer from firm knowledge.', searchText: 'Instead of a general internet answer, the assistant searches only an approved corpus: matters, opinions, templates, memoranda, and internal procedures. Every answer should show the documents on which it relies.',
      query: 'How did we last address the limitation of liability in a similar SaaS agreement?', searchResults: [{ title: 'Matter AL-2025-017', detail: 'Final agreement · clause 12' }, { title: 'Internal memorandum', detail: 'SaaS risks · version 3' }, { title: 'Agreement template v4', detail: 'Approved alternative wording' }],
      onboardingTitle: 'Onboarding that does not interrupt a senior for every question.', onboardingText: 'A junior receives guidance from approved templates and internal practice when needed. The senior remains a mentor for judgment and strategy instead of becoming an archive search engine.',
      trainingEyebrow: 'TRAINING IS THE FOUNDATION', trainingTitle: 'The team must know where AI helps — and where it must stop.', trainingText: 'Workshops use examples from your practice, not generic theory. The outcome is a usage policy, a library of tested prompts, and practical daily workflows.',
      trainingItems: ['Confidentiality, privilege, and data classification', 'Prompts for drafting, review, summarization, and search', 'Checking facts, sources, citations, and hallucinations', 'When human review is mandatory and who approves', 'Safe work in English and Serbian', 'Measuring time, quality, and team adoption'],
      researchEyebrow: 'AI IN LEGAL PRACTICE', researchTitle: 'Research shows a pattern: AI returns time while lawyers retain judgment and responsibility.', researchText: 'The greatest potential lies in standardized contract review, draft preparation, and document search. Firms that adopt controlled systems earlier can respond faster and compete with more efficient pricing.',
      benchmarks: [{ value: '~30 days', label: 'of working time per lawyer each year', source: 'Thomson Reuters / Everlaw, 2025 — figure quoted by the reference page' }, { value: '80–85%', label: 'faster review of standard commercial contracts', source: 'industry research — figure quoted by the reference page' }, { value: '92%', label: 'of legal professionals use at least one AI tool', source: 'industry survey, 2025 — figure quoted by the reference page' }],
      benchmarkNote: 'External benchmarks describe industry potential and are not a RoutineForge performance guarantee. In your firm, we measure time before and after, draft quality, correction volume, and team adoption.',
      processEyebrow: 'FROM RULES TO DAILY WORK', processTitle: 'We start where non-billable hours disappear.', process: [{ phase: '01', title: 'Process and risk discovery', text: 'We map documents, emails, search, onboarding, data types, current tools, and responsible people.' }, { phase: '02', title: 'Policy and safe pilot', text: 'We define permitted use, users, sources, model, retention, and one limited use case.' }, { phase: '03', title: 'Training and testing', text: 'The team works with realistic examples, measures accuracy and usefulness, and checks where the system must escalate.' }, { phase: '04', title: 'Phased expansion', text: 'Firms often begin with training and document preparation, then add internal search and automation.' }],
      faqEyebrow: 'FREQUENTLY ASKED QUESTIONS', faqTitle: 'What law firms want to know.',
      faqs: [
        { q: 'What about client confidentiality?', a: 'It is the first project topic. We define what may enter the system, choose a setup where data is not used to train public models, control access, retention, and deletion, and build the rules into team training.' },
        { q: 'Does AI write legal advice?', a: 'Not independently. AI prepares a draft and finds material, while the lawyer checks facts and law, exercises judgment, approves the text, and signs.' },
        { q: 'Our team has no technical background. Is that a problem?', a: 'No. Workshops use practical examples and clear procedures, so users do not need to understand the model’s technical internals to use the tool responsibly.' },
        { q: 'Where do we start?', a: 'With a snapshot of where non-billable hours go. A common first step is a usage policy, training, and document preparation, followed by internal search and connected automation.' },
        { q: 'How much does bringing AI into a law firm cost?', a: 'It depends on users, data types, integrations, and use cases. Training is the smallest and common first step; an internal assistant and automation are introduced in phases after a clear proposal.' },
        { q: 'Does AI work with documents in Serbian?', a: 'Yes. Systems can work in English and Serbian, including legal terminology, but quality must be tested against your templates, style, and typical documents.' }
      ],
      ctaTitle: 'Less administration. More law.', ctaText: 'In a free consultation, we review how the firm works and propose what AI can take over in the first phase — without risking confidentiality or bypassing legal review.', ctaButton: 'Book a consultation'
    };

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: isSr ? 'AI sistemi za advokatske kancelarije' : 'AI systems for law firms',
  serviceType: 'Law firm AI automation and training',
  provider: { '@type': 'Organization', name: 'RoutineForge', url: SITE_URL },
  areaServed: 'Global', description: content.metaDescription,
  availableChannel: { '@type': 'ServiceChannel', serviceUrl: content.canonical, availableLanguage: ['English', 'Serbian'] }
};
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} canonical={content.canonical} enUrl={content.enUrl} srUrl={content.srUrl} lang={isSr ? 'sr' : 'en'}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <div class="min-h-screen overflow-x-hidden bg-slate-50">
    <Navbar />
    <main>
