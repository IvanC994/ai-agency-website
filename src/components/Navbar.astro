---
const currentPath = Astro.url.pathname;
const isSerbianPage = currentPath.startsWith('/sr');

const links = isSerbianPage
  ? [
      { label: 'Usluge', href: '#services' },
      { label: 'Proces', href: '#process' },
      { label: 'Česta pitanja', href: '#faq' },
      { label: 'Kontakt', href: '#contact' }
    ]
  : [
      { label: 'Services', href: '#services' },
      { label: 'Process', href: '#process' },
      { label: 'FAQ', href: '#faq' },
      { label: 'Contact', href: '#contact' }
    ];

const consultationText = isSerbianPage ? 'Zakažite besplatnu konsultaciju' : 'Book a consultation';
const languageButtonText = isSerbianPage ? 'EN' : 'SR';
const languageButtonLink = isSerbianPage ? '/' : '/sr';
---

<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="#top" class="flex items-center gap-3 text-lg font-semibold tracking-tight text-slate-950" aria-label="CortexFlow home">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-slate-950 text-sm font-bold text-white">CF</span>
      <span>CortexFlow</span>
    </a>
    <nav class="hidden items-center gap-8 text-sm font-medium text-slate-600 md:flex" aria-label="Primary">
      {links.map((link) => <a href={link.href} class="transition hover:text-slate-950">{link.label}</a>)}
    </nav>
    <div class="flex items-center gap-3">
      <a href="#contact" class="hidden rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-sky-300 hover:text-sky-700 sm:inline-flex">{consultationText}</a>
      <a href={languageButtonLink} class="rounded-full border border-slate-200 bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800">{languageButtonText}</a>
    </div>
  </div>
</header>
