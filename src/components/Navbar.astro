---
import LogoWordmark from './LogoWordmark.astro';
import ServiceIcon from './ServiceIcon.astro';
const currentPath = Astro.url.pathname;
const isSerbianPage = currentPath.startsWith('/sr');
const isLandingPage = currentPath === '/' || currentPath === '/sr';
const homeHref = isSerbianPage ? '/sr' : '/';
const pagePrefix = isLandingPage ? '' : homeHref;
const aboutHref = isSerbianPage ? '/sr/about' : '/about';
const chatbotHref = isSerbianPage ? '/sr/ai-chatbot' : '/ai-chatbot';
const automationHref = isSerbianPage ? '/sr/ai-automatizacije' : '/ai-automation';
const webDevelopmentHref = isSerbianPage ? '/sr/izrada-sajtova' : '/web-development';
const phoneAgentHref = isSerbianPage ? '/sr/ai-telefonski-agent' : '/ai-phone-agent';
const customSystemsHref = isSerbianPage ? '/sr/prilagodjeni-ai-sistemi' : '/custom-ai-systems';
const languageRoutePairs = {
  '/ai-automation': '/sr/ai-automatizacije',
  '/web-development': '/sr/izrada-sajtova',
  '/ai-phone-agent': '/sr/ai-telefonski-agent',
  '/custom-ai-systems': '/sr/prilagodjeni-ai-sistemi'
};
const normalizedPath = currentPath.length > 1 ? currentPath.replace(/\/$/, '') : currentPath;
const matchedEnglishPath = Object.entries(languageRoutePairs).find(([, srPath]) => srPath === normalizedPath)?.[0];
const enHref = matchedEnglishPath || (isSerbianPage ? (normalizedPath === '/sr' ? '/' : normalizedPath.replace(/^\/sr/, '')) : normalizedPath);
const srHref = languageRoutePairs[normalizedPath] || (isSerbianPage ? normalizedPath : (normalizedPath === '/' ? '/sr' : `/sr${normalizedPath}`));

const navigation = isSerbianPage
  ? {
      home: 'Početna', services: 'Usluge', contact: 'Kontakt', about: 'O nama',
      homeLinks: [
        { label: 'Usluge', description: 'Pregled AI sistema koje gradimo', href: `${pagePrefix}#services` },
        { label: 'Industrije', description: 'Rešenja prema poslovnom kontekstu', href: `${pagePrefix}#industries` },
        { label: 'Proces', description: 'Od snimka procesa do produkcije', href: `${pagePrefix}#process` },
        { label: 'Utisci', description: 'Iskustva i rezultati klijenata', href: `${pagePrefix}#testimonials` },
        { label: 'Česta pitanja', description: 'Odgovori pre prvog razgovora', href: `${pagePrefix}#faq` },
        { label: 'ROI kalkulator', description: 'Okvirna vrednost automatizacije', href: `${pagePrefix}#roi` }
      ],
      serviceLinks: [
        { label: 'AI chatbot', description: 'Prodaja, podrška i zakazivanje 24/7', href: chatbotHref, icon: 'chat' },
        { label: 'AI automatizacije', description: 'Procesi koji se odvijaju sami', href: automationHref, icon: 'workflow' },
        { label: 'Izrada sajtova', description: 'Brzi sajtovi za Google, AI i konverzije', href: webDevelopmentHref, icon: 'web' },
        { label: 'AI telefonski agent', description: 'Svaki poziv dobija odgovor i sledeći korak', href: phoneAgentHref, icon: 'phone' },
        { label: 'Prilagođeni AI sistemi', description: 'AI izgrađen oko Vašeg jedinstvenog procesa', href: customSystemsHref, icon: 'custom' }
      ]
    }
  : {
      home: 'Home', services: 'Services', contact: 'Contact', about: 'About us',
      homeLinks: [
        { label: 'Services', description: 'An overview of the AI systems we build', href: `${pagePrefix}#services` },
        { label: 'Industries', description: 'Solutions shaped around business context', href: `${pagePrefix}#industries` },
        { label: 'Process', description: 'From process discovery to production', href: `${pagePrefix}#process` },
        { label: 'Testimonials', description: 'Client experiences and outcomes', href: `${pagePrefix}#testimonials` },
        { label: 'FAQ', description: 'Answers before the first conversation', href: `${pagePrefix}#faq` },
        { label: 'ROI Calculator', description: 'Estimate the value of automation', href: `${pagePrefix}#roi` }
      ],
      serviceLinks: [
        { label: 'AI Chatbot', description: 'Sales, support, and booking 24/7', href: chatbotHref, icon: 'chat' },
        { label: 'AI Automation', description: 'Processes that run themselves', href: automationHref, icon: 'workflow' },
        { label: 'Web Development', description: 'Fast websites for search, AI, and conversion', href: webDevelopmentHref, icon: 'web' },
        { label: 'AI Phone Agent', description: 'Every call gets an answer and a next step', href: phoneAgentHref, icon: 'phone' },
        { label: 'Custom AI Systems', description: 'AI built around your unique process', href: customSystemsHref, icon: 'custom' }
      ]
    };

const consultationText = isSerbianPage ? 'Zakažite besplatnu konsultaciju' : 'Book a consultation';
const menuText = isSerbianPage ? 'Meni' : 'Menu';
const closeMenuText = isSerbianPage ? 'Zatvori meni' : 'Close menu';
---

<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur-xl" data-site-header>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href={homeHref} class="inline-flex" aria-label="RoutineForge home">
      <LogoWordmark />
    </a>
    <nav class="hidden items-center gap-6 text-sm font-medium text-slate-600 xl:flex" aria-label="Primary">
      <div class="group relative">
        <a href={homeHref} class="inline-flex items-center gap-1.5 py-2 transition hover:text-slate-950" aria-haspopup="true"><span>{navigation.home}</span><svg viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" stroke-width="1.8" aria-hidden="true"><path d="m6 8 4 4 4-4" stroke-linecap="round" stroke-linejoin="round" /></svg></a>
        <div class="invisible absolute left-0 top-full z-50 w-80 translate-y-2 pt-3 opacity-0 transition duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
          <div class="rounded-3xl border border-slate-200 bg-white/95 p-2 shadow-2xl shadow-slate-300/50 backdrop-blur-xl">
            {navigation.homeLinks.map((link) => <a href={link.href} data-nav-link data-nav-target={link.href.includes('#') ? link.href.split('#')[1] : undefined} class="group/item block rounded-2xl px-4 py-3 transition hover:bg-sky-50"><span class="flex items-center justify-between gap-3 font-semibold text-slate-900"><span>{link.label}</span><span class="text-sky-500 opacity-0 transition group-hover/item:translate-x-0.5 group-hover/item:opacity-100">→</span></span><span class="mt-1 block text-xs font-normal leading-5 text-slate-500">{link.description}</span></a>)}
          </div>
        </div>
      </div>

      <div class="group relative">
        <a href={`${pagePrefix}#services`} class="inline-flex items-center gap-1.5 py-2 transition hover:text-slate-950" aria-haspopup="true"><span>{navigation.services}</span><svg viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" stroke-width="1.8" aria-hidden="true"><path d="m6 8 4 4 4-4" stroke-linecap="round" stroke-linejoin="round" /></svg></a>
        <div class="invisible absolute left-0 top-full z-50 w-80 translate-y-2 pt-3 opacity-0 transition duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
          <div class="rounded-3xl border border-slate-200 bg-white/95 p-2 shadow-2xl shadow-slate-300/50 backdrop-blur-xl">
            {navigation.serviceLinks.map((link) => <a href={link.href} class="group/item flex gap-4 rounded-2xl px-4 py-4 transition hover:bg-sky-50"><span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl border border-sky-100 bg-sky-50 text-sky-600 transition group-hover/item:border-sky-200 group-hover/item:bg-white group-hover/item:text-sky-700"><ServiceIcon icon={link.icon} /></span><span class="min-w-0 flex-1"><span class="flex items-center justify-between gap-3 font-semibold text-slate-900"><span>{link.label}</span><span class="text-sky-500 opacity-0 transition group-hover/item:translate-x-0.5 group-hover/item:opacity-100">→</span></span><span class="mt-1 block text-xs font-normal leading-5 text-slate-500">{link.description}</span></span></a>)}
          </div>
        </div>
      </div>

      <a href={`${pagePrefix}#contact`} data-nav-link data-nav-target="contact" class="py-2 transition hover:text-slate-950">{navigation.contact}</a>
      <a href={aboutHref} class="py-2 transition hover:text-slate-950">{navigation.about}</a>
    </nav>
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1 rounded-full bg-slate-100 p-1" aria-label="Language selector">
        <a href={enHref} class:list={["rounded-full px-3 py-1.5 text-xs font-semibold transition", !isSerbianPage ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700']}>EN</a>
        <a href={srHref} class:list={["rounded-full px-3 py-1.5 text-xs font-semibold transition", isSerbianPage ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700']}>SR</a>
      </div>
      <a href={`${pagePrefix}#contact`} class="group hidden items-center gap-2 rounded-full bg-sky-600 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-sky-200 transition hover:bg-cyan-500 hover:shadow-sky-300 sm:inline-flex"><span>{consultationText}</span><span class="transition-transform duration-200 group-hover:translate-x-0.5" aria-hidden="true">→</span></a>
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-sm transition hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700 xl:hidden"
        aria-label={menuText}
        aria-expanded="false"
        aria-controls="mobile-navigation"
        data-close-label={closeMenuText}
        data-mobile-nav-toggle
      >
        <span class="sr-only" data-mobile-nav-label>{menuText}</span>
        <svg data-mobile-nav-open-icon viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="2" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
        </svg>
        <svg data-mobile-nav-close-icon viewBox="0 0 24 24" class="hidden h-5 w-5 fill-none stroke-current" stroke-width="2" aria-hidden="true">
          <path d="m6 6 12 12M18 6 6 18" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-navigation"
    class="mx-4 mb-4 hidden overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-2xl shadow-slate-200/70 xl:hidden"
    data-mobile-nav
  >
    <nav class="grid gap-4 p-3 text-sm text-slate-700" aria-label="Mobile primary">
      <div>
        <a href={homeHref} data-mobile-nav-link class="flex items-center justify-between rounded-2xl bg-slate-50 px-4 py-3 font-semibold text-slate-950"><span>{navigation.home}</span><span class="text-sky-600">→</span></a>
        <div class="mt-1 grid gap-0.5 pl-3">{navigation.homeLinks.map((link) => <a href={link.href} data-mobile-nav-link class="rounded-xl px-4 py-2.5 font-medium transition hover:bg-sky-50 hover:text-sky-700">{link.label}</a>)}</div>
      </div>
      <div>
        <p class="rounded-2xl bg-slate-50 px-4 py-3 font-semibold text-slate-950">{navigation.services}</p>
        <div class="mt-1 grid gap-0.5 pl-3">{navigation.serviceLinks.map((link) => <a href={link.href} data-mobile-nav-link class="flex items-center gap-3 rounded-xl px-4 py-2.5 font-medium transition hover:bg-sky-50 hover:text-sky-700"><span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-xl border border-sky-100 bg-sky-50 text-sky-600"><ServiceIcon icon={link.icon} /></span><span>{link.label}</span></a>)}</div>
      </div>
      <div class="grid gap-0.5 border-t border-slate-100 pt-3">
        <a href={`${pagePrefix}#contact`} data-mobile-nav-link class="rounded-xl px-4 py-2.5 font-semibold transition hover:bg-sky-50 hover:text-sky-700">{navigation.contact}</a>
        <a href={aboutHref} data-mobile-nav-link class="rounded-xl px-4 py-2.5 font-semibold transition hover:bg-sky-50 hover:text-sky-700">{navigation.about}</a>
      </div>
    </nav>
    <div class="border-t border-slate-100 p-3">
      <a href={`${pagePrefix}#contact`} data-mobile-nav-link class="group flex items-center justify-center gap-2 rounded-full bg-sky-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-200 transition hover:bg-cyan-500 hover:shadow-sky-300"><span>{consultationText}</span><span class="transition-transform duration-200 group-hover:translate-x-0.5" aria-hidden="true">→</span></a>
    </div>
  </div>
</header>

<script>
  const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));

  if (navLinks.length) {
    const sections = navLinks
      .map((link) => {
        const id = link.getAttribute('data-nav-target');
        const section = id ? document.getElementById(id) : null;
        return section ? { link, section } : null;
      })
      .filter(Boolean);

    const setActive = (activeLink) => {
      navLinks.forEach((link) => {
        if (link === activeLink) {
          link.classList.add('text-sky-700', 'font-semibold');
          link.classList.remove('text-slate-600');
        } else {
          link.classList.remove('text-sky-700', 'font-semibold');
          link.classList.add('text-slate-600');
        }
      });
    };

    if (sections.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const match = sections.find((s) => s.section === entry.target);
              if (match) setActive(match.link);
            }
          });
        },
        { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
      );

      sections.forEach(({ section }) => observer.observe(section));
    }
  }

  const mobileNav = document.querySelector('[data-mobile-nav]');
  const mobileNavToggle = document.querySelector('[data-mobile-nav-toggle]');
  const mobileNavOpenIcon = document.querySelector('[data-mobile-nav-open-icon]');
  const mobileNavCloseIcon = document.querySelector('[data-mobile-nav-close-icon]');
  const mobileNavLabel = document.querySelector('[data-mobile-nav-label]');
  const siteHeader = document.querySelector('[data-site-header]');
  const openLabel = mobileNavToggle?.getAttribute('aria-label') || 'Menu';
  const closeLabel = mobileNavToggle?.getAttribute('data-close-label') || 'Close menu';

  const setMobileNavOpen = (isOpen) => {
    mobileNav?.classList.toggle('hidden', !isOpen);
    mobileNavToggle?.setAttribute('aria-expanded', String(isOpen));
    mobileNavToggle?.setAttribute('aria-label', isOpen ? closeLabel : openLabel);
    mobileNavOpenIcon?.classList.toggle('hidden', isOpen);
    mobileNavCloseIcon?.classList.toggle('hidden', !isOpen);
    if (mobileNavLabel) mobileNavLabel.textContent = isOpen ? closeLabel : openLabel;
  };

  mobileNavToggle?.addEventListener('click', () => {
    const isOpen = mobileNavToggle.getAttribute('aria-expanded') === 'true';
    setMobileNavOpen(!isOpen);
  });

  document.querySelectorAll('[data-mobile-nav-link]').forEach((link) => {
    link.addEventListener('click', () => setMobileNavOpen(false));
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMobileNavOpen(false);
  });

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (target instanceof Node && siteHeader && !siteHeader.contains(target)) {
      setMobileNavOpen(false);
    }
  });
</script>
