---
const { icon } = Astro.props;
---

{icon === 'dental' && (
  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M8.2 3.1c1.4 0 2.5.8 3.8.8s2.4-.8 3.8-.8c2.8 0 4.7 2.2 4.3 5.2-.5 3.4-2 5.6-2.8 8.8-.5 2-1.1 3.8-2.4 3.8-1.6 0-1.2-4.8-2.9-4.8s-1.3 4.8-2.9 4.8c-1.3 0-1.9-1.8-2.4-3.8-.8-3.2-2.3-5.4-2.8-8.8-.4-3 1.5-5.2 4.3-5.2Z" />
    <path d="M9 7.2c1.8.8 4.2.8 6 0" />
  </svg>
)}

{icon === 'travel' && (
  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
