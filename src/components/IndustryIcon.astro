    <path d="M12 3v17M7 21h10M5 6h14M6 6l-4 7h8L6 6ZM18 6l-4 7h8l-4-7Z" />
    <path d="M2 13c.6 1.2 1.9 2 4 2s3.4-.8 4-2M14 13c.6 1.2 1.9 2 4 2s3.4-.8 4-2" />
  </svg>
)}

{icon === 'hotel' && (
  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16M16 9h2a2 2 0 0 1 2 2v10M2 21h20" />
    <path d="M8 7h4M8 11h4M8 15h4M8 19h4" />
