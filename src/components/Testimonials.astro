---
const {
  eyebrow = 'Client feedback',
  title = 'Trusted by teams that automated with CortexFlow',
  testimonials = []
} = Astro.props;
---

<div class="relative" data-testimonials-root>
  <div class="flex items-end justify-between gap-4">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-700">{eyebrow}</p>
      <h2 class="mt-3 max-w-2xl text-3xl font-semibold tracking-tight text-slate-950">{title}</h2>
    </div>
    <div class="hidden shrink-0 gap-2 sm:flex">
      <button data-testimonial-prev type="button" aria-label="Previous testimonial" class="flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 shadow-sm transition hover:border-sky-300 hover:text-sky-700 disabled:cursor-not-allowed disabled:opacity-40">
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="2"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button data-testimonial-next type="button" aria-label="Next testimonial" class="flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 shadow-sm transition hover:border-sky-300 hover:text-sky-700 disabled:cursor-not-allowed disabled:opacity-40">
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <div data-testimonial-track class="mt-8 flex snap-x snap-mandatory gap-5 overflow-x-auto scroll-smooth pb-4 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
    {testimonials.map((t) => (
      <article class="w-[85%] shrink-0 snap-start rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:w-[60%] lg:w-[38%]">
        <svg viewBox="0 0 32 24" class="h-7 w-7 fill-sky-200"><path d="M0 24V14.4C0 6.4 5.6 0.8 13.6 0L14.8 3.2C10 4.4 7.2 7.6 6.8 12H14V24H0ZM18 24V14.4C18 6.4 23.6 0.8 31.6 0L32.8 3.2C28 4.4 25.2 7.6 24.8 12H32V24H18Z"/></svg>
        <p class="mt-4 text-base leading-7 text-slate-700">{t.quote}</p>
        <div class="mt-6 flex items-center gap-3 border-t border-slate-100 pt-6">
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sm font-semibold text-sky-700">{t.initials}</span>
          <div class="min-w-0">
            <p class="truncate font-semibold text-slate-950">{t.name}</p>
            <p class="truncate text-sm text-slate-500">{t.role}</p>
          </div>
          {t.stat && (
            <span class="ml-auto shrink-0 rounded-full bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600">{t.stat}</span>
          )}
        </div>
      </article>
    ))}
  </div>

  <div data-testimonial-dots class="mt-2 flex justify-center gap-2 sm:hidden">
    {testimonials.map((_, i) => (
      <span data-testimonial-dot data-dot-index={i} class="h-1.5 w-1.5 rounded-full bg-slate-300 transition-all duration-300"></span>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('[data-testimonials-root]').forEach((root) => {
    const track = root.querySelector('[data-testimonial-track]');
    const prevBtn = root.querySelector('[data-testimonial-prev]');
    const nextBtn = root.querySelector('[data-testimonial-next]');
    const dots = Array.from(root.querySelectorAll('[data-testimonial-dot]'));
    const cards = Array.from(track.children);

    const scrollByCard = (direction) => {
      const card = cards[0];
      if (!card) return;
      const gap = 20;
      const amount = (card.getBoundingClientRect().width + gap) * direction;
      track.scrollBy({ left: amount, behavior: 'smooth' });
    };

    prevBtn?.addEventListener('click', () => scrollByCard(-1));
    nextBtn?.addEventListener('click', () => scrollByCard(1));

    const updateActiveDot = () => {
      if (!dots.length) return;
      const trackRect = track.getBoundingClientRect();
      let closestIndex = 0;
      let closestDistance = Infinity;
      cards.forEach((card, index) => {
        const cardRect = card.getBoundingClientRect();
        const distance = Math.abs(cardRect.left - trackRect.left);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });
      dots.forEach((dot, index) => {
        if (index === closestIndex) {
          dot.classList.add('w-5', 'bg-sky-500');
          dot.classList.remove('bg-slate-300');
        } else {
          dot.classList.remove('w-5', 'bg-sky-500');
          dot.classList.add('bg-slate-300');
        }
      });
    };

    let scrollTimeout;
    track.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(updateActiveDot, 100);
    });

    updateActiveDot();
  });
</script>

