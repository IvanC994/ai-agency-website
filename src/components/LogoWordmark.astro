---
const { dark = false, class: className = '' } = Astro.props;
const textClass = dark ? 'text-white' : 'text-slate-950';
---

<span class:list={["inline-flex items-center gap-2.5", className]} aria-label="RoutineForge">
  <svg viewBox="0 0 200 200" fill="none" class="h-10 w-10 shrink-0" aria-hidden="true">
    <defs>
      <linearGradient id="routineforge-sky" x1="50" y1="165" x2="160" y2="40" gradientUnits="userSpaceOnUse"><stop stop-color="#0284C7"/><stop offset="1" stop-color="#22D3EE"/></linearGradient>
      <linearGradient id="routineforge-forge" x1="154" y1="42" x2="190" y2="76" gradientUnits="userSpaceOnUse"><stop stop-color="#F97316"/><stop offset="1" stop-color="#FBBF24"/></linearGradient>
    </defs>
    <rect width="200" height="200" rx="46" fill="#020617"/>
    <path d="M60 153V52h53c31 0 50 17 50 44 0 23-14 38-36 43l39 30" stroke="url(#routineforge-sky)" stroke-width="17" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M60 104h68M60 153l49-49 45-42" stroke="url(#routineforge-sky)" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="60" cy="153" r="14" fill="#020617" stroke="#38BDF8" stroke-width="7"/><circle cx="109" cy="104" r="15" fill="#020617" stroke="#38BDF8" stroke-width="7"/><circle cx="154" cy="62" r="16" fill="url(#routineforge-forge)"/>
    <path d="m171 30 5 13 13 5-13 5-5 13-5-13-13-5 13-5 5-13Z" fill="#FBBF24"/>
  </svg>
  <span class:list={["text-lg font-semibold tracking-tight", textClass]}>Routine<span class="text-orange-500">Forge</span></span>
</span>
