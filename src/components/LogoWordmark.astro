---
const { dark = false, class: className = '' } = Astro.props;
const textClass = dark ? 'text-white' : 'text-slate-950';
---

<span class:list={["inline-flex items-center gap-1", className]} role="img" aria-label="RoutineForge">
  <img src="/logo-mark-display.webp" srcset="/logo-mark-display.webp 1x, /logo-mark-display@2x.webp 2x" width="40" height="40" alt="" class="h-10 w-10 shrink-0 object-contain" aria-hidden="true" />
  <span class:list={["-ml-1 text-lg font-semibold tracking-tight", textClass]}>outineForge</span>
</span>
