---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Marquee from '../components/Marquee.astro';
import LiveDemoCard from '../components/LiveDemoCard.astro';
import Testimonials from '../components/Testimonials.astro';
import ROICalculator from '../components/ROICalculator.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    icon: 'phone',
    title: 'AI Phone Agent',
    description: 'Human-like voice agents that answer calls day and night, book appointments, and route priority requests without delays.',
    bullets: ['24/7 phone coverage', 'Appointment booking', 'FAQ responses', 'CRM calendar sync']
  },
  {
    icon: 'chat',
    title: 'AI Chatbots',
    description: 'Assist customers instantly across Instagram, WhatsApp, Messenger, and your website with a consistent brand voice.',
    bullets: ['Multi-channel support', 'Lead capture', 'Order tracking', 'Team handoff']
  },
  {
    icon: 'workflow',
    title: 'Workflow Automation',
    description: 'Automate repetitive operations so your team spends less time on admin and more time growing the business.',
    bullets: ['CRM syncing', 'Email automation', 'Lead routing', 'Invoice workflows']
  },
  {
    icon: 'custom',
    title: 'Custom AI Systems',
    description: 'Tailored solutions for specialized processes, document handling, and internal operations that need precision.',
    bullets: ['Custom logic', 'Secure integrations', 'Process mapping', 'Scalable deployment']
  }
];

const benefits = [
  'Always-on support for missed calls and late-night inquiries',
  'Lower admin cost without sacrificing service quality',
  'Faster response times across phone, chat, and email',
  'Consistent lead capture and qualification',
  'A premium experience that scales with your growth'
];

const stats = [
  { countTo: 95, suffix: '%', label: 'Faster response time' },
  { countTo: 70, suffix: '%', label: 'Reduced admin work' },
  { value: '24/7', label: 'Availability' },
  { countTo: 5, suffix: '×', label: 'More qualified leads' }
];

const faqItems = [
  {
    question: 'How long does implementation take?',
    answer: 'Most projects move from discovery to launch within 2–4 weeks, depending on the complexity of your workflows and integrations.'
  },
  {
    question: 'Can AI answer phone calls naturally?',
    answer: 'Yes. Our voice agents are designed to sound calm, clear, and natural while handling scheduling, FAQs, and routing requests.'
  },
  {
    question: 'Can it integrate with my CRM?',
    answer: 'We connect with common CRMs, calendars, email systems, and business tools to keep your operations synced.'
  },
  {
    question: 'Can customers still talk to humans?',
    answer: 'Absolutely. The experience can be designed to hand off to staff when a call needs a human touch.'
  },
  {
    question: 'How secure is the system?',
    answer: 'We build with privacy, access controls, and secure integrations in mind, and we can align with your internal compliance requirements.'
  }
];

const testimonials = [
  {
    name: 'Dr. Elena Marsh',
    role: 'Owner, Brightview Dental',
    initials: 'EM',
    quote: 'CortexFlow\u2019s AI phone agent cut our missed calls in half in the first month. Patients love how fast they get a callback.',
    stat: '50% fewer missed calls'
  },
  {
    name: 'James Okafor',
    role: 'Broker, Northgate Realty',
    initials: 'JO',
    quote: 'Leads used to sit in our inbox for hours. Now the AI qualifies them and books a viewing within minutes.',
    stat: '3x faster lead response'
  },
  {
    name: 'Priya Chandran',
    role: 'GM, Marlowe Hotel & Suites',
    initials: 'PC',
    quote: 'Our front desk team finally has room to breathe. Routine questions and reservations are handled instantly, day or night.',
    stat: '24/7 guest support'
  },
  {
    name: 'Tom Bianchi',
    role: 'Founder, Bianchi Leather Co.',
    initials: 'TB',
    quote: 'The WhatsApp bot handles half our order questions before a human ever sees them. It paid for itself in the first week.',
    stat: '40% fewer support tickets'
  },
  {
    name: 'Sara Whitfield',
    role: 'Partner, Whitfield & Cole Law',
    initials: 'SW',
    quote: 'Client intake used to be our biggest bottleneck. Now it runs itself, and nothing falls through the cracks.',
    stat: '2 weeks to launch'
  }
];

const industries = [
  {
    name: 'Dental Practices',
    icon: '🦷',
    description: 'Handle appointment scheduling, answer patient questions about procedures, and reduce no-shows with automated reminders.'
  },
  {
    name: 'Veterinary Clinics',
    icon: '🐾',
    description: 'Manage pet appointments, answer routine health questions, and send follow-up care instructions automatically.'
  },
  {
    name: 'E-Commerce',
    icon: '🛒',
    description: 'Process orders, handle returns and refunds, and provide order tracking updates without human involvement.'
  },
  {
    name: 'Instagram Shops',
    icon: '📸',
    description: 'Answer product questions, process DM inquiries, and send product recommendations based on customer interests.'
  },
  {
    name: 'Law Firms',
    icon: '⚖️',
    description: 'Schedule consultations, manage client intake, and handle routine legal inquiries in a professional manner.'
  },
  {
    name: 'Travel Agencies',
    icon: '✈️',
    description: 'Answer travel questions, manage bookings, and provide itinerary updates and flight change notifications.'
  },
  {
    name: 'Hotels',
    icon: '🏨',
    description: 'Handle reservations, answer guest questions, and manage check-in procedures and special requests.'
  },
  {
    name: 'Real Estate',
    icon: '🏠',
    description: 'Schedule property viewings, answer buyer questions, and provide property information instantly to leads.'
  }
];
---

<BaseLayout
  title="AI automation for modern businesses"
  description="CortexFlow builds AI phone agents, chatbots, and workflow automation systems that help businesses save time and never miss another customer."
  canonical="https://cortexflow.example.com"
  lang="en"
>
  <div id="top" class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(125,211,252,0.16),_transparent_22%),linear-gradient(135deg,_#f8fbff,_#f4f7fb)]">
    <Navbar />

    <main>
      <section class="mx-auto grid max-w-7xl items-center gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-28">
        <div>
          <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-sky-100 bg-sky-50 px-3 py-1 text-sm font-medium text-sky-600 shadow-sm"><span class="h-2 w-2 animate-pulse rounded-full bg-sky-500"></span>AI automation that works while you sleep</p>
          <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">Your customers get instant answers, and your team gets their time back.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">CortexFlow helps businesses automate customer communication and repetitive operations with premium AI voice agents, chatbots, and intelligent workflows.</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href="#contact">Book a free consultation</Button>
            <Button href="#services" variant="secondary">See our services</Button>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white/80 p-6 shadow-[0_30px_90px_-20px_rgba(15,23,42,0.25)] backdrop-blur-xl sm:p-8">
          <LiveDemoCard
            messages={[
              { sender: 'customer', text: '“Book a consultation for Friday.”' },
              { sender: 'ai', text: '“I have a few slots open — what time works best?”' },
              { sender: 'customer', text: '“2 PM works great.”' },
              { sender: 'ai', text: '“Perfect, you’re booked for Friday at 2 PM.”' }
            ]}
            statusItems={['CRM updated', 'Calendar booked', 'Email sent']}
          />
        </div>
      </section>

      <Marquee items={['AI Phone Agent', 'AI Chatbots', 'Workflow Automation', 'Custom AI Systems', 'CRM Integrations', 'WhatsApp AI']} />

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
          <SectionHeading title="Why modern businesses choose CortexFlow" eyebrow="Trusted by growing teams" />
          <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
            {benefits.map((benefit) => (
              <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-sm leading-7 text-slate-600">
                {benefit}
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="services" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Services designed for speed, clarity, and growth" eyebrow="Core services" />
        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {services.map((service, index) => (
            <div data-reveal style={`--reveal-delay: ${Math.min(index, 4) * 100}ms`}>
              <ServiceCard title={service.title} description={service.description} bullets={service.bullets} icon={service.icon} />
            </div>
          ))}
        </div>
      </section>

      <section id="industries" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Industries we serve" eyebrow="Tailored solutions" align="center" />
        <div class="mx-auto mt-10 max-w-4xl space-y-4">
          {industries.map((industry, index) => (
            <div data-reveal style={`--reveal-delay: ${Math.min(index, 5) * 80}ms`} class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm cursor-pointer overflow-hidden transition-all duration-300 hover:shadow-lg">
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                  <span class="text-3xl">{industry.icon}</span>
                  <span class="font-semibold text-slate-950">{industry.name}</span>
                </div>
                <span class="text-xl text-slate-400 transition group-hover:rotate-45">+</span>
              </div>
              <p class="mt-0 max-h-0 overflow-hidden text-sm leading-6 text-slate-600 transition-all duration-300 group-hover:mt-4 group-hover:max-h-96">{industry.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-slate-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.3)] sm:p-10">
          <SectionHeading title="What changes when your operations are automated" eyebrow="Why CortexFlow" align="center" />
          <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">24/7</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Never miss leads or late-night inquiries again.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Fast</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Instant replies and smoother handoffs for every request.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Secure</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Reliable integrations and a clear path to scale.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Custom</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Solutions tailored to your business, not generic scripts.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="process" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="How the implementation works" eyebrow="Simple process" />
        <div class="mx-auto mt-10 max-w-4xl space-y-3" data-process-accordion>
          {['Discovery', 'Strategy', 'Implementation', 'Optimization'].map((step, index) => (
            <details data-process-step open={index === 0} data-reveal style={`--reveal-delay: ${index * 100}ms`} class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition open:border-sky-200 open:shadow-md">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 text-left sm:p-6">
                <span class="flex items-center gap-4"><span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sm font-semibold text-sky-700">0{index + 1}</span><span class="text-lg font-semibold text-slate-950">{step}</span></span>
                <span class="text-2xl leading-none text-slate-400 transition-transform duration-300 group-open:rotate-45 group-open:text-sky-700">+</span>
              </summary>
              <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 group-open:grid-rows-[1fr]"><div class="overflow-hidden"><p class="border-t border-slate-100 px-5 py-5 text-sm leading-7 text-slate-600 sm:px-6">We map your communication goals, define the ideal experience, and launch a system that improves with every interaction.</p></div></div>
            </details>
          ))}
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="grid gap-6 rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-10 lg:grid-cols-[0.7fr_1.3fr]">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-700">Results</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">The numbers behind faster, smarter operations</h2>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {stats.map((stat) => (
              <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
                <p class="text-4xl font-semibold text-slate-950">
                  {stat.countTo ? (
                    <span data-counter data-target={stat.countTo} data-suffix={stat.suffix}>0{stat.suffix}</span>
                  ) : (
                    stat.value
                  )}
                </p>
                <p class="mt-2 text-sm font-medium text-slate-600">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="testimonials" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <Testimonials testimonials={testimonials} />
      </section>

      <section id="faq" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Frequently asked questions" eyebrow="FAQ" />
        <div class="mt-10 space-y-4">
          {faqItems.map((item, index) => (
            <details data-reveal style={`--reveal-delay: ${Math.min(index, 4) * 80}ms`} class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-base font-semibold text-slate-950">
                <span>{item.question}</span>
                <span class="text-xl text-slate-400 transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="roi" class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal>
          <ROICalculator />
        </div>
      </section>

      <section id="contact" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-gradient-to-br from-slate-950 via-slate-900 to-sky-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.4)] sm:p-10">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">Contact</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">Let’s build your AI workforce.</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">Tell us about your business and we’ll map the right automation strategy for your team.</p>
          </div>
          <form class="mt-8 grid gap-4 md:grid-cols-2">
            <input class="rounded-2xl border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-slate-400 outline-none ring-0" type="text" placeholder="Name" aria-label="Name" />
            <input class="rounded-2xl border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-slate-400 outline-none ring-0" type="email" placeholder="Email" aria-label="Email" />
            <input class="rounded-2xl border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-slate-400 outline-none ring-0" type="text" placeholder="Company" aria-label="Company" />
            <input class="rounded-2xl border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-slate-400 outline-none ring-0" type="tel" placeholder="Phone" aria-label="Phone" />
            <textarea class="md:col-span-2 min-h-32 rounded-2xl border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-slate-400 outline-none ring-0" placeholder="Tell us about the challenge you want to solve." aria-label="Message"></textarea>
            <div class="md:col-span-2">
              <Button href="mailto:hello@cortexflow.ai" class="w-full justify-center">Book my free consultation</Button>
            </div>
          </form>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('[data-process-accordion]').forEach((accordion) => {
    accordion.querySelectorAll('[data-process-step]').forEach((step) => {
      step.addEventListener('toggle', () => {
        if (step.open) accordion.querySelectorAll('[data-process-step]').forEach((other) => { if (other !== step) other.open = false; });
      });
    });
  });
</script>
