---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Marquee from '../components/Marquee.astro';
import LiveDemoCard from '../components/LiveDemoCard.astro';
import Testimonials from '../components/Testimonials.astro';
import ROICalculator from '../components/ROICalculator.astro';
import MultiStepContactForm from '../components/MultiStepContactForm.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    icon: 'phone',
    title: 'AI Phone Agent',
    description: 'Answer every call, qualify the lead, and book directly into your calendar — even after hours.',
    bullets: ['24/7 phone coverage', 'Appointment booking', 'FAQ responses', 'CRM calendar sync'],
    bestFor: 'Clinics, hotels, service businesses, and teams losing calls when staff are busy.'
  },
  {
    icon: 'chat',
    title: 'AI Chatbots',
    description: 'Turn website, WhatsApp, and Instagram conversations into qualified leads without leaving anyone waiting.',
    bullets: ['Multi-channel support', 'Lead capture', 'Order tracking', 'Team handoff'],
    bestFor: 'Businesses with high message volume, product questions, or leads that expect an instant reply.'
  },
  {
    icon: 'workflow',
    title: 'Workflow Automation',
    description: 'Remove the manual handoffs that slow your team down and let routine follow-up happen automatically.',
    bullets: ['CRM syncing', 'Email automation', 'Lead routing', 'Invoice workflows'],
    bestFor: 'Teams juggling spreadsheets, inboxes, and repetitive admin work every day.'
  },
  {
    icon: 'custom',
    title: 'Custom AI Systems',
    description: 'Build a reliable AI system around your process instead of forcing your business into a generic tool.',
    bullets: ['Custom logic', 'Secure integrations', 'Process mapping', 'Scalable deployment'],
    bestFor: 'Complex operations, internal workflows, and businesses with unique systems or data.'
  }
];

const processSteps = [
  {
    title: 'Audit the opportunity',
    description: 'We start with the business bottleneck, not a tool. Together we identify where leads, time, and revenue are being lost.',
    bullets: ['Map missed calls, slow responses, and manual handoffs', 'Define one measurable business outcome', 'Identify the first workflow worth automating'],
    outcome: 'You leave with a clear priority — not a generic AI pitch.',
    meta: '60-minute discovery call'
  },
  {
    title: 'Design the AI blueprint',
    description: 'We turn the opportunity into a practical system your team can trust and operate.',
    bullets: ['Choose the right channels: phone, chat, WhatsApp, or email', 'Map CRM, calendar, and human handoff rules', 'Set success metrics before anything is built'],
    outcome: 'A simple rollout plan built around your current tools.',
    meta: 'Clear scope, timeline, and ownership'
  },
  {
    title: 'Build, test, and launch',
    description: 'We build the workflow, connect your tools, and test real scenarios before it reaches customers.',
    bullets: ['Configure conversations, automations, and integrations', 'Test edge cases with your team', 'Launch with clear escalation paths for humans'],
    outcome: 'A production-ready system that fits your operations.',
    meta: 'First workflow live in 2–4 weeks'
  },
  {
    title: 'Measure and improve',
    description: 'Launch is the start. We review what the system is doing, then refine it around real customer behaviour.',
    bullets: ['Track response speed, bookings, and handoffs', 'Review conversations and missed opportunities', 'Improve prompts, workflows, and integrations over time'],
    outcome: 'A system that keeps improving as your business grows.',
    meta: 'Ongoing optimisation and support'
  }
];

const benefits = [
  { title: 'Always on', text: 'Support for missed calls and late-night inquiries, without extending your team’s working hours.' },
  { title: 'More time for people', text: 'Lower admin workload without sacrificing the service quality customers remember.' },
  { title: 'Fast, everywhere', text: 'Faster first responses across phone, chat, email, and the channels your customers prefer.' },
  { title: 'Every lead captured', text: 'Consistent qualification and follow-up, so promising conversations do not disappear.' },
  { title: 'Built to scale', text: 'A premium customer experience that keeps working as inquiry volume and your team grow.' }
];

const stats = [
  { countTo: 95, suffix: '%', label: 'Faster response time' },
  { countTo: 70, suffix: '%', label: 'Reduced admin work' },
  { value: '24/7', label: 'Availability' },
  { countTo: 5, suffix: '×', label: 'More qualified leads' }
];

const faqItems = [
  {
    question: 'What does CortexFlow build?',
    answer: 'We design AI phone agents, chatbots, workflow automation, and custom AI systems for customer communication and internal operations. Each engagement can start with one system or connect into a larger automation roadmap.'
  },
  {
    question: 'How long does an AI system take to launch?',
    answer: 'A focused first system typically takes two to four weeks from discovery to launch. Timing depends on the number of channels, integrations, and the complexity of the workflow.'
  },
  {
    question: 'How is a project priced?',
    answer: 'Pricing is based on the system’s scope and the work needed to connect it reliably to your process. The first consultation is free; afterwards you receive a clear recommendation and proposal before committing.'
  },
  {
    question: 'Which AI models do you use?',
    answer: 'We select the right combination of modern AI models and tools for each job. The focus is not on a model name, but on building a reliable workflow that is safe, useful, and maintainable for your team.'
  },
  {
    question: 'Where can an AI assistant work?',
    answer: 'It can work on your website, phone line, WhatsApp, Instagram, email, calendar, or inside internal business tools. We start with the channel where response speed matters most.'
  },
  {
    question: 'Can the AI communicate in Serbian and English?',
    answer: 'Yes. We can build customer conversations in Serbian, English, or both, then adapt the language and tone to how your customers actually ask questions.'
  },
  {
    question: 'Can it respond through WhatsApp, Instagram, and Facebook?',
    answer: 'Yes. A customer-facing system can be configured for the messaging channels that fit your business, capturing details, answering routine questions, and routing qualified conversations to your team.'
  },
  {
    question: 'How does the AI collect lead details?',
    answer: 'It guides the conversation with relevant questions, then sends the answers to your CRM, calendar, spreadsheet, or another approved system so the next step is not lost in an inbox.'
  },
  {
    question: 'Can it work with the software we already use?',
    answer: 'Usually, yes. We assess your current tools and available integrations first, then design the AI around what already works instead of asking you to replace everything.'
  },
  {
    question: 'What if we do not have a CRM yet?',
    answer: 'That is common. We can recommend a practical place for leads, conversations, and follow-ups to live before adding more automation, so your team has one reliable source of truth.'
  },
  {
    question: 'Which business tasks can be automated?',
    answer: 'Common examples include lead routing, follow-up messages, appointment reminders, FAQ replies, CRM updates, reporting, invoices, and internal handoffs. We begin with the repetitive task that has the clearest return.'
  },
  {
    question: 'Can AI handle phone calls?',
    answer: 'For suitable use cases, an AI phone agent can answer common questions, qualify callers, collect details, book appointments, and route a call to a person when required.'
  },
  {
    question: 'Will you train our team?',
    answer: 'Yes. We introduce the workflow, show your team when and how to take over a conversation, and make sure the people using the system understand what it can do.'
  },
  {
    question: 'What is an internal AI agent?',
    answer: 'It is an AI assistant that helps employees with repeatable internal work, such as finding information, preparing drafts, updating systems, or moving a task through a defined process.'
  },
  {
    question: 'What happens if the AI is unsure or makes a mistake?',
    answer: 'We define boundaries, test real scenarios, and build human handoffs into the workflow. The AI does not need to guess: it can request more information or pass the case to your team.'
  },
  {
    question: 'What support do we get after launch?',
    answer: 'We review early performance, refine the workflow, and support your team as the system becomes part of daily operations. The goal is an automation that keeps improving with your business.'
  }
];

const testimonials = [
  {
    name: 'Dr. Elena Marsh',
    role: 'Owner, Brightview Dental',
    initials: 'EM',
    quote: 'CortexFlow\u2019s AI phone agent cut our missed calls in half in the first month. Patients love how fast they get a callback.',
    stat: '50% fewer missed calls'
  },
  {
    name: 'James Okafor',
    role: 'Broker, Northgate Realty',
    initials: 'JO',
    quote: 'Leads used to sit in our inbox for hours. Now the AI qualifies them and books a viewing within minutes.',
    stat: '3x faster lead response'
  },
  {
    name: 'Priya Chandran',
    role: 'GM, Marlowe Hotel & Suites',
    initials: 'PC',
    quote: 'Our front desk team finally has room to breathe. Routine questions and reservations are handled instantly, day or night.',
    stat: '24/7 guest support'
  },
  {
    name: 'Tom Bianchi',
    role: 'Founder, Bianchi Leather Co.',
    initials: 'TB',
    quote: 'The WhatsApp bot handles half our order questions before a human ever sees them. It paid for itself in the first week.',
    stat: '40% fewer support tickets'
  },
  {
    name: 'Sara Whitfield',
    role: 'Partner, Whitfield & Cole Law',
    initials: 'SW',
    quote: 'Client intake used to be our biggest bottleneck. Now it runs itself, and nothing falls through the cracks.',
    stat: '2 weeks to launch'
  }
];

const industries = [
  {
    name: 'Dental Practices',
    icon: '🦷',
    problem: 'Missed calls, delayed bookings, and empty appointment slots from no-shows.',
    system: 'AI receptionist with calendar booking and automated appointment reminders.',
    result: 'Fewer empty slots and a faster path from inquiry to appointment.'
  },
  {
    name: 'Veterinary Clinics',
    icon: '🐾',
    problem: 'Teams are interrupted by routine care questions and appointment requests.',
    system: 'AI intake agent, care reminders, and follow-up workflows for pet owners.',
    result: 'Faster responses while the clinical team stays focused on care.'
  },
  {
    name: 'E-Commerce',
    icon: '🛒',
    problem: 'Support teams repeat the same order, return, and delivery answers all day.',
    system: 'AI shopping assistant with order tracking, return flows, and proactive follow-up.',
    result: 'More completed orders and fewer repetitive support tickets.'
  },
  {
    name: 'Instagram Shops',
    icon: '📸',
    problem: 'Sales opportunities disappear when DMs wait for a reply.',
    system: 'AI DM assistant that answers product questions and captures qualified buyers.',
    result: 'Every inquiry gets an immediate response — even outside business hours.'
  },
  {
    name: 'Law Firms',
    icon: '⚖️',
    problem: 'Initial consultations and document requests consume valuable legal time.',
    system: 'Structured AI intake, consultation scheduling, and matter-routing automation.',
    result: 'Better-qualified inquiries and more time for billable legal work.'
  },
  {
    name: 'Travel Agencies',
    icon: '✈️',
    problem: 'Travelers choose the agency that responds first to availability questions.',
    system: 'AI travel assistant across web and messaging with itinerary updates and lead follow-up.',
    result: 'Faster first responses and fewer promising travelers going cold.'
  },
  {
    name: 'Hotels',
    icon: '🏨',
    problem: 'Reservation questions and guest requests overload the front desk.',
    system: 'AI concierge for bookings, FAQs, check-in guidance, and guest requests.',
    result: 'Guests get help faster while staff can focus on the in-person experience.'
  },
  {
    name: 'Real Estate',
    icon: '🏠',
    problem: 'Agents spend time on unqualified listing inquiries and missed follow-ups.',
    system: 'AI lead qualifier that answers listing questions and books viewings automatically.',
    result: 'Agents spend more time with serious buyers and sellers.'
  }
];
---

<BaseLayout
  title="AI automation for modern businesses"
  description="CortexFlow builds AI phone agents, chatbots, and workflow automation systems that help businesses save time and never miss another customer."
  canonical="https://cortexflow.example.com"
  lang="en"
>
  <div id="top" class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(125,211,252,0.16),_transparent_22%),linear-gradient(135deg,_#f8fbff,_#f4f7fb)]">
    <Navbar />

    <main>
      <section class="mx-auto grid max-w-7xl items-center gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-28">
        <div>
          <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-sky-100 bg-sky-50 px-3 py-1 text-sm font-medium text-sky-600 shadow-sm"><span class="h-2 w-2 animate-pulse rounded-full bg-sky-500"></span>AI automation that works while you sleep</p>
          <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">Stop losing leads after hours. Let AI qualify, book, and follow up — automatically.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">Turn every call, message, and inquiry into a fast, consistent customer experience — while your team focuses on the work only people can do.</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href="#contact">Book a free consultation</Button>
            <Button href="#services" variant="secondary">See our services</Button>
          </div>
          <div class="mt-8 flex flex-wrap gap-2 text-sm font-medium text-slate-600">
            <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-2 shadow-sm ring-1 ring-slate-200"><span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span>Replies to leads in seconds</span>
            <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-2 shadow-sm ring-1 ring-slate-200"><span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span>Books into your calendar</span>
            <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-2 shadow-sm ring-1 ring-slate-200"><span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span>Human handoff when needed</span>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white/80 p-6 shadow-[0_30px_90px_-20px_rgba(15,23,42,0.25)] backdrop-blur-xl sm:p-8">
          <LiveDemoCard
            messages={[
              { sender: 'customer', text: '“Book a consultation for Friday.”' },
              { sender: 'ai', text: '“I have a few slots open — what time works best?”' },
              { sender: 'customer', text: '“2 PM works great.”' },
              { sender: 'ai', text: '“Perfect, you’re booked for Friday at 2 PM.”' }
            ]}
            statusItems={['CRM updated', 'Calendar booked', 'Email sent']}
          />
        </div>
      </section>

      <Marquee items={['AI Phone Agent', 'AI Chatbots', 'Workflow Automation', 'Custom AI Systems', 'CRM Integrations', 'WhatsApp AI']} />

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
          <SectionHeading title="Why modern businesses choose CortexFlow" eyebrow="Trusted by growing teams" />
          <div class="mt-8 grid gap-5 lg:grid-cols-[0.85fr_1.15fr]">
            <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-slate-950 via-slate-900 to-sky-950 p-7 text-white sm:p-8">
              <div class="absolute -right-12 -top-12 h-44 w-44 rounded-full bg-sky-400/20 blur-3xl" aria-hidden="true"></div>
              <div class="relative flex h-full flex-col justify-between">
                <div><p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-300">Designed for the handoff</p><h3 class="mt-3 text-2xl font-semibold tracking-tight">AI handles the repeatable work. Your team handles the human work.</h3><p class="mt-4 leading-7 text-slate-300">Every system is designed around one goal: create a faster, clearer path from a first inquiry to a real customer conversation.</p></div>
                <div class="mt-8 flex items-center gap-3 text-sm font-medium text-sky-100"><span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-sky-300/40 bg-sky-400/10">✓</span>Connected to your existing workflow</div>
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              {benefits.map((benefit, index) => (
              <div class:list={["group rounded-2xl border border-slate-200 bg-slate-50 p-5 transition duration-300 hover:-translate-y-1 hover:border-sky-200 hover:bg-white hover:shadow-lg", index === 4 && 'sm:col-span-2']}>
                <div class="flex items-center justify-between gap-3"><span class="text-xs font-semibold tracking-[0.16em] text-sky-700">0{index + 1}</span><span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-sky-200 bg-sky-50 text-sm font-semibold text-sky-700 transition group-hover:bg-sky-600 group-hover:text-white">✓</span></div>
                <h3 class="mt-5 font-semibold text-slate-950">{benefit.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600">{benefit.text}</p>
              </div>
            ))}
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Services designed for speed, clarity, and growth" eyebrow="Core services" />
        <div class="mt-10 grid gap-6 lg:auto-rows-fr lg:grid-cols-2">
          {services.map((service, index) => (
            <div data-reveal style={`--reveal-delay: ${Math.min(index, 4) * 100}ms`}>
              <ServiceCard title={service.title} description={service.description} bullets={service.bullets} bestFor={service.bestFor} icon={service.icon} />
            </div>
          ))}
        </div>
      </section>

      <section id="industries" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Industries we serve" eyebrow="Tailored solutions" align="center" />
        <p class="mx-auto mt-4 max-w-2xl text-center text-lg leading-8 text-slate-600">Every system starts with a real operational bottleneck — then connects the right AI workflow to an outcome your team can track.</p>
        <div class="mx-auto mt-10 grid max-w-6xl gap-5 md:grid-cols-2">
          {industries.map((industry, index) => (
            <article data-reveal style={`--reveal-delay: ${Math.min(index, 5) * 80}ms`} class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-sky-200 hover:shadow-xl sm:p-7">
              <div class="flex items-center gap-3 border-b border-slate-100 pb-5">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-sky-50 text-2xl ring-1 ring-sky-100">{industry.icon}</span>
                <h3 class="text-lg font-semibold text-slate-950">{industry.name}</h3>
              </div>
              <dl class="mt-5 space-y-4 text-sm leading-6">
                <div><dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Problem</dt><dd class="mt-1 text-slate-600">{industry.problem}</dd></div>
                <div class="border-l-2 border-sky-200 pl-4"><dt class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-600">AI system</dt><dd class="mt-1 font-medium text-slate-700">{industry.system}</dd></div>
                <div class="rounded-2xl bg-emerald-50 px-4 py-3"><dt class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald-700">Result</dt><dd class="mt-1 font-medium text-emerald-950">{industry.result}</dd></div>
              </dl>
            </article>
          ))}
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-slate-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.3)] sm:p-10">
          <SectionHeading title="What changes when your operations are automated" eyebrow="Why CortexFlow" align="center" dark />
          <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">24/7</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Never miss leads or late-night inquiries again.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Fast</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Instant replies and smoother handoffs for every request.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Secure</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Reliable integrations and a clear path to scale.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Custom</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Solutions tailored to your business, not generic scripts.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="process" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="How the implementation works" eyebrow="Simple process" />
        <div class="mx-auto mt-10 max-w-4xl space-y-3" data-process-accordion>
          {processSteps.map((step, index) => (
            <details data-process-step open={index === 0} data-reveal style={`--reveal-delay: ${index * 100}ms`} class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition open:border-sky-200 open:shadow-md">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 text-left sm:p-6">
                <span class="flex items-center gap-4"><span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sm font-semibold text-sky-700">0{index + 1}</span><span><span class="block text-[11px] font-semibold uppercase tracking-[0.18em] text-sky-700">Phase 0{index + 1}</span><span class="mt-1 block text-lg font-semibold text-slate-950">{step.title}</span></span></span>
                <span class="text-2xl leading-none text-slate-400 transition-transform duration-300 group-open:rotate-45 group-open:text-sky-700">+</span>
              </summary>
              <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 group-open:grid-rows-[1fr]"><div class="overflow-hidden border-t border-slate-100 px-5 py-5 sm:px-6"><p class="text-sm leading-7 text-slate-600">{step.description}</p><ul class="mt-4 space-y-2 text-sm leading-6 text-slate-600">{step.bullets.map((bullet) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-sky-500"></span>{bullet}</li>)}</ul><div class="mt-5 flex flex-wrap items-center gap-3 rounded-xl bg-sky-50 px-4 py-3"><span class="text-xs font-semibold uppercase tracking-wide text-sky-700">Outcome</span><span class="text-sm font-medium text-slate-700">{step.outcome}</span></div><p class="mt-4 text-sm font-semibold text-emerald-700">{step.meta}</p></div></div>
            </details>
          ))}
        </div>
        <div data-reveal class="mx-auto mt-8 max-w-4xl border-t border-sky-200 pt-8">
          <div class="flex flex-col gap-5 rounded-2xl border border-sky-200 bg-sky-50 p-6 sm:flex-row sm:items-center sm:justify-between">
            <div><p class="text-sm font-semibold text-sky-700">Ready for the next step?</p><h3 class="mt-1 text-xl font-semibold tracking-tight text-slate-950">Let’s map the process that matters most to your business.</h3></div>
            <Button href="#contact" class="shrink-0">Book a consultation</Button>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="relative overflow-hidden rounded-[2rem] border border-sky-400/20 bg-slate-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.45)] sm:p-10">
          <div class="absolute -right-24 -top-28 h-72 w-72 rounded-full bg-sky-400/15 blur-3xl" aria-hidden="true"></div>
          <div class="relative grid gap-8 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">Proof, not promises</p>
              <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white">The numbers behind faster, smarter operations</h2>
              <p class="mt-4 max-w-md leading-7 text-slate-300">We design systems around the bottlenecks your team can see — and the improvements you can measure.</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              {stats.map((stat) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-sky-300/50 hover:bg-sky-400/10">
                  <p class="text-4xl font-semibold text-sky-300">
                    {stat.countTo ? (
                      <span data-counter data-target={stat.countTo} data-suffix={stat.suffix}>0{stat.suffix}</span>
                    ) : (
                      stat.value
                    )}
                  </p>
                  <p class="mt-2 text-sm font-medium text-slate-300">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="testimonials" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <Testimonials testimonials={testimonials} />
      </section>

      <section id="faq" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Frequently asked questions" eyebrow="FAQ" />
        <div class="mt-10 space-y-4">
          {faqItems.map((item, index) => (
            <details data-reveal style={`--reveal-delay: ${Math.min(index, 4) * 80}ms`} class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-base font-semibold text-slate-950">
                <span>{item.question}</span>
                <span class="text-xl text-slate-400 transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="roi" class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal>
          <ROICalculator />
        </div>
      </section>

      <section id="contact" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-gradient-to-br from-slate-950 via-slate-900 to-sky-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.4)] sm:p-10">
          <div class="max-w-3xl">
            <p class="inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-sm font-semibold text-sky-300">Contact</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">Let’s build your AI workforce.</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">Tell us about your business and we’ll map the right automation strategy for your team.</p>
          </div>
          <MultiStepContactForm
            industries={industries}
            services={services}
            labels={{
              step: 'Step', of: 'of', industryTitle: 'What type of business do you run?', serviceTitle: 'What are you interested in?', detailsTitle: 'How can we reach you?', next: 'Continue', back: 'Back', submit: 'Send consultation request', name: 'Name', email: 'Email', phone: 'Phone', message: 'Tell us about the challenge you want to solve.', success: 'Thanks — we will be in touch shortly.'
            }}
          />
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('[data-process-accordion]').forEach((accordion) => {
    accordion.querySelectorAll('[data-process-step]').forEach((step) => {
      step.addEventListener('toggle', () => {
        if (step.open) accordion.querySelectorAll('[data-process-step]').forEach((other) => { if (other !== step) other.open = false; });
      });
    });
  });
</script>
