---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Marquee from '../components/Marquee.astro';
import LiveDemoCard from '../components/LiveDemoCard.astro';
import Testimonials from '../components/Testimonials.astro';
import ROICalculator from '../components/ROICalculator.astro';
import MultiStepContactForm from '../components/MultiStepContactForm.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    icon: 'phone',
    title: 'AI telefonski agent',
    description: 'Odgovara na svaki poziv, kvalifikuje lead i zakazuje direktno u kalendar — čak i van radnog vremena.',
    bullets: ['Pokrivenost telefona 24/7', 'Zakazivanje termina', 'Odgovori na česta pitanja', 'Sinhronizacija sa CRM-om i kalendarom'],
    bestFor: 'Klinike, hotele, servisne biznise i timove koji gube pozive dok je osoblje zauzeto.'
  },
  {
    icon: 'chat',
    title: 'AI čatbotovi',
    description: 'Pretvaraju razgovore sa sajta, WhatsAppa i Instagrama u kvalifikovane leadove bez čekanja.',
    bullets: ['Podrška na više kanala', 'Prikupljanje leadova', 'Praćenje porudžbina', 'Predaja timu'],
    bestFor: 'Biznise sa velikim brojem poruka, pitanjima o proizvodima ili leadovima koji očekuju trenutni odgovor.'
  },
  {
    icon: 'workflow',
    title: 'Automatizacija tokova rada',
    description: 'Uklanja ručne predaje koje usporavaju tim i omogućava da se rutinski follow-up odvija automatski.',
    bullets: ['Sinhronizacija CRM-a', 'Email automatizacija', 'Usmeravanje leadova', 'Automatizacija računa'],
    bestFor: 'Timove koji svakodnevno kombinuju tabele, inboxe i ponavljajući administrativni posao.'
  },
  {
    icon: 'custom',
    title: 'Prilagođena AI rešenja',
    description: 'Gradi pouzdan AI sistem oko vašeg procesa, umesto da posao prilagođavate generičkom alatu.',
    bullets: ['Prilagođena logika', 'Sigurne integracije', 'Mapiranje procesa', 'Skalabilno lansiranje'],
    bestFor: 'Složene operacije, interne tokove rada i biznise sa jedinstvenim sistemima ili podacima.'
  }
];

const processSteps = [
  {
    title: 'Audit prilike',
    description: 'Počinjemo od poslovnog uskog grla, a ne od alata. Zajedno otkrivamo gde se gube leadovi, vreme i prihod.',
    bullets: ['Mapiramo propuštene pozive, spore odgovore i ručne predaje', 'Definišemo jedan merljiv poslovni rezultat', 'Biramo prvi workflow koji vredi automatizovati'],
    outcome: 'Dobijate jasan prioritet, a ne generičku AI ponudu.',
    meta: 'Besplatna konsultacija od 60 minuta'
  },
  {
    title: 'AI blueprint',
    description: 'Priliku pretvaramo u praktičan sistem kome vaš tim može da veruje i koji može da koristi.',
    bullets: ['Biramo kanale: telefon, chat, WhatsApp ili email', 'Mapiramo CRM, kalendar i pravila za predaju čoveku', 'Postavljamo metrike uspeha pre početka izrade'],
    outcome: 'Jednostavan plan lansiranja oko vaših postojećih alata.',
    meta: 'Jasan obim, rokovi i odgovornosti'
  },
  {
    title: 'Izrada, testiranje i lansiranje',
    description: 'Gradimo workflow, povezujemo alate i testiramo realne scenarije pre nego što sistem dođe do klijenata.',
    bullets: ['Povezujemo razgovore, automatizacije i integracije', 'Testiramo rubne slučajeve sa vašim timom', 'Lansiramo uz jasne trenutke za preuzimanje od strane ljudi'],
    outcome: 'Sistem spreman za produkciju, prilagođen vašem poslovanju.',
    meta: 'Prvi workflow uživo za 2–4 nedelje'
  },
  {
    title: 'Merenje i unapređenje',
    description: 'Lansiranje je početak. Pratimo rad sistema i unapređujemo ga na osnovu stvarnog ponašanja klijenata.',
    bullets: ['Merimo brzinu odgovora, zakazivanja i predaje timu', 'Pregledamo razgovore i propuštene prilike', 'Unapređujemo promptove, workflowe i integracije kroz vreme'],
    outcome: 'Sistem koji postaje bolji kako vaš posao raste.',
    meta: 'Kontinuirana optimizacija i podrška'
  }
];

const benefits = [
  'Podrška 24/7 za propuštene pozive i upite van radnog vremena',
  'Niži troškovi administracije bez žrtvovanja kvaliteta usluge',
  'Brži odgovori na telefon, chat i email',
  'Dosledno prikupljanje i kvalifikacija leadova',
  'Premium iskustvo koje raste uz vaš posao'
];

const stats = [
  { countTo: 95, suffix: '%', label: 'Brži odgovor' },
  { countTo: 70, suffix: '%', label: 'Smanjena administracija' },
  { value: '24/7', label: 'Dostupnost' },
  { countTo: 5, suffix: '×', label: 'Više kvalifikovanih leadova' }
];

const faqItems = [
  {
    question: 'Koliko traje implementacija?',
    answer: 'Većina projekata se kreće od otkrivanja do pokretanja između 2–4 nedelje, zavisno od složenosti vaših tokova rada i integracija.'
  },
  {
    question: 'Može li AI odgovoritiна pozive prirodno?',
    answer: 'Da. Naši glasovni agenti su dizajnirani da zvuče mirno, jasno i prirodno dok obrađuju zakazivanje, često postavljana pitanja i rutiranje zahteva.'
  },
  {
    question: 'Može li se integrirati sa mojim CRM-om?',
    answer: 'Povezujemo se sa uobičajenim CRM-ima, kalendarima, email sistemima i poslovnim alatima kako bismo vaše operacije bili sinhronizovani.'
  },
  {
    question: 'Mogu li klijenti razgovarati sa ljudima?',
    answer: 'Apsolutno. Iskustvo može biti dizajnirano tako da se prenese timu kada poziv treba ljudski dodir.'
  },
  {
    question: 'Koliko je bezbedan sistem?',
    answer: 'Gradimo sa privatnošću, kontrolom pristupa i bezbednim integracijama u vidu, i možemo uskladiti sa vašim internim zahtevima za usklađenost.'
  }
];

const testimonials = [
  {
    name: 'Dr. Jelena Marković',
    role: 'Vlasnica, Bright Dental',
    initials: 'JM',
    quote: 'AI telefonski agent CortexFlow-a je prepolovio broj propuštenih poziva već u prvom mesecu. Pacijenti obožavaju koliko brzo dobiju povratni poziv.',
    stat: '50% manje propuštenih poziva'
  },
  {
    name: 'Nemanja Ilić',
    role: 'Broker, Nova Nekretnine',
    initials: 'NI',
    quote: 'Leadovi su ranije satima čekali u inboxu. Sada ih AI kvalifikuje i zakazuje pregled u roku od nekoliko minuta.',
    stat: '3x brži odgovor na lead'
  },
  {
    name: 'Milica Petrović',
    role: 'GM, Hotel Marlow',
    initials: 'MP',
    quote: 'Naš recepcijski tim konačno ima vremena da diše. Rutinska pitanja i rezervacije se obrađuju trenutno, danju i noću.',
    stat: '24/7 podrška gostima'
  },
  {
    name: 'Marko Radović',
    role: 'Osnivač, Radović Koža',
    initials: 'MR',
    quote: 'WhatsApp bot rešava polovinu pitanja o porudžbinama pre nego što ih iko od ljudi i vidi. Isplatio se već prve nedelje.',
    stat: '40% manje tiketa podrške'
  },
  {
    name: 'Ana Stanković',
    role: 'Partner, Stanković Advokati',
    initials: 'AS',
    quote: 'Prijem klijenata nam je ranije bio najveće usko grlo. Sada radi sam od sebe, i ništa nam ne promakne.',
    stat: '2 nedelje do lansiranja'
  }
];

const industries = [
  {
    name: 'Stomatološke ordinacije',
    icon: '🦷',
    problem: 'Propušteni pozivi, sporo zakazivanje i prazni termini zbog izostanaka.',
    system: 'AI recepcionar sa zakazivanjem u kalendar i automatskim podsetnicima.',
    result: 'Manje praznih termina i brži put od upita do zakazivanja.'
  },
  {
    name: 'Veterinarske klinike',
    icon: '🐾',
    problem: 'Rutinska pitanja vlasnika i zahtevi za termine prekidaju rad tima.',
    system: 'AI agent za prijem, podsetnici za negu i automatizovan follow-up vlasnicima.',
    result: 'Brži odgovori, dok se medicinski tim fokusira na negu ljubimaca.'
  },
  {
    name: 'Elektronska trgovina',
    icon: '🛒',
    problem: 'Tim neprestano odgovara na ista pitanja o porudžbinama, povratima i dostavi.',
    system: 'AI prodajni asistent sa praćenjem porudžbina, povratima i proaktivnim follow-upom.',
    result: 'Više završenih kupovina i manje ponavljajućih tiketa podrške.'
  },
  {
    name: 'Instagram prodavnice',
    icon: '📸',
    problem: 'Prodajne prilike nestaju kada DM poruke čekaju odgovor.',
    system: 'AI DM asistent koji odgovara na pitanja o proizvodima i prikuplja kvalifikovane kupce.',
    result: 'Svaki upit dobija brz odgovor — i van radnog vremena.'
  },
  {
    name: 'Advokatske kancelarije',
    icon: '⚖️',
    problem: 'Uvodne konsultacije i zahtevi za dokumentima troše dragoceno pravno vreme.',
    system: 'Strukturisan AI prijem klijenata, zakazivanje konsultacija i usmeravanje predmeta.',
    result: 'Kvalitetniji upiti i više vremena za naplativ pravni rad.'
  },
  {
    name: 'Turističke agencije',
    icon: '✈️',
    problem: 'Putnici biraju agenciju koja prva odgovori na pitanja o dostupnosti.',
    system: 'AI putni asistent na sajtu i kanalima za poruke, sa ažuriranjima i follow-upom.',
    result: 'Brži prvi odgovor i manje zainteresovanih putnika koji se ohlade.'
  },
  {
    name: 'Hoteli',
    icon: '🏨',
    problem: 'Pitanja oko rezervacija i zahtevi gostiju preopterećuju recepciju.',
    system: 'AI konsijerž za rezervacije, česta pitanja, prijavu i zahteve gostiju.',
    result: 'Gosti dobijaju pomoć brže, a osoblje se fokusira na iskustvo uživo.'
  },
  {
    name: 'Nekretnine',
    icon: '🏠',
    problem: 'Agenti troše vreme na nekvalifikovane upite i propuštene follow-upove.',
    system: 'AI kvalifikator leadova koji odgovara na pitanja o oglasima i zakazuje razgledanja.',
    result: 'Agenti više vremena provode sa ozbiljnim kupcima i prodavcima.'
  }
];
---

<BaseLayout
  title="AI automatizacija za moderne poslovne timove"
  description="CortexFlow gradi AI telefonske agente, čačbotove i sisteme automatizacije koji pomažu preduzećima da štede vreme i ne propuštaju klijente."
  canonical="https://cortexflow.example.com/sr"
  lang="sr"
>
  <div id="top" class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(125,211,252,0.16),_transparent_22%),linear-gradient(135deg,_#f8fbff,_#f4f7fb)]">
    <Navbar />

    <main>
      <section class="mx-auto grid max-w-7xl items-center gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-28">
        <div>
          <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-sky-100 bg-sky-50 px-3 py-1 text-sm font-medium text-sky-600 shadow-sm"><span class="h-2 w-2 animate-pulse rounded-full bg-sky-500"></span>AI automatizacija koja radi dok spavate</p>
          <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">Prestanite da gubite leadove van radnog vremena. Neka AI kvalifikuje, zakaže i isprati svaki upit — automatski.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">Pretvorite svaki poziv, poruku i upit u brzo i dosledno iskustvo za klijenta, dok se vaš tim fokusira na posao koji samo ljudi mogu da rade.</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href="#contact">Zakažite besplatnu konsultaciju</Button>
            <Button href="#services" variant="secondary">Pogledajte usluge</Button>
          </div>
          <div class="mt-8 flex flex-wrap gap-2 text-sm font-medium text-slate-600">
            <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-2 shadow-sm ring-1 ring-slate-200"><span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span>Odgovor leadovima za nekoliko sekundi</span>
            <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-2 shadow-sm ring-1 ring-slate-200"><span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span>Direktno zakazivanje u kalendar</span>
            <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-2 shadow-sm ring-1 ring-slate-200"><span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span>Preuzimanje od strane tima po potrebi</span>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white/80 p-6 shadow-[0_30px_90px_-20px_rgba(15,23,42,0.25)] backdrop-blur-xl sm:p-8">
          <LiveDemoCard
            eyebrow="Tok rada uživo"
            title="Klijent → AI agent → CRM"
            badge="24/7 aktivno"
            messages={[
              { sender: 'customer', text: '„Želim da zakažem konsultaciju za petak.“' },
              { sender: 'ai', text: '„Imam par slobodnih termina — koje vreme vam odgovara?“' },
              { sender: 'customer', text: '„14h mi odgovara.“' },
              { sender: 'ai', text: '„Odlično, zakazano je za petak u 14h.“' }
            ]}
            statusLabel="Ažuriranje sistema"
            statusItems={['CRM ažuriran', 'Termin zakazan', 'Email poslat']}
          />
        </div>
      </section>

      <Marquee items={['AI Telefonski Agent', 'AI Čatbotovi', 'Automatizacija Procesa', 'Prilagođena AI Rešenja', 'CRM Integracije', 'WhatsApp AI']} />

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
          <SectionHeading title="Zašto moderne firme biraju CortexFlow" eyebrow="Poverenje rasta" />
          <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
            {benefits.map((benefit) => (
              <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-sm leading-7 text-slate-600">
                {benefit}
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="services" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Usluge dizajnirane za brzinu, jasnoću i rast" eyebrow="Osnovne usluge" />
        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {services.map((service, index) => (
            <div data-reveal style={`--reveal-delay: ${Math.min(index, 4) * 100}ms`}>
              <ServiceCard title={service.title} description={service.description} bullets={service.bullets} bestFor={service.bestFor} bestForLabel="Idealno za" icon={service.icon} />
            </div>
          ))}
        </div>
      </section>

      <section id="industries" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
       <SectionHeading title="Industrije koje služimo" eyebrow="Prilagođena rešenja" align="center" />
       <p class="mx-auto mt-4 max-w-2xl text-center text-lg leading-8 text-slate-600">Svaki sistem počinje stvarnim operativnim uskim grlom — zatim povezujemo pravi AI tok rada sa rezultatom koji vaš tim može da prati.</p>
       <div class="mx-auto mt-10 grid max-w-6xl gap-5 md:grid-cols-2">
         {industries.map((industry, index) => (
           <article data-reveal style={`--reveal-delay: ${Math.min(index, 5) * 80}ms`} class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-sky-200 hover:shadow-xl sm:p-7">
             <div class="flex items-center gap-3 border-b border-slate-100 pb-5">
               <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-sky-50 text-2xl ring-1 ring-sky-100">{industry.icon}</span>
               <h3 class="text-lg font-semibold text-slate-950">{industry.name}</h3>
             </div>
             <dl class="mt-5 space-y-4 text-sm leading-6">
               <div><dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Problem</dt><dd class="mt-1 text-slate-600">{industry.problem}</dd></div>
               <div class="border-l-2 border-sky-200 pl-4"><dt class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-600">AI sistem</dt><dd class="mt-1 font-medium text-slate-700">{industry.system}</dd></div>
               <div class="rounded-2xl bg-emerald-50 px-4 py-3"><dt class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald-700">Rezultat</dt><dd class="mt-1 font-medium text-emerald-950">{industry.result}</dd></div>
             </dl>
           </article>
         ))}
       </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-slate-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.3)] sm:p-10">
          <SectionHeading title="Šta se menja kada su vaši procesi automatizovani" eyebrow="Zašto CortexFlow" align="center" dark />
          <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">24/7</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Više ne propuštajte pozive ni upite po izlasku iz radnog vremena.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Brzo</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Trenutni odgovori i glađi prelaz između zahteva.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Sigurno</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Pouzdane integracije i jasna putanja ka rastu.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Prilagođeno</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Rešenja prilagođena vašem poslu, a ne generički skripti.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="process" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Kako izgleda implementacija" eyebrow="Jednostavan proces" />
        <div class="mx-auto mt-10 max-w-4xl space-y-3" data-process-accordion>
          {processSteps.map((step, index) => (
            <details data-process-step open={index === 0} data-reveal style={`--reveal-delay: ${index * 100}ms`} class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition open:border-sky-200 open:shadow-md">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 text-left sm:p-6">
                <span class="flex items-center gap-4"><span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sm font-semibold text-sky-700">0{index + 1}</span><span><span class="block text-[11px] font-semibold uppercase tracking-[0.18em] text-sky-700">Faza 0{index + 1}</span><span class="mt-1 block text-lg font-semibold text-slate-950">{step.title}</span></span></span>
                <span class="text-2xl leading-none text-slate-400 transition-transform duration-300 group-open:rotate-45 group-open:text-sky-700">+</span>
              </summary>
              <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 group-open:grid-rows-[1fr]"><div class="overflow-hidden border-t border-slate-100 px-5 py-5 sm:px-6"><p class="text-sm leading-7 text-slate-600">{step.description}</p><ul class="mt-4 space-y-2 text-sm leading-6 text-slate-600">{step.bullets.map((bullet) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-sky-500"></span>{bullet}</li>)}</ul><div class="mt-5 flex flex-wrap items-center gap-3 rounded-xl bg-sky-50 px-4 py-3"><span class="text-xs font-semibold uppercase tracking-wide text-sky-700">Ishod</span><span class="text-sm font-medium text-slate-700">{step.outcome}</span></div><p class="mt-4 text-sm font-semibold text-emerald-700">{step.meta}</p></div></div>
            </details>
          ))}
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="relative overflow-hidden rounded-[2rem] border border-sky-400/20 bg-slate-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.45)] sm:p-10">
          <div class="absolute -right-24 -top-28 h-72 w-72 rounded-full bg-sky-400/15 blur-3xl" aria-hidden="true"></div>
          <div class="relative grid gap-8 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">Dokaz, ne obećanje</p>
              <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white">Brojevi iza bržih, pametnijih operacija</h2>
              <p class="mt-4 max-w-md leading-7 text-slate-300">Sisteme gradimo oko uskih grla koje vaš tim vidi — i poboljšanja koja možete da izmerite.</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              {stats.map((stat) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-sky-300/50 hover:bg-sky-400/10">
                  <p class="text-4xl font-semibold text-sky-300">
                    {stat.countTo ? (
                      <span data-counter data-target={stat.countTo} data-suffix={stat.suffix}>0{stat.suffix}</span>
                    ) : (
                      stat.value
                    )}
                  </p>
                  <p class="mt-2 text-sm font-medium text-slate-300">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="testimonials" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <Testimonials
          eyebrow="Utisci klijenata"
          title="Poverenje timova koji su automatizovali sa CortexFlow-om"
          testimonials={testimonials}
        />
      </section>

      <section id="faq" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Često postavljana pitanja" eyebrow="Česta pitanja" />
        <div class="mt-10 space-y-4">
          {faqItems.map((item, index) => (
            <details data-reveal style={`--reveal-delay: ${Math.min(index, 4) * 80}ms`} class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-base font-semibold text-slate-950">
                <span>{item.question}</span>
                <span class="text-xl text-slate-400 transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="roi" class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal>
          <ROICalculator
            eyebrow="ROI kalkulator"
            title="Vidite koliko bi vam automatizacija vredela"
            description="Pomerite klizače da odgovaraju vašem poslovanju i vidite procenu na osnovu tipičnih rezultata CortexFlow klijenata."
            currency="€"
            inquiriesLabel="Upiti klijenata mesečno"
            avgValueLabel="Prosečna vrednost rezervisanog klijenta"
            adminHoursLabel="Sati nedeljno na administraciji"
            recoveredLeadsLabel="Spašeni leadovi mesečno"
            extraRevenueLabel="Procenjen dodatni mesečni prihod"
            hoursSavedLabel="Ušteđeni sati nedeljno"
            disclaimer="Ovo su samo procene, zasnovane na tipičnim rezultatima CortexFlow klijenata. Stvarni rezultati zavise od poslovanja."
          />
        </div>
      </section>

      <section id="contact" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-gradient-to-br from-slate-950 via-slate-900 to-sky-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.4)] sm:p-10">
          <div class="max-w-3xl">
            <p class="inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-sm font-semibold text-sky-300">Kontakt</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">Izgradimo vaš AI tim.</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">Recite nam nešto o svom poslu i mi ćemo vam mapirati pravu strategiju automatizacije.</p>
          </div>
          <MultiStepContactForm
            industries={industries}
            services={services}
            labels={{
              step: 'Korak', of: 'od', industryTitle: 'Kojim tipom posla se bavite?', serviceTitle: 'Šta vas najviše zanima?', detailsTitle: 'Kako možemo da vas kontaktiramo?', next: 'Nastavi', back: 'Nazad', submit: 'Pošaljite zahtev za konsultaciju', name: 'Ime i prezime', email: 'Email', phone: 'Telefon', message: 'Recite nam koji problem želite da rešite.', success: 'Hvala — javićemo vam se uskoro.'
            }}
          />
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('[data-process-accordion]').forEach((accordion) => {
    accordion.querySelectorAll('[data-process-step]').forEach((step) => {
      step.addEventListener('toggle', () => {
        if (step.open) accordion.querySelectorAll('[data-process-step]').forEach((other) => { if (other !== step) other.open = false; });
      });
    });
  });
</script>
