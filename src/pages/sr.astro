      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
          <SectionHeading title="Zašto moderne firme biraju RoutineForge" eyebrow="Partner za rast" />
          <div class="mt-8 grid gap-5 lg:grid-cols-[0.85fr_1.15fr]">
            <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-slate-950 via-slate-900 to-sky-950 p-7 text-white sm:p-8">
              <div class="absolute -right-12 -top-12 h-44 w-44 rounded-full bg-sky-400/20 blur-3xl" aria-hidden="true"></div>
              <div class="relative flex h-full flex-col justify-between">
                <div><p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-300">Osmišljeno za saradnju AI-ja i ljudi</p><h3 class="mt-3 text-2xl font-semibold tracking-tight">AI preuzima ponavljajuće zadatke. Vaš tim se posvećuje klijentima.</h3><p class="mt-4 leading-7 text-slate-300">Svaki sistem gradimo sa jednim ciljem: da put od prvog upita do razgovora sa klijentom bude brži i jasniji.</p></div>
                <div class="mt-8 flex items-center gap-3 text-sm font-medium text-sky-100"><span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-sky-300/40 bg-sky-400/10">✓</span>Povezano sa vašim postojećim tokom rada</div>
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              {benefits.map((benefit, index) => (
              <div class:list={["group rounded-2xl border border-slate-200 bg-slate-50 p-5 transition duration-300 hover:-translate-y-1 hover:border-sky-200 hover:bg-white hover:shadow-lg", index === 4 && 'sm:col-span-2']}>
                <div class="flex items-center justify-between gap-3"><span class="text-xs font-semibold tracking-[0.16em] text-sky-700">0{index + 1}</span><span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-sky-200 bg-sky-50 text-sm font-semibold text-sky-700 transition group-hover:bg-sky-600 group-hover:text-white">✓</span></div>
                <h3 class="mt-5 font-semibold text-slate-950">{benefit.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600">{benefit.text}</p>
              </div>
            ))}
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Usluge dizajnirane za brzinu, jasnoću i rast" eyebrow="Osnovne usluge" />
        <div class="mt-10 grid gap-6 lg:auto-rows-fr lg:grid-cols-2">
          {services.map((service, index) => (
            <div data-reveal style={`--reveal-delay: ${Math.min(index, 4) * 100}ms`} class:list={[index === services.length - 1 && services.length % 2 === 1 && 'lg:col-span-2 lg:w-[calc((100%-1.5rem)/2)] lg:justify-self-center']}>
              <ServiceCard title={service.title} description={service.description} bullets={service.bullets} bestFor={service.bestFor} bestForLabel="Idealno za" icon={service.icon} href={service.href} linkLabel="Saznajte više" />
            </div>
          ))}
        </div>
      </section>

      <section id="industries" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
       <SectionHeading title="Industrije sa kojima radimo" eyebrow="Prilagođena rešenja" align="center" />
       <p class="mx-auto mt-4 max-w-2xl text-center text-lg leading-8 text-slate-600">Svaki sistem počinje od stvarnog operativnog uskog grla. Zatim gradimo odgovarajući AI tok rada i povezujemo ga sa rezultatom koji vaš tim može da prati.</p>
       <div class="mx-auto mt-10 grid max-w-6xl gap-5 md:grid-cols-2">
         {industries.map((industry, index) => (
           <article data-reveal style={`--reveal-delay: ${Math.min(index, 5) * 80}ms`} class:list={["group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-sky-200 hover:shadow-xl sm:p-7", index === industries.length - 1 && industries.length % 2 === 1 && 'md:col-span-2 md:w-[calc((100%-1.25rem)/2)] md:justify-self-center']}>
             <div class="flex items-center gap-3 border-b border-slate-100 pb-5">
               <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-sky-50 text-2xl ring-1 ring-sky-100">{industry.icon}</span>
               <div class="min-w-0"><h3 class="text-lg font-semibold text-slate-950">{industry.name}</h3><span class="mt-1 inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-slate-500">KPI: {industry.kpi}</span></div>
             </div>
             <dl class="mt-5 space-y-4 text-sm leading-6">
               <div><dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Problem</dt><dd class="mt-1 text-slate-600">{industry.problem}</dd></div>
               <div class="border-l-2 border-sky-200 pl-4"><dt class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-600">AI sistem</dt><dd class="mt-1 font-medium text-slate-700">{industry.system}</dd></div>
               <div class="rounded-2xl bg-emerald-50 px-4 py-3"><dt class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald-700">Rezultat</dt><dd class="mt-1 font-medium text-emerald-950">{industry.result}</dd></div>
             </dl>
           </article>
         ))}
       </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-slate-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.3)] sm:p-10">
          <SectionHeading title="Šta se menja kada su vaši procesi automatizovani" eyebrow="Zašto RoutineForge" align="center" dark />
          <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">24/7</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Ne propuštate pozive ni upite van radnog vremena.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Brzo</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Brzi odgovori i jednostavniji prelaz sa jednog koraka na drugi.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Sigurno</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Pouzdane integracije i jasna osnova za rast.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6">
              <p class="text-4xl font-semibold text-sky-300">Prilagođeno</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">Rešenja prilagođena vašem poslu, a ne generičkim skriptama.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="process" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Kako uvodimo sistem" eyebrow="Jednostavan proces" />
        <div class="mx-auto mt-10 max-w-4xl space-y-3" data-process-accordion>
          {processSteps.map((step, index) => (
            <details data-process-step open={index === 0} data-reveal style={`--reveal-delay: ${index * 100}ms`} class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition open:border-sky-200 open:shadow-md">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 text-left sm:p-6">
                <span class="flex items-center gap-4"><span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sm font-semibold text-sky-700">0{index + 1}</span><span><span class="block text-[11px] font-semibold uppercase tracking-[0.18em] text-sky-700">Faza 0{index + 1}</span><span class="mt-1 block text-lg font-semibold text-slate-950">{step.title}</span></span></span>
                <span class="text-2xl leading-none text-slate-400 transition-transform duration-300 group-open:rotate-45 group-open:text-sky-700">+</span>
              </summary>
              <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 group-open:grid-rows-[1fr]"><div class="overflow-hidden border-t border-slate-100 px-5 py-5 sm:px-6"><p class="text-sm leading-7 text-slate-600">{step.description}</p><ul class="mt-4 space-y-2 text-sm leading-6 text-slate-600">{step.bullets.map((bullet) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-sky-500"></span>{bullet}</li>)}</ul><div class="mt-5 flex flex-wrap items-center gap-3 rounded-xl bg-sky-50 px-4 py-3"><span class="text-xs font-semibold uppercase tracking-wide text-sky-700">Ishod</span><span class="text-sm font-medium text-slate-700">{step.outcome}</span></div><p class="mt-4 text-sm font-semibold text-emerald-700">{step.meta}</p></div></div>
            </details>
          ))}
        </div>
        <div data-reveal class="mx-auto mt-8 max-w-4xl border-t border-sky-200 pt-8">
          <div class="flex flex-col gap-5 rounded-2xl border border-sky-200 bg-sky-50 p-6 sm:flex-row sm:items-center sm:justify-between">
            <div><p class="text-sm font-semibold text-sky-700">Spremni za sledeći korak?</p><h3 class="mt-1 text-xl font-semibold tracking-tight text-slate-950">Hajde da mapiramo proces koji je najvažniji za vaš posao.</h3></div>
            <Button href="#contact" class="shrink-0">Zakažite konsultaciju</Button>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal class="relative overflow-hidden rounded-[2rem] border border-sky-400/20 bg-slate-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.45)] sm:p-10">
          <div class="absolute -right-24 -top-28 h-72 w-72 rounded-full bg-sky-400/15 blur-3xl" aria-hidden="true"></div>
          <div class="relative grid gap-8 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300">Dokaz, ne obećanje</p>
              <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white">Brojevi iza bržih, pametnijih operacija</h2>
              <p class="mt-4 max-w-md leading-7 text-slate-300">Sisteme gradimo oko uskih grla koje vaš tim vidi — i poboljšanja koja možete da izmerite.</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              {stats.map((stat) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:border-sky-300/50 hover:bg-sky-400/10">
                  <p class="text-4xl font-semibold text-sky-300">
                    {stat.countTo ? (
                      <span data-counter data-target={stat.countTo} data-suffix={stat.suffix}>{stat.countTo}{stat.suffix}</span>
                    ) : (
                      stat.value
                    )}
                  </p>
                  <p class="mt-2 text-sm font-medium text-slate-300">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="testimonials" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <Testimonials
          eyebrow="Utisci klijenata"
          title="Poverenje timova koji su automatizovali svoje procese uz RoutineForge"
          testimonials={testimonials}
          previousLabel="Prethodni utisak"
          nextLabel="Sledeći utisak"
        />
      </section>

      <section id="faq" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <SectionHeading title="Često postavljana pitanja" eyebrow="Česta pitanja" />
        <div class="mt-10 space-y-4">
          {faqItems.map((item, index) => (
            <details data-reveal style={`--reveal-delay: ${Math.min(index, 4) * 80}ms`} class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-base font-semibold text-slate-950">
                <span>{item.question}</span>
                <span class="text-xl text-slate-400 transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="roi" class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div data-reveal>
          <ROICalculator
            eyebrow="ROI kalkulator"
            title="Vidite koliko bi vam automatizacija vredela"
            description="Pomerite klizače da odgovaraju vašem poslovanju i vidite procenu na osnovu tipičnih rezultata RoutineForge klijenata."
            currency="€"
            inquiriesLabel="Upiti klijenata mesečno"
            avgValueLabel="Prosečna vrednost po novom klijentu"
            adminHoursLabel="Sati nedeljno na administraciji"
            recoveredLeadsLabel="Dodatno pridobijeni klijenti mesečno"
            extraRevenueLabel="Procenjen dodatni mesečni prihod"
            hoursSavedLabel="Ušteđeni sati nedeljno"
            disclaimer="Ovo su samo procene, zasnovane na tipičnim rezultatima RoutineForge klijenata. Stvarni rezultati zavise od poslovanja."
          />
        </div>
      </section>

      <section id="contact" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
        <div data-reveal class="rounded-[2rem] border border-slate-200 bg-gradient-to-br from-slate-950 via-slate-900 to-sky-950 p-8 text-white shadow-[0_30px_90px_-20px_rgba(15,23,42,0.4)] sm:p-10">
          <div class="max-w-3xl">
            <p class="inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-sm font-semibold text-sky-300">Kontakt</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">Izgradimo AI sistem za vaš tim.</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">Recite nam nešto o svom poslu, a mi ćemo osmisliti strategiju automatizacije koja odgovara vašem timu.</p>
          </div>
          <MultiStepContactForm
            industries={industries}
            services={services}
            labels={{
              step: 'Korak', of: 'od', industryTitle: 'Čime se bavite?', serviceTitle: 'Koja usluga vas najviše zanima?', detailsTitle: 'Kako možemo da vas kontaktiramo?', next: 'Nastavi', back: 'Nazad', submit: 'Pošaljite zahtev za konsultaciju', name: 'Ime i prezime', email: 'E-mail', phone: 'Telefon', message: 'Opišite problem koji želite da rešite.', success: 'Hvala — javićemo vam se uskoro.'
            }}
          />
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('[data-process-accordion]').forEach((accordion) => {
    accordion.querySelectorAll('[data-process-step]').forEach((step) => {
      step.addEventListener('toggle', () => {
        if (step.open) accordion.querySelectorAll('[data-process-step]').forEach((other) => { if (other !== step) other.open = false; });
      });
    });
  });
</script>
