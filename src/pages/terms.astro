---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegalDocument from '../components/LegalDocument.astro';
import { SITE_URL } from '../config/site';
---

<BaseLayout
  title="Terms of Use"
  description="Terms governing the use of the RoutineForge website."
  canonical={`${SITE_URL}/terms/`}
  enUrl={`${SITE_URL}/terms/`}
  srUrl={`${SITE_URL}/sr/terms/`}
>
  <LegalDocument type="terms" />
</BaseLayout>
