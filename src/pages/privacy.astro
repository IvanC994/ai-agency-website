---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegalDocument from '../components/LegalDocument.astro';
import { SITE_URL } from '../config/site';
---

<BaseLayout
  title="Privacy Policy"
  description="Learn how RoutineForge collects, uses, protects, and retains personal data, and how you can exercise your privacy rights."
  canonical={`${SITE_URL}/privacy/`}
  enUrl={`${SITE_URL}/privacy/`}
  srUrl={`${SITE_URL}/sr/privacy/`}
>
  <LegalDocument type="privacy" />
</BaseLayout>
